<!-- Global confirm modal — window.modal.confirm({ title, body, danger, confirmLabel, onConfirm }) -->
<div id="globalModal" class="fixed inset-0 z-[9000] flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200">
  <div class="absolute inset-0 bg-black/60" id="globalModalBackdrop"></div>
  <div id="globalModalPanel" class="relative bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700/60 rounded-2xl shadow-2xl w-full max-w-sm mx-4 transform scale-95 transition-transform duration-200">
    <div class="px-5 pt-5 pb-4">
      <p id="globalModalTitle" class="text-sm font-semibold text-neutral-800 dark:text-white leading-snug"></p>
      <p id="globalModalBody" class="text-xs text-neutral-500 dark:text-neutral-400 mt-1.5 leading-relaxed"></p>
    </div>
    <div class="flex gap-2 px-5 pb-5 justify-end">
      <button id="globalModalCancel" class="px-4 py-2 text-xs font-medium rounded-xl bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">Cancel</button>
      <button id="globalModalConfirm" class="px-4 py-2 text-xs font-medium rounded-xl text-white transition"></button>
    </div>
  </div>
</div>

<script>
(function () {
  if (window.modal) return;

  const overlay  = document.getElementById('globalModal');
  const panel    = document.getElementById('globalModalPanel');
  const title    = document.getElementById('globalModalTitle');
  const body     = document.getElementById('globalModalBody');
  const cancel   = document.getElementById('globalModalCancel');
  const confirmBtn  = document.getElementById('globalModalConfirm');
  const backdrop = document.getElementById('globalModalBackdrop');

  let currentResolve = null;

  function open({ title: t, body: b, danger = true, confirmLabel = 'Confirm', onConfirm }) {
    title.textContent = t || '';
    body.textContent  = b || '';
    confirmBtn.textContent = confirmLabel;
    confirmBtn.className = danger
      ? 'px-4 py-2 text-xs font-medium rounded-xl text-white transition bg-red-600 hover:bg-red-500'
      : 'px-4 py-2 text-xs font-medium rounded-xl text-white transition bg-neutral-900 dark:bg-neutral-700 hover:bg-neutral-800 dark:hover:bg-neutral-600';

    currentResolve = onConfirm || null;

    overlay.classList.remove('opacity-0', 'pointer-events-none');
    panel.classList.remove('scale-95');
    panel.classList.add('scale-100');
  }

  function close() {
    overlay.classList.add('opacity-0', 'pointer-events-none');
    panel.classList.remove('scale-100');
    panel.classList.add('scale-95');
    currentResolve = null;
  }

  cancel.addEventListener('click', close);
  backdrop.addEventListener('click', close);

  confirmBtn.addEventListener('click', () => {
    const fn = currentResolve;
    close();
    if (fn) fn();
  });

  window.modal = { confirm: open };
})();
</script>
