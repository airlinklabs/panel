<% if (installed.failed) { %>
  <div class="bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 p-4 ml-8 mr-8 mt-4 rounded-xl flex items-start gap-3">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 shrink-0 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
    </svg>
    <div>
      <p class="text-sm font-medium text-red-700 dark:text-red-400">Installation failed</p>
      <p class="text-xs text-red-500 dark:text-red-400/70 mt-0.5">An error occurred during installation. Check logs or contact an administrator.</p>
    </div>
  </div>
<% } else if (!installed.installed && !installed.error) { %>
  <div id="installBanner" class="bg-blue-50 dark:bg-blue-500/10 border border-blue-200 dark:border-blue-500/20 p-4 ml-8 mr-8 mt-4 rounded-xl">
    <div class="flex items-start gap-3">
      <svg id="installSpinner" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mt-0.5 shrink-0 text-blue-500 animate-spin" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
      </svg>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-blue-700 dark:text-blue-300">Installing server</p>
        <p id="installStateText" class="text-xs text-blue-500 dark:text-blue-400/80 mt-0.5">Waiting for daemon...</p>
        <div id="installSteps" class="mt-2 space-y-0.5"></div>
      </div>
    </div>
  </div>

  <script>
  (function () {
    const serverUUID = '<%= server.UUID %>';
    const banner = document.getElementById('installBanner');
    const stateText = document.getElementById('installStateText');
    const stepsEl = document.getElementById('installSteps');
    const spinner = document.getElementById('installSpinner');

    const stateMessages = {
      installing: 'Downloading and configuring files...',
      installed:  'Installation complete.',
      failed:     'Installation failed.',
    };

    const steps = [
      'Daemon acknowledged request',
      'Pulling container image',
      'Running install scripts',
      'Configuring server files',
    ];

    let shownSteps = new Set();
    let stepIndex = 0;

    function addStep(label) {
      if (!label || shownSteps.has(label)) return;
      shownSteps.add(label);
      const row = document.createElement('div');
      row.className = 'flex items-center gap-1.5 opacity-0 transition-opacity duration-300';
      row.innerHTML = `<span class="text-[10px] text-emerald-500">✓</span><span class="text-[11px] text-blue-400 dark:text-blue-400/70">${label}</span>`;
      stepsEl.appendChild(row);
      requestAnimationFrame(() => row.classList.remove('opacity-0'));
    }

    const stepTimer = setInterval(() => {
      if (stepIndex < steps.length) addStep(steps[stepIndex++]);
    }, 6000);

    let pollAttempts = 0;

    function poll() {
      fetch(`/server/${serverUUID}/status`)
        .then(r => r.json())
        .then(data => {
          pollAttempts++;
          const state = data.state || (data.installed ? 'installed' : data.failed ? 'failed' : 'installing');
          if (stateMessages[state]) stateText.textContent = stateMessages[state];

          if (state === 'installed') {
            clearInterval(stepTimer);
            clearInterval(poller);
            addStep('Server ready');
            spinner.classList.remove('animate-spin');
            spinner.classList.add('text-emerald-500');
            spinner.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>';
            banner.className = banner.className.replace(/blue/g, 'emerald');
            setTimeout(() => window.location.reload(), 2000);
          } else if (state === 'failed') {
            clearInterval(stepTimer);
            clearInterval(poller);
            spinner.classList.remove('animate-spin', 'text-blue-500');
            spinner.classList.add('text-red-500');
          }
        })
        .catch(() => {});
    }

    const poller = setInterval(poll, 3000);
    poll();
  })();
  </script>
<% } %>
