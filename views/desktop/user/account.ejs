<%- include('../components/header', { title: req.translations.userAccountTitle || 'Account' }) %>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <div class="w-60 h-full">
      <%- include('../components/template') %>
    </div>
    <div id="page-content" class="flex-1 overflow-y-auto pt-16 pb-12">

      <div class="px-8 pt-5 mb-6">
        <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.userAccountTitle || 'Account' %></h1>
        <p class="mt-0.5 text-sm text-neutral-500"><%= req.translations.userAccountText || 'Manage your profile and preferences.' %></p>
      </div>

      <div class="px-8 space-y-6">

        <!-- Profile picture -->
        <div class="bg-neutral-50 dark:bg-white/5 rounded-2xl p-5 border border-neutral-200 dark:border-white/5">
          <p class="text-sm font-medium text-neutral-800 dark:text-white mb-4">Profile picture</p>
          <div class="flex items-center gap-5">
            <img id="avatar-preview"
              src="<%= user.avatar ? user.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(user.username) %>"
              alt="Avatar"
              class="h-16 w-16 rounded-2xl border border-neutral-200 dark:border-white/10 object-cover shrink-0">
            <div class="flex flex-col gap-2">
              <label for="avatar-input" class="cursor-pointer inline-block rounded-xl bg-neutral-100 dark:bg-neutral-700/30 hover:bg-neutral-200 dark:hover:bg-white/10 border border-neutral-200 dark:border-neutral-600/30 px-4 py-2 text-sm font-medium text-neutral-700 dark:text-neutral-300 transition">
                Choose image
              </label>
              <input id="avatar-input" type="file" accept="image/*" class="hidden">
              <p class="text-xs text-neutral-400">JPG, PNG, GIF or WebP — max 2 MB</p>
              <% if (user.avatar) { %>
              <button id="remove-avatar-btn" type="button" class="text-xs text-red-500 hover:text-red-400 text-left transition">Remove picture</button>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Two-column: identity + preferences -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

          <!-- Left: identity -->
          <div class="space-y-4">

            <div class="bg-neutral-50 dark:bg-white/5 rounded-2xl p-5 border border-neutral-200 dark:border-white/5">
              <p class="text-sm font-medium text-neutral-800 dark:text-white mb-4"><%= req.translations.updateAccount || 'Account details' %></p>

              <form id="change-username-form" action="/change-username" method="POST" class="mb-4">
                <%- include('../components/csrf') %>
                <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1.5"><%= req.translations.username || 'Username' %></label>
                <div class="flex gap-2">
                  <input id="username" type="text" name="username" placeholder="<%= user.username %>"
                    class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/30 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors">
                  <button type="submit" id="change-username-btn" disabled
                    class="rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium shrink-0 disabled:opacity-40 disabled:cursor-not-allowed transition">
                    <%= req.translations.update || 'Update' %>
                  </button>
                </div>
                <span id="username-feedback" class="mt-1.5 text-xs text-neutral-400 inline-block"><%= req.translations.checking || 'Checking...' %></span>
              </form>

              <form id="change-email-form" class="mb-4">
                <%- include('../components/csrf') %>
                <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1.5"><%= req.translations.email || 'Email' %></label>
                <div class="flex gap-2">
                  <input id="email" type="email" name="email" placeholder="<%= user.email %>"
                    class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/30 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors">
                  <button type="submit"
                    class="rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium shrink-0 transition">
                    <%= req.translations.update || 'Update' %>
                  </button>
                </div>
              </form>

              <form id="change-description-form" class="mb-4">
                <%- include('../components/csrf') %>
                <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1.5"><%= req.translations.description || 'Description' %></label>
                <textarea id="description" name="description" rows="3"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/30 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors resize-none"
                  placeholder="<%= user.description %>"><%= user.description %></textarea>
                <button type="submit" class="mt-2 rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium transition">
                  <%= req.translations.updateDescription || 'Update' %>
                </button>
              </form>
            </div>

            <div class="bg-neutral-50 dark:bg-white/5 rounded-2xl p-5 border border-neutral-200 dark:border-white/5">
              <p class="text-sm font-medium text-neutral-800 dark:text-white mb-4"><%= req.translations.changePassword || 'Change password' %></p>
              <form id="change-password-form" class="space-y-3">
                <%- include('../components/csrf') %>
                <div>
                  <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1.5"><%= req.translations.currentPassword || 'Current password' %></label>
                  <span id="current-password-feedback" class="text-xs text-neutral-400 block mb-1.5"><%= req.translations.checking || 'Checking...' %></span>
                  <input id="currentPassword" type="password" name="currentPassword" placeholder="••••••••"
                    class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/30 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors">
                </div>
                <div>
                  <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1.5"><%= req.translations.newPassword || 'New password' %></label>
                  <input id="newPassword" type="password" name="newPassword" placeholder="••••••••" disabled
                    class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/30 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors disabled:opacity-50">
                </div>
                <button type="submit"
                  class="rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium transition">
                  <%= req.translations.update_password || 'Update password' %>
                </button>
              </form>
            </div>

          </div>

          <!-- Right: language + 2FA -->
          <div class="space-y-4">

            <div class="bg-neutral-50 dark:bg-white/5 rounded-2xl p-5 border border-neutral-200 dark:border-white/5">
              <p class="text-sm font-medium text-neutral-800 dark:text-white mb-4"><%= req.translations.languagePreference || 'Language' %></p>
              <form id="language-preference-form">
                <%- include('../components/csrf') %>
                <select id="language" name="language"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors mb-3">
                  <option value="en"  <%= req.lang === 'en'  ? 'selected' : '' %>>English</option>
                  <option value="fr"  <%= req.lang === 'fr'  ? 'selected' : '' %>>Français</option>
                  <option value="de"  <%= req.lang === 'de'  ? 'selected' : '' %>>Deutsch</option>
                  <option value="es"  <%= req.lang === 'es'  ? 'selected' : '' %>>Español</option>
                  <option value="pt"  <%= req.lang === 'pt'  ? 'selected' : '' %>>Português</option>
                  <option value="it"  <%= req.lang === 'it'  ? 'selected' : '' %>>Italiano</option>
                  <option value="ru"  <%= req.lang === 'ru'  ? 'selected' : '' %>>Русский</option>
                  <option value="zh"  <%= req.lang === 'zh'  ? 'selected' : '' %>>中文</option>
                  <option value="ja"  <%= req.lang === 'ja'  ? 'selected' : '' %>>日本語</option>
                  <option value="ta"  <%= req.lang === 'ta'  ? 'selected' : '' %>>தமிழ்</option>
                </select>
                <button type="submit"
                  class="rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium transition">
                  <%= req.translations.saveLanguagePreference || 'Save' %>
                </button>
              </form>
            </div>

            <div class="bg-neutral-50 dark:bg-white/5 rounded-2xl p-5 border border-neutral-200 dark:border-white/5">
              <p class="text-sm font-medium text-neutral-800 dark:text-white mb-3"><%= req.translations.twoFactorAuth || 'Two-factor authentication' %></p>
              <% if (user['2fa'] !== true) { %>
              <p class="text-sm text-neutral-500 dark:text-neutral-400">2FA is not yet available.</p>
              <% } else { %>
              <form action="/disable-2fa" method="POST">
                <%- include('../components/csrf') %>
                <button class="rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium transition">
                  <%= req.translations.disable2FA || 'Disable 2FA' %>
                </button>
              </form>
              <% } %>
            </div>

          </div>
        </div>

        <!-- Login history — full width -->
        <div class="bg-neutral-50 dark:bg-white/5 rounded-2xl p-5 border border-neutral-200 dark:border-white/5">
          <p class="text-sm font-medium text-neutral-800 dark:text-white mb-4"><%= req.translations.loginHistory || 'Login history' %></p>
          <div class="overflow-x-auto rounded-xl border border-neutral-200 dark:border-white/5">
            <table class="min-w-full text-sm divide-y divide-neutral-200 dark:divide-white/5">
              <thead class="bg-neutral-100 dark:bg-white/5">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.dateTime || 'Date & Time' %></th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.ipAddress || 'IP Address' %></th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.browserDevice || 'Browser / Device' %></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-100 dark:divide-white/5">
                <% if (loginHistory && loginHistory.length > 0) { %>
                  <% loginHistory.forEach(login => { %>
                  <tr class="hover:bg-neutral-100 dark:hover:bg-white/5 transition-colors">
                    <td class="px-4 py-3 text-neutral-700 dark:text-neutral-300 whitespace-nowrap"><%= new Date(login.timestamp).toLocaleString() %></td>
                    <td class="px-4 py-3 text-neutral-500 dark:text-neutral-400 whitespace-nowrap font-mono text-xs"><%= login.ipAddress || 'Unknown' %></td>
                    <td class="px-4 py-3 text-neutral-400 text-xs truncate max-w-[260px]"><%= login.userAgent || 'Unknown' %></td>
                  </tr>
                  <% }) %>
                <% } else { %>
                <tr><td colspan="3" class="px-4 py-6 text-center text-sm text-neutral-400"><%= req.translations.noLoginHistory || 'No login history available' %></td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include('../components/toast') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const { showToast } = createToastSystem();
  const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
  let submitting = false;

  async function post(url, data) {
    if (submitting) return;
    submitting = true;
    try {
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
        body: JSON.stringify(data),
      });
      const text = await res.text();
      if (res.ok) return { ok: true, text };
      return { ok: false, text };
    } finally {
      submitting = false;
    }
  }

  document.getElementById('change-username-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const input = e.target.querySelector('#username');
    const { ok, text } = await post('/update-username', { newUsername: input.value.trim() });
    if (ok) {
      showToast('Username updated', 'success');
      const sb = document.getElementById('sidebar-username');
      if (sb) sb.textContent = input.value.trim();
      input.placeholder = input.value.trim();
    } else { showToast(text); }
  });

  document.getElementById('change-email-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const { ok, text } = await post('/change-email', { email: e.target.querySelector('#email').value.trim() });
    if (ok) showToast('Email updated', 'success'); else showToast(text);
  });

  document.getElementById('change-description-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const el = e.target.querySelector('#description');
    const { ok, text } = await post('/update-description', { description: el.value.trim() });
    if (ok) { showToast('Description updated', 'success'); el.placeholder = el.value.trim(); } else showToast(text);
  });

  document.getElementById('change-password-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const { ok, text } = await post('/change-password', {
      currentPassword: e.target.querySelector('#currentPassword').value,
      newPassword:     e.target.querySelector('#newPassword').value,
    });
    if (ok) { showToast('Password updated', 'success'); setTimeout(() => location.href = '/login?err=UpdatedCredentials', 1500); }
    else showToast(text);
  });

  // Username availability check
  const usernameInput = document.getElementById('username');
  const usernameBtn   = document.getElementById('change-username-btn');
  const usernameFb    = document.getElementById('username-feedback');
  let usernameTimer;

  usernameInput?.addEventListener('input', () => {
    clearTimeout(usernameTimer);
    usernameTimer = setTimeout(async () => {
      const val = usernameInput.value.trim();
      if (!val) { usernameFb.textContent = ''; usernameBtn.disabled = true; return; }
      try {
        const res = await fetch(`/check-username?username=${encodeURIComponent(val)}`);
        const { exists } = await res.json();
        usernameFb.textContent = exists ? '<%= req.translations.usernameTaken || "Username taken" %>' : '<%= req.translations.usernameIsNotTaken || "Username available" %>';
        usernameBtn.disabled = exists;
      } catch { usernameBtn.disabled = true; }
    }, 500);
  });

  // Password validation
  const currentPwInput = document.getElementById('currentPassword');
  const newPwInput     = document.getElementById('newPassword');
  const pwFeedback     = document.getElementById('current-password-feedback');
  let pwTimer;

  currentPwInput?.addEventListener('input', () => {
    clearTimeout(pwTimer);
    const val = currentPwInput.value.trim();
    if (!val) { pwFeedback.textContent = ''; newPwInput.disabled = true; newPwInput.value = ''; return; }
    pwTimer = setTimeout(async () => {
      try {
        const res = await fetch('/validate-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
          body: JSON.stringify({ currentPassword: val }),
        });
        const { valid } = await res.json();
        pwFeedback.textContent = valid ? '<%= req.translations.correctPassword || "Correct" %>' : '<%= req.translations.incorrectPassword || "Incorrect password" %>';
        newPwInput.disabled = !valid;
      } catch { pwFeedback.textContent = 'Could not validate'; newPwInput.disabled = true; }
    }, 500);
  });

  // Language
  document.getElementById('language-preference-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const lang = e.target.querySelector('#language').value;
    const res = await fetch('/set-language', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
      body: JSON.stringify({ language: lang }),
    });
    if (res.ok) { showToast('Language saved', 'success'); setTimeout(() => location.reload(), 1400); }
    else showToast('Failed to save language', 'error');
  });

  // Avatar
  const avatarInput   = document.getElementById('avatar-input');
  const avatarPreview = document.getElementById('avatar-preview');

  avatarInput?.addEventListener('change', e => {
    const file = e.target.files[0];
    if (!file) return;
    if (file.size > 2 * 1024 * 1024) { showToast('Image must be under 2 MB', 'error'); return; }
    const reader = new FileReader();
    reader.onload = evt => openCropPopup(evt.target.result, csrfToken);
    reader.readAsDataURL(file);
    avatarInput.value = '';
  });

  document.getElementById('remove-avatar-btn')?.addEventListener('click', async () => {
    const res = await fetch('/remove-avatar', { method: 'POST', headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken } });
    if (res.ok) {
      avatarPreview.src = 'https://api.dicebear.com/9.x/thumbs/svg?seed=<%= encodeURIComponent(user.username) %>';
      showToast('Profile picture removed', 'success');
      setTimeout(() => location.reload(), 1200);
    } else showToast('Failed to remove picture', 'error');
  });

  function openCropPopup(dataUrl, csrf) {
    const overlay = document.createElement('div');
    overlay.className = 'fixed inset-0 z-[9999] bg-black/70 flex items-center justify-center p-4';
    overlay.innerHTML = `
      <div class="bg-white dark:bg-neutral-900 rounded-2xl shadow-2xl border border-neutral-200 dark:border-white/10 w-full max-w-lg overflow-hidden">
        <div class="flex items-center justify-between px-5 pt-5 pb-3 border-b border-neutral-100 dark:border-white/5">
          <div>
            <p class="text-sm font-semibold text-neutral-800 dark:text-white">Position your photo</p>
            <p class="text-xs text-neutral-500 mt-0.5">Drag and resize the selection box.</p>
          </div>
          <button id="crop-cancel" class="w-7 h-7 flex items-center justify-center rounded-lg text-neutral-400 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="relative bg-neutral-950 select-none overflow-hidden" style="height:340px" id="crop-stage">
          <img id="crop-img" src="${dataUrl}" draggable="false" style="position:absolute;top:0;left:0;user-select:none;max-width:none"/>
          <div id="crop-box" style="position:absolute;border:2px solid white;box-shadow:0 0 0 9999px rgba(0,0,0,0.55);cursor:move;box-sizing:border-box">
            <div class="crop-handle" data-dir="nw" style="position:absolute;top:-5px;left:-5px;width:10px;height:10px;background:white;border-radius:50%;cursor:nw-resize"></div>
            <div class="crop-handle" data-dir="ne" style="position:absolute;top:-5px;right:-5px;width:10px;height:10px;background:white;border-radius:50%;cursor:ne-resize"></div>
            <div class="crop-handle" data-dir="sw" style="position:absolute;bottom:-5px;left:-5px;width:10px;height:10px;background:white;border-radius:50%;cursor:sw-resize"></div>
            <div class="crop-handle" data-dir="se" style="position:absolute;bottom:-5px;right:-5px;width:10px;height:10px;background:white;border-radius:50%;cursor:se-resize"></div>
          </div>
        </div>
        <div class="flex gap-3 px-5 py-4 border-t border-neutral-100 dark:border-white/5">
          <button id="crop-cancel-btn" class="flex-1 rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 py-2.5 text-sm font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition">Cancel</button>
          <button id="crop-save" class="flex-1 rounded-xl bg-neutral-950 dark:bg-white py-2.5 text-sm font-medium text-white dark:text-neutral-900 hover:bg-neutral-800 dark:hover:bg-neutral-100 transition">Save photo</button>
        </div>
      </div>`;
    document.body.appendChild(overlay);

    const stage = document.getElementById('crop-stage');
    const img   = document.getElementById('crop-img');
    const box   = document.getElementById('crop-box');
    const stageW = stage.offsetWidth, stageH = stage.offsetHeight;

    img.onload = () => {
      const scale = Math.min(stageW / img.naturalWidth, stageH / img.naturalHeight);
      const dw = img.naturalWidth * scale, dh = img.naturalHeight * scale;
      img.style.width = dw + 'px'; img.style.height = dh + 'px';
      img.style.left = ((stageW - dw) / 2) + 'px'; img.style.top = ((stageH - dh) / 2) + 'px';
      img._scale = scale; img._offX = (stageW - dw) / 2; img._offY = (stageH - dh) / 2;
      const bs = Math.min(dw, dh, 200);
      box.style.width = bs + 'px'; box.style.height = bs + 'px';
      box.style.left = ((stageW - bs) / 2) + 'px'; box.style.top = ((stageH - bs) / 2) + 'px';
    };
    if (img.complete) img.onload();

    let action = null, sx, sy, sb;
    const clamp = (v, a, b) => Math.max(a, Math.min(b, v));

    box.addEventListener('mousedown', e => {
      if (e.target.classList.contains('crop-handle')) return;
      e.preventDefault(); action = 'move'; sx = e.clientX; sy = e.clientY;
      sb = { l: parseInt(box.style.left), t: parseInt(box.style.top), w: box.offsetWidth, h: box.offsetHeight };
    });
    box.querySelectorAll('.crop-handle').forEach(h => h.addEventListener('mousedown', e => {
      e.preventDefault(); e.stopPropagation(); action = h.dataset.dir; sx = e.clientX; sy = e.clientY;
      sb = { l: parseInt(box.style.left), t: parseInt(box.style.top), w: box.offsetWidth, h: box.offsetHeight };
    }));

    const onUp = () => action = null;
    const onMove = e => {
      if (!action) return;
      const dx = e.clientX - sx, dy = e.clientY - sy, min = 60;
      if (action === 'move') {
        box.style.left = clamp(sb.l + dx, 0, stageW - sb.w) + 'px';
        box.style.top  = clamp(sb.t + dy, 0, stageH - sb.h) + 'px';
      } else {
        let l = sb.l, t = sb.t, w = sb.w, h = sb.h;
        if (action.includes('e')) w = Math.max(min, sb.w + dx);
        if (action.includes('s')) h = Math.max(min, sb.h + dy);
        if (action.includes('w')) { const nw = Math.max(min, sb.w - dx); l = sb.l + (sb.w - nw); w = nw; }
        if (action.includes('n')) { const nh = Math.max(min, sb.h - dy); t = sb.t + (sb.h - nh); h = nh; }
        l = clamp(l, 0, stageW - min); t = clamp(t, 0, stageH - min);
        w = Math.min(w, stageW - l); h = Math.min(h, stageH - t);
        box.style.left = l + 'px'; box.style.top = t + 'px';
        box.style.width = w + 'px'; box.style.height = h + 'px';
      }
    };

    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);

    const close = () => { document.removeEventListener('mousemove', onMove); document.removeEventListener('mouseup', onUp); overlay.remove(); };
    document.getElementById('crop-cancel').addEventListener('click', close);
    document.getElementById('crop-cancel-btn').addEventListener('click', close);

    document.getElementById('crop-save').addEventListener('click', () => {
      const scale = img._scale, offX = img._offX, offY = img._offY;
      const boxL = parseInt(box.style.left), boxT = parseInt(box.style.top);
      const canvas = document.createElement('canvas');
      canvas.width = 256; canvas.height = 256;
      canvas.getContext('2d').drawImage(img, (boxL - offX) / scale, (boxT - offY) / scale, box.offsetWidth / scale, box.offsetHeight / scale, 0, 0, 256, 256);
      canvas.toBlob(async blob => {
        const form = new FormData();
        form.append('avatar', blob, 'avatar.png');
        try {
          const res = await fetch('/upload-avatar', { method: 'POST', headers: { 'CSRF-Token': csrf }, body: form });
          if (res.ok) {
            const { avatar } = await res.json();
            avatarPreview.src = avatar + '?t=' + Date.now();
            showToast('Profile picture updated', 'success');
            close();
          } else showToast('Failed to upload', 'error');
        } catch { showToast('Failed to upload', 'error'); }
      }, 'image/png');
    });
  }
});
</script>

