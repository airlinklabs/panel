<%- include('../components/header', { title: 'Servers' }) %>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <div class="w-60 h-full">
      <%- include('../components/template') %>
    </div>

    <div class="flex-1 overflow-y-auto pt-16">
      <div class="px-12 pt-6 pb-8">

        <div class="flex items-center justify-between mb-6">
          <div>
            <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.userDashboardTitle %></h1>
            <p class="text-sm text-neutral-500 mt-0.5"><%= req.translations.userDashboardText %></p>
          </div>
          <% if (servers && servers.length > 0) { %>
          <div class="flex items-center gap-1 bg-neutral-100 dark:bg-neutral-800/60 p-1 rounded-xl border border-neutral-200 dark:border-white/5">
            <button id="gridViewBtn" class="view-toggle-btn px-3 py-1.5 text-sm font-medium rounded-lg flex items-center gap-1.5 active">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
              </svg>
              Grid
            </button>
            <button id="listViewBtn" class="view-toggle-btn px-3 py-1.5 text-sm font-medium rounded-lg flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
              List
            </button>
          </div>
          <% } %>
        </div>

        <% if (req.query.err === "NOTACTIVEYET") { %>
          <div class="rounded-xl bg-amber-50 dark:bg-amber-800/10 border border-amber-200 dark:border-amber-500/20 px-4 py-3 mb-5">
            <p class="text-sm font-medium text-amber-700 dark:text-amber-400"><%= req.translations.awaitingInstallation || 'Awaiting Installation' %></p>
            <p class="text-xs text-amber-600 dark:text-amber-400/60 mt-0.5"><%= req.translations.awaitingInstallationDesc || "The server isn't installed yet or is in a failed state." %></p>
          </div>
        <% } %>

        <% if (typeof daemonOffline !== 'undefined' && daemonOffline) { %>
          <div class="rounded-xl bg-red-50 dark:bg-red-800/10 border border-red-200 dark:border-red-500/20 px-4 py-3 mb-5">
            <p class="text-sm font-medium text-red-700 dark:text-red-400"><%= req.translations.connectionError || 'Connection Error' %></p>
            <p class="text-xs text-red-600 dark:text-red-400/60 mt-0.5"><%= req.translations.connectionErrorDesc || 'One or more nodes are offline.' %></p>
            <button onclick="window.location.reload()" class="mt-2 px-3 py-1 bg-red-600 text-white text-xs rounded-lg transition-colors"><%= req.translations.retry || 'Retry' %></button>
          </div>
        <% } %>

        <% if (servers.length === 0) { %>
          <div class="flex flex-col items-center justify-center mt-40 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-20 w-20 text-neutral-300 dark:text-neutral-700 mb-4">
              <path fill-rule="evenodd" d="M11.622 1.602a.75.75 0 0 1 .756 0l2.25 1.313a.75.75 0 0 1-.756 1.295L12 3.118 10.128 4.21a.75.75 0 1 1-.756-1.295l2.25-1.313ZM5.898 5.81a.75.75 0 0 1-.27 1.025l-1.14.665 1.14.665a.75.75 0 1 1-.756 1.295L3.75 8.806v.944a.75.75 0 0 1-1.5 0V7.5a.75.75 0 0 1 .372-.648l2.25-1.312a.75.75 0 0 1 1.026.27Zm12.204 0a.75.75 0 0 1 1.026-.27l2.25 1.312a.75.75 0 0 1 .372.648v2.25a.75.75 0 0 1-1.5 0v-.944l-1.122.654a.75.75 0 1 1-.756-1.295l1.14-.665-1.14-.665a.75.75 0 0 1-.27-1.025Zm-9 5.25a.75.75 0 0 1 1.026-.27L12 11.882l1.872-1.092a.75.75 0 1 1 .756 1.295l-1.878 1.096V15a.75.75 0 0 1-1.5 0v-1.82l-1.878-1.095a.75.75 0 0 1-.27-1.025Z" clip-rule="evenodd" />
            </svg>
            <h2 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.noServersYet || 'No servers yet' %></h2>
            <p class="text-sm text-neutral-500 mt-1">
              <% if (user.isAdmin) { %>
                <a href="/admin/servers/create" class="text-blue-500"><%= req.translations.createOneNow || 'Create one now' %></a>
              <% } else { %>
                An admin will assign one to you.
              <% } %>
            </p>
          </div>
        <% } else { %>

          <div id="gridView" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 mb-6">
            <% servers.forEach(server => { %>
              <a href="../server/<%= server.UUID %>" class="block bg-white dark:bg-neutral-800/20 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none p-4 hover:border-neutral-300 dark:hover:border-white/10 hover:shadow-md dark:hover:shadow-none transition-all duration-150 cursor-pointer">
                <div class="flex items-start justify-between mb-3">
                  <div class="min-w-0 flex-1 mr-3">
                    <h3 class="text-sm font-medium text-neutral-900 dark:text-white truncate"><%= server.name %></h3>
                    <% if (server.description) { %>
                      <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5 truncate"><%= server.description %></p>
                    <% } else { %>
                      <p class="text-xs text-neutral-400 mt-0.5 truncate italic"><%= req.translations.noDescription || 'No description' %></p>
                    <% } %>
                  </div>
                  <span class="inline-flex items-center gap-1.5 px-2 py-0.5 text-xs font-medium rounded-md shrink-0
                      <%= server.status === 'running' ? 'bg-emerald-50 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/30' : 'bg-rose-50 dark:bg-rose-500/10 text-rose-600 dark:text-rose-400 border border-rose-200 dark:border-rose-500/20' %>">
                    <span class="relative flex h-1.5 w-1.5">
                      <% if (server.status === 'running') { %>
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
                      <% } else { %>
                        <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-rose-500"></span>
                      <% } %>
                    </span>
                    <%= server.status === 'running' ? 'Running' : 'Stopped' %>
                  </span>
                </div>

                <div class="flex gap-3 mb-3">
                  <div class="flex-1 bg-neutral-100 dark:bg-neutral-700/30 rounded-lg px-3 py-2">
                    <p class="text-[10px] text-neutral-500 dark:text-neutral-400 mb-0.5"><%= req.translations.ram || 'RAM' %></p>
                    <p class="text-sm font-medium text-neutral-700 dark:text-neutral-300"><%= server.ramUsage %>%</p>
                  </div>
                  <div class="flex-1 bg-neutral-100 dark:bg-neutral-700/30 rounded-lg px-3 py-2">
                    <p class="text-[10px] text-neutral-500 dark:text-neutral-400 mb-0.5"><%= req.translations.cpu || 'CPU' %></p>
                    <p class="text-sm font-medium text-neutral-700 dark:text-neutral-300"><%= server.cpuUsage %>%</p>
                  </div>
                  <% if (server.ramLimit) { %>
                  <div class="flex-1 bg-neutral-100 dark:bg-neutral-700/30 rounded-lg px-3 py-2">
                    <p class="text-[10px] text-neutral-500 dark:text-neutral-400 mb-0.5"><%= req.translations.limit || 'Limit' %></p>
                    <p class="text-sm font-medium text-neutral-700 dark:text-neutral-300"><%= server.ramLimit %></p>
                  </div>
                  <% } %>
                </div>

                <div class="flex items-center justify-between pt-2 border-t border-neutral-100 dark:border-white/5">
                  <div class="flex items-center gap-1.5 min-w-0">
                    <img class="h-4 w-4 rounded-full shrink-0" src="<%= server.owner && server.owner.avatar ? server.owner.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(server.owner ? server.owner.username : 'unknown') %>" alt="">
                    <span class="text-xs text-neutral-500 dark:text-neutral-400 truncate"><%= server.owner ? server.owner.username : 'Unknown' %></span>
                  </div>
                  <% if (server.node) { %>
                  <span class="text-xs text-neutral-400 dark:text-neutral-500 shrink-0 ml-2 truncate max-w-[6rem]"><%= server.node.name || server.node.address %></span>
                  <% } %>
                </div>
              </a>
            <% }); %>
          </div>

          <div id="listView" class="rounded-xl border border-neutral-200 dark:border-white/5 overflow-hidden shadow-sm dark:shadow-none hidden">
            <table class="min-w-full divide-y divide-neutral-200 dark:divide-white/5">
              <thead class="bg-neutral-50 dark:bg-neutral-800/20">
                <tr>
                  <th class="py-3 pl-4 pr-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 sm:pl-6"><%= req.translations.serverColumn || 'Server' %></th>
                  <th class="px-3 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.statusColumn || 'Status' %></th>
                  <th class="px-3 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.ownerColumn || 'Owner' %></th>
                  <th class="px-3 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.ram || 'RAM' %></th>
                  <th class="px-3 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.cpu || 'CPU' %></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-100 dark:divide-white/5 bg-white dark:bg-transparent">
                <% servers.forEach(server => { %>
                  <tr onclick="window.location.href = '../server/<%= server.UUID %>';" class="hover:bg-neutral-50 dark:hover:bg-white/5 cursor-pointer transition-colors duration-100">
                    <td class="py-3.5 pl-4 pr-3 sm:pl-6">
                      <div class="text-sm font-medium text-neutral-900 dark:text-white"><%= server.name %></div>
                      <% if (server.description) { %>
                        <div class="text-xs text-neutral-500 dark:text-neutral-400 truncate max-w-[14rem]"><%= server.description %></div>
                      <% } %>
                    </td>
                    <td class="px-3 py-3.5 text-sm">
                      <span class="inline-flex items-center gap-1.5 px-2 py-0.5 text-xs font-medium rounded-md
                          <%= server.status === 'running' ? 'bg-emerald-50 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/30' : 'bg-rose-50 dark:bg-rose-500/10 text-rose-600 dark:text-rose-400 border border-rose-200 dark:border-rose-500/20' %>">
                        <span class="relative flex h-1.5 w-1.5">
                          <% if (server.status === 'running') { %>
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
                          <% } else { %>
                            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-rose-500"></span>
                          <% } %>
                        </span>
                        <%= server.status === 'running' ? 'Running' : 'Stopped' %>
                      </span>
                    </td>
                    <td class="px-3 py-3.5 text-sm text-neutral-600 dark:text-neutral-300">
                      <%= server.owner ? server.owner.username : 'Unknown' %>
                    </td>
                    <td class="px-3 py-3.5 text-sm text-neutral-600 dark:text-neutral-300"><%= server.ramUsage %>%</td>
                    <td class="px-3 py-3.5 text-sm text-neutral-600 dark:text-neutral-300"><%= server.cpuUsage %>%</td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>

          <% if (totalPages > 1) { %>
            <div class="flex items-center justify-center gap-3 mt-6">
              <% if (currentPage > 1) { %>
                <a href="/?page=<%= currentPage - 1 %>" class="px-4 py-2 text-sm font-medium text-neutral-700 dark:text-neutral-300 bg-neutral-100 dark:bg-neutral-800/60 border border-neutral-200 dark:border-white/5 rounded-xl hover:bg-neutral-200 dark:hover:bg-neutral-700/60 transition-colors"><%= req.translations.prev || 'Prev' %></a>
              <% } %>
              <span class="text-sm text-neutral-500"><%= currentPage %> / <%= totalPages %></span>
              <% if (currentPage < totalPages) { %>
                <a href="/?page=<%= currentPage + 1 %>" class="px-4 py-2 text-sm font-medium text-neutral-700 dark:text-neutral-300 bg-neutral-100 dark:bg-neutral-800/60 border border-neutral-200 dark:border-white/5 rounded-xl hover:bg-neutral-200 dark:hover:bg-neutral-700/60 transition-colors"><%= req.translations.next || 'Next' %></a>
              <% } %>
            </div>
          <% } %>

        <% } %>
      </div>
    </div>
  </div>
</main>

<%- include('../components/footer') %>

<style>
  .view-toggle-btn { color: #737373; }
  .view-toggle-btn.active { background: white; color: #171717; }
  .dark .view-toggle-btn { color: #a3a3a3; }
  .dark .view-toggle-btn.active { background: rgba(255,255,255,0.08); color: white; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const gridView = document.getElementById('gridView');
    const listView = document.getElementById('listView');
    const gridViewBtn = document.getElementById('gridViewBtn');
    const listViewBtn = document.getElementById('listViewBtn');

    if (!gridView || !listView || !gridViewBtn || !listViewBtn) return;

    const savedView = localStorage.getItem('serverViewPreference') || 'grid';

    if (savedView === 'list') {
      gridView.classList.add('hidden');
      listView.classList.remove('hidden');
      gridViewBtn.classList.remove('active');
      listViewBtn.classList.add('active');
    }

    gridViewBtn.addEventListener('click', function() {
      gridView.classList.remove('hidden');
      listView.classList.add('hidden');
      gridViewBtn.classList.add('active');
      listViewBtn.classList.remove('active');
      localStorage.setItem('serverViewPreference', 'grid');
    });

    listViewBtn.addEventListener('click', function() {
      gridView.classList.add('hidden');
      listView.classList.remove('hidden');
      gridViewBtn.classList.remove('active');
      listViewBtn.classList.add('active');
      localStorage.setItem('serverViewPreference', 'list');
    });
  });
</script>
