<%- include('../components/header', { title: 'Create Server' }) %>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <div class="w-60 h-full">
      <%- include('../components/template') %>
    </div>
    <div id="page-content" class="flex-1 overflow-y-auto pt-16">
      <div class="px-12 pt-6 pb-8 max-w-3xl">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h1 class="text-base font-medium text-neutral-800 dark:text-white">Create a server</h1>
            <p class="text-sm text-neutral-500 mt-0.5">You have <%= currentCount %> of <%= serverLimit %> servers.</p>
          </div>
          <a href="/" class="text-sm text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition">Cancel</a>
        </div>

        <div class="bg-neutral-50 dark:bg-neutral-800/20 rounded-xl border border-neutral-200 dark:border-white/5 p-6 space-y-6">

          <!-- Name & description -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Name</label>
              <input type="text" id="serverName" placeholder="My server" maxlength="64"
                class="w-full rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/30 focus:outline-none text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2.5 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors">
            </div>
            <div>
              <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Description <span class="text-neutral-400 font-normal">(optional)</span></label>
              <input type="text" id="serverDescription" placeholder="What is this server for?" maxlength="128"
                class="w-full rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/30 focus:outline-none text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2.5 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors">
            </div>
          </div>

          <!-- Node selection -->
          <div>
            <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Node</label>
            <select id="nodeId" class="w-full rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:outline-none text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2.5 text-neutral-800 dark:text-white transition-colors">
              <option value="">Select a node</option>
              <% nodes.forEach(node => { %>
              <option value="<%= node.id %>"><%= node.name %> (<%= node.address %>)</option>
              <% }); %>
            </select>
          </div>

          <!-- Image selection -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Image</label>
              <select id="imageId" class="w-full rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:outline-none text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2.5 text-neutral-800 dark:text-white transition-colors">
                <option value="">Select an image</option>
                <% images.forEach(image => { %>
                <option value="<%= image.id %>" data-docker='<%= image.dockerImages %>'>
                  <%= image.name %>
                </option>
                <% }); %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Docker variant</label>
              <select id="dockerImage" class="w-full rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:outline-none text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2.5 text-neutral-800 dark:text-white transition-colors" disabled>
                <option value="">Select an image first</option>
              </select>
            </div>
          </div>

          <!-- Resources -->
          <div>
            <p class="text-sm font-medium text-neutral-700 dark:text-white mb-3">Resources</p>
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1.5">RAM <span class="text-neutral-400">(MB)</span></label>
                <input type="number" id="Memory" value="512" min="128" max="<%= resourceLimits.maxMemory %>"
                  class="w-full rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:outline-none text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2.5 text-neutral-800 dark:text-white transition-colors">
                <p class="text-[11px] text-neutral-400 mt-1">Max <%= resourceLimits.maxMemory %> MB</p>
              </div>
              <div>
                <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1.5">CPU <span class="text-neutral-400">(%)</span></label>
                <input type="number" id="Cpu" value="100" min="10" max="<%= resourceLimits.maxCpu %>"
                  class="w-full rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:outline-none text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2.5 text-neutral-800 dark:text-white transition-colors">
                <p class="text-[11px] text-neutral-400 mt-1">Max <%= resourceLimits.maxCpu %>%</p>
              </div>
              <div>
                <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1.5">Storage <span class="text-neutral-400">(GB)</span></label>
                <input type="number" id="Storage" value="5" min="1" max="<%= resourceLimits.maxStorage %>"
                  class="w-full rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:outline-none text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2.5 text-neutral-800 dark:text-white transition-colors">
                <p class="text-[11px] text-neutral-400 mt-1">Max <%= resourceLimits.maxStorage %> GB</p>
              </div>
            </div>
          </div>

          <div id="errorMsg" class="hidden rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 px-4 py-3">
            <p class="text-sm text-red-600 dark:text-red-400" id="errorText"></p>
          </div>

          <div class="flex justify-end">
            <button type="button" id="createBtn"
              class="rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-6 py-2.5 text-sm font-medium shadow-sm transition">
              Create server
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<%- include('../components/toast') %>

<script>
  const imageSelect  = document.getElementById('imageId');
  const dockerSelect = document.getElementById('dockerImage');

  imageSelect.addEventListener('change', function () {
    const opt = this.options[this.selectedIndex];
    const raw = opt.dataset.docker;
    dockerSelect.innerHTML = '<option value="">Select variant</option>';
    dockerSelect.disabled = true;
    if (!raw) return;
    try {
      const images = JSON.parse(raw);
      images.forEach(obj => {
        Object.keys(obj).forEach(key => {
          const o = document.createElement('option');
          o.value = key;
          o.textContent = key;
          dockerSelect.appendChild(o);
        });
      });
      dockerSelect.disabled = false;
    } catch {}
  });

  document.getElementById('createBtn').addEventListener('click', async function () {
    const btn = this;
    const errBox  = document.getElementById('errorMsg');
    const errText = document.getElementById('errorText');

    errBox.classList.add('hidden');

    const name        = document.getElementById('serverName').value.trim();
    const description = document.getElementById('serverDescription').value.trim();
    const nodeId      = document.getElementById('nodeId').value;
    const imageId     = document.getElementById('imageId').value;
    const dockerImage = document.getElementById('dockerImage').value;
    const Memory      = document.getElementById('Memory').value;
    const Cpu         = document.getElementById('Cpu').value;
    const Storage     = document.getElementById('Storage').value;

    if (!name || !nodeId || !imageId || !dockerImage) {
      errText.textContent = 'Fill in all required fields.';
      errBox.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Creating...';

    try {
      const r = await fetch('/create-server', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, description, nodeId, imageId, dockerImage, Memory, Cpu, Storage }),
      });
      const d = await r.json();
      if (d.success) {
        window.location.href = '/server/' + d.serverUUID;
      } else {
        errText.textContent = d.error || 'Something went wrong.';
        errBox.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Create server';
      }
    } catch {
      errText.textContent = 'Network error. Try again.';
      errBox.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Create server';
    }
  });
</script>

<%- include('../components/footer') %>
