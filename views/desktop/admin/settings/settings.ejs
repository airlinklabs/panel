<%- include('../../components/header', { title: req.translations.adminSettingsTitle || 'Settings' }) %>

<main class="min-h-screen">
  <div class="flex min-h-screen">
    <div class="w-60 shrink-0">
      <%- include('../../components/template') %>
    </div>
    <div class="flex-1 overflow-y-auto pt-16 pb-12">
      <div class="sm:flex sm:items-center px-8 pt-4">
        <div class="sm:flex-auto">
          <h1 class="text-base font-medium leading-6 text-neutral-800 dark:text-white"><%= req.translations.adminSettingsTitle %></h1>
          <p class="mt-1 tracking-tight text-sm text-neutral-500"><%= req.translations.adminSettingsText %></p>
        </div>
      </div>

      <div class="px-8 mt-5">
        <%- include('../../components/settingsTemplate') %>

        <form id="settingsForm" class="space-y-5" enctype="multipart/form-data">

          <!-- General -->
          <div class="flex flex-col bg-neutral-50 dark:bg-white/5 rounded-xl">
            <h2 class="text-neutral-800 dark:text-white text-[15px] px-5 py-4 mb-1 w-full bg-neutral-100 dark:bg-white/5 rounded-t-xl font-medium"><%= req.translations.general || 'General' %></h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 px-5 py-5">
              <div>
                <label class="block text-neutral-700 dark:text-white text-sm font-medium mb-2"><%= req.translations.siteTitle || 'Site Title' %></label>
                <input
                  type="text"
                  name="title"
                  value="<%= settings.title %>"
                  placeholder="<%= settings.title %>"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/50 focus:outline-none text-sm w-full transition-colors bg-neutral-100 dark:bg-neutral-700/20 hover:bg-neutral-200 dark:hover:bg-white/5 px-4 py-2 text-neutral-800 dark:text-white placeholder-neutral-500 dark:placeholder-neutral-400"
                >
              </div>

              <div>
                <label class="block text-neutral-700 dark:text-white text-sm font-medium mb-2"><%= req.translations.uploadLogo || 'Upload Logo' %></label>
                <input type="file" name="logo" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white file:mr-3 file:py-1 file:px-2 file:rounded-lg file:border-0 file:text-xs file:bg-neutral-200 dark:file:bg-neutral-600 file:text-neutral-700 dark:file:text-neutral-300">
                <% if (settings.logo) { %>
                <div class="mt-2">
                  <p class="text-neutral-600 dark:text-white text-xs mb-1"><%= req.translations.currentLogo || 'Current Logo' %>:</p>
                  <img src="<%= settings.logo.startsWith('/') ? settings.logo : '/' + settings.logo %>" alt="Current Logo" class="h-10 object-contain">
                </div>
                <% } %>
              </div>

              <div>
                <label class="block text-neutral-700 dark:text-white text-sm font-medium mb-2"><%= req.translations.uploadFavicon || 'Upload Favicon' %></label>
                <input type="file" name="favicon" accept=".ico,.png,.jpg,.jpeg" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white file:mr-3 file:py-1 file:px-2 file:rounded-lg file:border-0 file:text-xs file:bg-neutral-200 dark:file:bg-neutral-600 file:text-neutral-700 dark:file:text-neutral-300">
                <% if (settings.favicon && settings.favicon.startsWith('/')) { %>
                <div class="mt-2">
                  <p class="text-neutral-600 dark:text-white text-xs mb-1"><%= req.translations.currentFavicon || 'Current Favicon' %>:</p>
                  <img src="<%= settings.favicon %>" alt="Current Favicon" class="h-6 object-contain">
                </div>
                <% } %>
                <p class="text-neutral-400 text-xs mt-1"><%= req.translations.faviconUploadHelp || 'Accepts .ico, .png, or .jpg — auto-converted to 32x32 .ico.' %></p>
              </div>

              <div>
                <label class="block text-neutral-700 dark:text-white text-sm font-medium mb-2"><%= req.translations.uploadLimit || 'Upload File Size Limit' %></label>
                <div class="relative">
                  <input
                    type="number"
                    name="uploadLimit"
                    value="<%= settings.uploadLimit %>"
                    min="1"
                    max="10240"
                    class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/50 focus:outline-none text-sm w-full transition-colors bg-neutral-100 dark:bg-neutral-700/20 hover:bg-neutral-200 dark:hover:bg-white/5 px-4 py-2 pr-14 text-neutral-800 dark:text-white"
                  >
                  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-neutral-400 pointer-events-none">MB</span>
                </div>
                <p class="mt-1 text-xs text-neutral-500"><%= req.translations.uploadLimitHelp || 'Maximum file size users can upload, in megabytes.' %></p>
              </div>
              <div>
                <label class="block text-neutral-700 dark:text-white text-sm font-medium mb-2">VirusTotal API Key</label>
                <div class="relative">
                  <input
                    type="password"
                    name="virusTotalApiKey"
                    value="<%= settings.virusTotalApiKey || '' %>"
                    placeholder="Paste your API key"
                    autocomplete="off"
                    class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/50 focus:outline-none text-sm w-full transition-colors bg-neutral-100 dark:bg-neutral-700/20 hover:bg-neutral-200 dark:hover:bg-white/5 px-4 py-2 pr-16 text-neutral-800 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-500 font-mono"
                  >
                  <button type="button" onclick="const i=this.previousElementSibling;i.type=i.type==='password'?'text':'password';this.textContent=i.type==='password'?'Show':'Hide';" class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition-colors">Show</button>
                </div>
                <p class="mt-1 text-xs text-neutral-500">Used by Radar. Free tier: 4/min · 500/day. <a href="https://www.virustotal.com" target="_blank" rel="noopener" class="text-blue-500 hover:underline">virustotal.com</a></p>
                <% if (settings.virusTotalApiKey) { %>
                  <p class="mt-1 text-xs text-emerald-600 dark:text-emerald-400">Key is set — leave blank to keep it.</p>
                <% } %>
              </div>
            </div>

            <div class="px-5 pb-5">
              <label class="block text-neutral-700 dark:text-white text-sm font-medium mb-2"><%= req.translations.allowRegistration || 'Allow Registration' %></label>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" name="allowRegistration" value="true" class="sr-only peer" <%= settings.allowRegistration ? 'checked' : '' %>>
                <div class="w-11 h-6 bg-neutral-300 dark:bg-neutral-600 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-neutral-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                <span class="ml-3 text-sm font-medium text-neutral-600 dark:text-neutral-400"><%= req.translations.allowRegistrationDescription || 'Enable new user registration' %></span>
              </label>
              <p class="mt-1 text-xs text-neutral-500"><%= req.translations.allowRegistrationHelp || 'When disabled, only the first user can register.' %></p>
            </div>
          </div>

          <!-- Themes -->
          <div class="flex flex-col bg-neutral-50 dark:bg-white/5 rounded-xl">
            <h2 class="text-neutral-800 dark:text-white text-[15px] px-5 py-4 mb-1 w-full bg-neutral-100 dark:bg-white/5 rounded-t-xl font-medium">Themes</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 px-5 py-5">

              <!-- Light mode theme -->
              <div>
                <label class="block text-neutral-700 dark:text-white text-sm font-medium mb-1">Light Mode Theme</label>
                <p class="text-xs text-neutral-500 mb-3">Applied when the panel is in light mode.</p>
                <div class="space-y-2">
                  <% const lightVal = settings.lightTheme || 'default'; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= lightVal === 'default' ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="lightTheme" value="default" class="sr-only" <%= lightVal === 'default' ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= lightVal === 'default' ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (lightVal === 'default') { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <span class="text-sm text-neutral-700 dark:text-neutral-300">Default</span>
                    <span class="ml-auto text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full">built-in</span>
                  </label>

                  <% allThemes.filter(t => t.name !== 'default').forEach(function(theme) { %>
                  <% const lightThemeVal = theme.lightPath || theme.path; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= lightVal === lightThemeVal ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="lightTheme" value="<%= lightThemeVal %>" class="sr-only" <%= lightVal === lightThemeVal ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= lightVal === lightThemeVal ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (lightVal === lightThemeVal) { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <div class="flex-1 min-w-0">
                      <span class="text-sm text-neutral-700 dark:text-neutral-300 capitalize block"><%= theme.name.replace(/-/g, ' ') %></span>
                      <% if (theme.author) { %><span class="text-xs text-neutral-400">by <%= theme.author %></span><% } %>
                    </div>
                    <span class="ml-auto text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full shrink-0"><%= theme.builtin ? 'built-in' : 'custom' %></span>
                  </label>
                  <% }); %>
                </div>
              </div>

              <!-- Dark mode theme -->
              <div>
                <label class="block text-neutral-700 dark:text-white text-sm font-medium mb-1">Dark Mode Theme</label>
                <p class="text-xs text-neutral-500 mb-3">Applied when the panel is in dark mode.</p>
                <div class="space-y-2">
                  <% const darkVal = settings.darkTheme || 'default'; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= darkVal === 'default' ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="darkTheme" value="default" class="sr-only" <%= darkVal === 'default' ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= darkVal === 'default' ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (darkVal === 'default') { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <span class="text-sm text-neutral-700 dark:text-neutral-300">Default</span>
                    <span class="ml-auto text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full">built-in</span>
                  </label>

                  <% allThemes.filter(t => t.name !== 'default').forEach(function(theme) { %>
                  <% const darkThemeVal = theme.darkPath || theme.path; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= darkVal === darkThemeVal ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="darkTheme" value="<%= darkThemeVal %>" class="sr-only" <%= darkVal === darkThemeVal ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= darkVal === darkThemeVal ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (darkVal === darkThemeVal) { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <div class="flex-1 min-w-0">
                      <span class="text-sm text-neutral-700 dark:text-neutral-300 capitalize block"><%= theme.name.replace(/-/g, ' ') %></span>
                      <% if (theme.author) { %><span class="text-xs text-neutral-400">by <%= theme.author %></span><% } %>
                    </div>
                    <span class="ml-auto text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full shrink-0"><%= theme.builtin ? 'built-in' : 'custom' %></span>
                  </label>
                  <% }); %>
                </div>
              </div>
            </div>

            <!-- Upload custom theme -->
            <div class="px-5 pb-5 border-t border-neutral-200 dark:border-white/5 pt-4">
              <div class="flex items-center justify-between mb-1">
                <label class="block text-neutral-700 dark:text-white text-sm font-medium">Upload Custom Theme</label>
                <a href="/admin/settings/example-theme" class="text-xs text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" /></svg>
                  Download example
                </a>
              </div>
              <p class="text-xs text-neutral-500 mb-3">Upload a theme.zip containing <code class="text-xs bg-neutral-100 dark:bg-neutral-700/40 px-1 py-0.5 rounded">info.json</code>, <code class="text-xs bg-neutral-100 dark:bg-neutral-700/40 px-1 py-0.5 rounded">light.css</code>, and <code class="text-xs bg-neutral-100 dark:bg-neutral-700/40 px-1 py-0.5 rounded">dark.css</code>.</p>
              <div class="flex items-center gap-3">
                <input type="file" name="themeFile" accept=".zip" class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white file:mr-3 file:py-1 file:px-2 file:rounded-lg file:border-0 file:text-xs file:bg-neutral-200 dark:file:bg-neutral-600 file:text-neutral-700 dark:file:text-neutral-300">
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex justify-end items-center space-x-4">
            <button
              type="button"
              id="resetButton"
              class="rounded-lg bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-800 px-3 py-2 text-sm font-medium shadow-md transition"
            >
              <%= req.translations.resetToDefault || 'Reset to Default' %>
            </button>
            <button
              type="submit"
              class="rounded-lg bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-800 px-6 py-2 text-sm font-medium shadow-md transition"
            >
              <%= req.translations.saveSettings || 'Save Settings' %>
            </button>
          </div>

        </form>
      </div>
    </div>
  </div>
</main>

<%- include('../../components/toast') %>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('settingsForm');
    const faviconInput = form.querySelector('input[name="favicon"]');

    faviconInput.addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file || file.name.toLowerCase().endsWith('.ico')) return;
      try {
        const canvas = document.createElement('canvas');
        canvas.width = 32;
        canvas.height = 32;
        const img = new Image();
        img.onload = () => {
          canvas.getContext('2d').drawImage(img, 0, 0, 32, 32);
          canvas.toBlob(blob => {
            const dt = new DataTransfer();
            dt.items.add(new File([blob], 'favicon.ico', { type: 'image/x-icon' }));
            faviconInput.files = dt.files;
            showToast('<%= req.translations.imageConvertedToFavicon || "Image converted to favicon format" %>', 'success');
          }, 'image/x-icon');
        };
        img.src = URL.createObjectURL(file);
      } catch {
        showToast('<%= req.translations.failedToConvertImage || "Failed to convert image to favicon" %>', 'error');
      }
    });

    // Live radio button highlight on click
    form.querySelectorAll('input[type="radio"]').forEach(radio => {
      radio.addEventListener('change', () => {
        const group = form.querySelectorAll(`input[name="${radio.name}"]`);
        group.forEach(r => {
          const label = r.closest('label');
          const dot = label.querySelector('span > span');
          const ring = label.querySelector('span');
          if (r.checked) {
            label.classList.add('border-blue-400', 'bg-blue-50', 'dark:bg-blue-500/10');
            label.classList.remove('border-neutral-200', 'dark:border-neutral-600/30');
            ring.classList.add('border-blue-500');
            ring.classList.remove('border-neutral-300', 'dark:border-neutral-600');
            if (!dot) {
              const d = document.createElement('span');
              d.className = 'w-2.5 h-2.5 rounded-full bg-blue-500';
              ring.appendChild(d);
            }
          } else {
            label.classList.remove('border-blue-400', 'bg-blue-50', 'dark:bg-blue-500/10');
            label.classList.add('border-neutral-200', 'dark:border-neutral-600/30');
            ring.classList.remove('border-blue-500');
            ring.classList.add('border-neutral-300', 'dark:border-neutral-600');
            if (dot) dot.remove();
          }
        });
      });
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]');
      const original = btn.textContent;
      btn.disabled = true;
      btn.innerHTML = `<svg class="animate-spin -ml-1 mr-2 h-4 w-4 inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Saving...`;

      try {
        const response = await fetch('/admin/settings', {
          method: 'POST',
          body: new FormData(form),
        });
        if (response.ok) {
          showToast('<%= req.translations.settingsSaved || "Settings saved successfully!" %>', 'success');
          setTimeout(() => window.location.reload(), 1500);
        } else {
          const err = await response.json().catch(() => ({}));
          throw new Error(err.error || '<%= req.translations.failedToSaveSettings || "Failed to save settings" %>');
        }
      } catch (error) {
        showToast(error.message, 'error');
        btn.disabled = false;
        btn.textContent = original;
      }
    });

    document.getElementById('resetButton').addEventListener('click', async () => {
      if (!confirm('<%= req.translations.resetSettingsConfirm || "Reset all settings to default?" %>')) return;
      try {
        const response = await fetch('/admin/settings/reset', { method: 'POST' });
        if (response.ok) {
          showToast('<%= req.translations.settingsReset || "Settings reset to default." %>', 'success');
          setTimeout(() => window.location.reload(), 1200);
        } else {
          const err = await response.json().catch(() => ({}));
          showToast(err.error || 'Failed to reset settings.', 'error');
        }
      } catch {
        showToast('Failed to reset settings.', 'error');
      }
    });
  });
</script>

<%- include('../../components/footer') %>
