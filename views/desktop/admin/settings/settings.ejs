<%- include('../../components/header', { title: 'Settings' }) %>

<main class="min-h-screen">
  <div class="flex min-h-screen">
    <div class="w-60 shrink-0">
      <%- include('../../components/template') %>
    </div>
    <div id="page-content" class="flex-1 overflow-y-auto pt-16 pb-12">
      <div class="px-8 pt-5">
        <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.adminSettingsTitle || 'Settings' %></h1>
        <p class="mt-0.5 text-sm text-neutral-500"><%= req.translations.adminSettingsText || 'Manage your panel configuration.' %></p>
      </div>

      <div class="px-8 mt-5">
        <!-- Tab nav -->
        <div class="flex gap-0.5 mb-6 border-b border-neutral-200 dark:border-neutral-700/40">
          <button type="button" data-tab="appearance"
            class="tab-btn px-4 py-2.5 text-sm font-medium transition-colors -mb-px border-b-2">Appearance</button>
          <button type="button" data-tab="configuration"
            class="tab-btn px-4 py-2.5 text-sm font-medium transition-colors -mb-px border-b-2">Configuration</button>
        </div>

        <!-- ── Appearance tab ─────────────────────────────────────────────── -->
        <form id="form-appearance" data-tab-form="appearance" class="tab-form space-y-5 hidden" enctype="multipart/form-data">

          <div class="flex flex-col bg-neutral-50 dark:bg-white/5 rounded-xl">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl">Branding</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 px-5 py-5">
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2"><%= req.translations.siteTitle || 'Site Title' %></label>
                <input type="text" name="title" value="<%= settings.title %>" placeholder="<%= settings.title %>"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/50 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors">
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Logo</label>
                <input type="file" name="logo" accept="image/*"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white file:mr-3 file:py-1 file:px-2 file:rounded-lg file:border-0 file:text-xs file:bg-neutral-200 dark:file:bg-neutral-600 file:text-neutral-700 dark:file:text-neutral-300">
                <% if (settings.logo) { %>
                <img src="<%= settings.logo.startsWith('/') ? settings.logo : '/' + settings.logo %>" alt="Logo" class="h-8 mt-2 object-contain">
                <% } %>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Favicon</label>
                <input type="file" name="favicon" accept=".ico,.png,.jpg,.jpeg"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white file:mr-3 file:py-1 file:px-2 file:rounded-lg file:border-0 file:text-xs file:bg-neutral-200 dark:file:bg-neutral-600 file:text-neutral-700 dark:file:text-neutral-300">
                <% if (settings.favicon && settings.favicon.startsWith('/')) { %>
                <img src="<%= settings.favicon %>" alt="Favicon" class="h-5 mt-2 object-contain">
                <% } %>
                <p class="text-xs text-neutral-400 mt-1">PNG or JPG auto-converted to 32×32 .ico</p>
              </div>
            </div>
          </div>

          <div class="flex flex-col bg-neutral-50 dark:bg-white/5 rounded-xl">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl">Themes</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 px-5 py-5">
              <div>
                <p class="text-sm font-medium text-neutral-700 dark:text-white mb-1">Light mode</p>
                <p class="text-xs text-neutral-500 mb-3">Applied when the panel is in light mode.</p>
                <div class="space-y-2">
                  <% const lightVal = settings.lightTheme || 'default'; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= lightVal === 'default' ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="lightTheme" value="default" class="sr-only" <%= lightVal === 'default' ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= lightVal === 'default' ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (lightVal === 'default') { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <span class="text-sm text-neutral-700 dark:text-neutral-300 flex-1">Default</span>
                    <span class="text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full">built-in</span>
                  </label>
                  <% allThemes.filter(t => t.name !== 'default').forEach(function(theme) { %>
                  <% const ltv = theme.lightPath || theme.path; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= lightVal === ltv ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="lightTheme" value="<%= ltv %>" class="sr-only" <%= lightVal === ltv ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= lightVal === ltv ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (lightVal === ltv) { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <div class="flex-1 min-w-0">
                      <span class="text-sm text-neutral-700 dark:text-neutral-300 capitalize block"><%= theme.name.replace(/-/g,' ') %></span>
                      <% if (theme.author) { %><span class="text-xs text-neutral-400">by <%= theme.author %></span><% } %>
                    </div>
                    <span class="text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full shrink-0"><%= theme.builtin ? 'built-in' : 'custom' %></span>
                  </label>
                  <% }); %>
                </div>
              </div>
              <div>
                <p class="text-sm font-medium text-neutral-700 dark:text-white mb-1">Dark mode</p>
                <p class="text-xs text-neutral-500 mb-3">Applied when the panel is in dark mode.</p>
                <div class="space-y-2">
                  <% const darkVal = settings.darkTheme || 'default'; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= darkVal === 'default' ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="darkTheme" value="default" class="sr-only" <%= darkVal === 'default' ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= darkVal === 'default' ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (darkVal === 'default') { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <span class="text-sm text-neutral-700 dark:text-neutral-300 flex-1">Default</span>
                    <span class="text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full">built-in</span>
                  </label>
                  <% allThemes.filter(t => t.name !== 'default').forEach(function(theme) { %>
                  <% const dtv = theme.darkPath || theme.path; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= darkVal === dtv ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="darkTheme" value="<%= dtv %>" class="sr-only" <%= darkVal === dtv ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= darkVal === dtv ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (darkVal === dtv) { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <div class="flex-1 min-w-0">
                      <span class="text-sm text-neutral-700 dark:text-neutral-300 capitalize block"><%= theme.name.replace(/-/g,' ') %></span>
                      <% if (theme.author) { %><span class="text-xs text-neutral-400">by <%= theme.author %></span><% } %>
                    </div>
                    <span class="text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full shrink-0"><%= theme.builtin ? 'built-in' : 'custom' %></span>
                  </label>
                  <% }); %>
                </div>
              </div>
            </div>
            <div class="px-5 pb-5 border-t border-neutral-200 dark:border-white/5 pt-4">
              <div class="flex items-center justify-between mb-2">
                <p class="text-sm font-medium text-neutral-700 dark:text-white">Upload custom theme</p>
                <a href="/admin/settings/example-theme" class="text-xs text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition">Download example</a>
              </div>
              <p class="text-xs text-neutral-500 mb-3">A .zip containing <code class="bg-neutral-100 dark:bg-neutral-700/40 px-1 py-0.5 rounded text-xs">info.json</code>, <code class="bg-neutral-100 dark:bg-neutral-700/40 px-1 py-0.5 rounded text-xs">light.css</code>, <code class="bg-neutral-100 dark:bg-neutral-700/40 px-1 py-0.5 rounded text-xs">dark.css</code>.</p>
              <input type="file" name="themeFile" accept=".zip"
                class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white file:mr-3 file:py-1 file:px-2 file:rounded-lg file:border-0 file:text-xs file:bg-neutral-200 dark:file:bg-neutral-600 file:text-neutral-700 dark:file:text-neutral-300">
            </div>
          </div>

          <div class="flex justify-end gap-3">
            <button type="submit" class="rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-6 py-2 text-sm font-medium shadow-sm transition">Save</button>
          </div>
        </form>

        <!-- ── Configuration tab ──────────────────────────────────────────── -->
        <div id="panel-configuration" data-tab-panel="configuration" class="tab-panel space-y-5 hidden">

          <!-- General behaviour -->
          <form id="form-general" class="flex flex-col bg-neutral-50 dark:bg-white/5 rounded-xl">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl">General</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 px-5 py-5">
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Upload file size limit</label>
                <div class="relative">
                  <input type="number" name="uploadLimit" value="<%= settings.uploadLimit %>" min="1" max="10240"
                    class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/50 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 pr-12 text-neutral-800 dark:text-white transition-colors">
                  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-neutral-400 pointer-events-none">MB</span>
                </div>
                <p class="mt-1 text-xs text-neutral-500">Maximum file size a user can upload.</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">VirusTotal API key</label>
                <div class="relative">
                  <input type="password" name="virusTotalApiKey" value="<%= settings.virusTotalApiKey || '' %>" placeholder="Paste your key" autocomplete="off"
                    class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/50 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 pr-16 text-neutral-800 dark:text-white placeholder-neutral-400 font-mono transition-colors">
                  <button type="button" onclick="const i=this.previousElementSibling;i.type=i.type==='password'?'text':'password';this.textContent=i.type==='password'?'Show':'Hide';" class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition">Show</button>
                </div>
                <p class="mt-1 text-xs text-neutral-500">Used by Radar. Free tier: 4/min · 500/day. <a href="https://www.virustotal.com" target="_blank" rel="noopener" class="text-blue-500 hover:underline">virustotal.com</a></p>
                <% if (settings.virusTotalApiKey) { %><p class="mt-1 text-xs text-emerald-600 dark:text-emerald-400">Key is set — leave blank to keep it.</p><% } %>
              </div>
            </div>
            <div class="px-5 pb-5 border-t border-neutral-200 dark:border-white/5 pt-4 flex items-center gap-4">
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" name="allowRegistration" value="true" class="sr-only peer" <%= settings.allowRegistration ? 'checked' : '' %>>
                <div class="w-11 h-6 bg-neutral-300 dark:bg-neutral-600 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                <span class="ml-3 text-sm font-medium text-neutral-600 dark:text-neutral-400">Allow registration</span>
              </label>
              <button type="submit" class="ml-auto rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-5 py-2 text-sm font-medium shadow-sm transition">Save</button>
              <button type="button" id="resetButton" class="rounded-xl border border-neutral-200 dark:border-neutral-700/40 text-neutral-600 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white px-4 py-2 text-sm font-medium transition">Reset defaults</button>
            </div>
          </form>

          <!-- Rate limiting -->
          <div class="flex flex-col bg-neutral-50 dark:bg-white/5 rounded-xl">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl">Rate limiting</h2>
            <div class="px-5 py-5 space-y-4">
              <div class="flex items-start gap-4">
                <label class="relative inline-flex items-center cursor-pointer mt-0.5 shrink-0">
                  <input type="checkbox" id="rateLimitEnabled" class="sr-only peer" <%= settings.rateLimitEnabled ? 'checked' : '' %>>
                  <div class="w-11 h-6 bg-neutral-300 dark:bg-neutral-600 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                </label>
                <div>
                  <p class="text-sm font-medium text-neutral-700 dark:text-white">Enable rate limiting</p>
                  <p class="text-xs text-neutral-500 mt-0.5">Caps HTTP requests per IP address per minute, panel-wide.</p>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="relative w-44">
                  <input type="number" id="rateLimitRpm" value="<%= settings.rateLimitRpm || 100 %>" min="1" max="10000"
                    class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/50 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 pr-16 text-neutral-800 dark:text-white transition-colors">
                  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-neutral-400 pointer-events-none">req/min</span>
                </div>
                <button type="button" id="saveRateLimit" class="rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-5 py-2 text-sm font-medium shadow-sm transition">Save</button>
              </div>
            </div>
          </div>

          <!-- IP banning -->
          <div class="flex flex-col bg-neutral-50 dark:bg-white/5 rounded-xl">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl">Banned IPs</h2>
            <div class="px-5 py-5 space-y-3">
              <div class="flex gap-2">
                <input type="text" id="banIpInput" placeholder="e.g. 1.2.3.4"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/50 focus:outline-none text-sm font-mono bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors flex-1 max-w-xs">
                <button type="button" id="banIpBtn" class="rounded-xl bg-red-600 hover:bg-red-500 text-white px-4 py-2 text-sm font-medium transition shrink-0">Ban IP</button>
              </div>
              <div id="bannedIpList" class="space-y-1.5">
                <% let banned = []; try { banned = JSON.parse(settings.bannedIps || '[]'); } catch(e) {} %>
                <% if (banned.length === 0) { %>
                <p class="text-xs text-neutral-400 italic">No IPs are currently banned.</p>
                <% } %>
                <% banned.forEach(function(ip) { %>
                <div class="flex items-center justify-between bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 rounded-xl px-4 py-2.5" data-banned-ip="<%= ip %>">
                  <span class="text-sm font-mono text-neutral-700 dark:text-neutral-300"><%= ip %></span>
                  <button type="button" class="unban-btn text-xs text-red-500 hover:text-red-400 font-medium transition" data-ip="<%= ip %>">Unban</button>
                </div>
                <% }); %>
              </div>
            </div>
          </div>

        </div><!-- end configuration panel -->
      </div>
    </div>
  </div>
</main>

<%- include('../../components/toast') %>

<script>
(function () {
  // ── Tab switching ─────────────────────────────────────────────────────────
  const tabBtns   = document.querySelectorAll('.tab-btn');
  const tabForms  = document.querySelectorAll('.tab-form');
  const tabPanels = document.querySelectorAll('.tab-panel');

  function activate(id) {
    tabBtns.forEach(btn => {
      const on = btn.dataset.tab === id;
      btn.classList.toggle('border-neutral-800',           on);
      btn.classList.toggle('dark:border-white',            on);
      btn.classList.toggle('text-neutral-800',             on);
      btn.classList.toggle('dark:text-white',              on);
      btn.classList.toggle('border-transparent',           !on);
      btn.classList.toggle('text-neutral-500',             !on);
      btn.classList.toggle('dark:text-neutral-400',        !on);
    });
    tabForms.forEach(f  => f.classList.toggle('hidden', f.dataset.tabForm  !== id));
    tabPanels.forEach(p => p.classList.toggle('hidden', p.dataset.tabPanel !== id));
    try { localStorage.setItem('settings_tab', id); } catch {}
  }

  tabBtns.forEach(btn => btn.addEventListener('click', () => activate(btn.dataset.tab)));
  let saved = null;
  try { saved = localStorage.getItem('settings_tab'); } catch {}
  activate(saved || 'appearance');

  // ── Radio highlight ───────────────────────────────────────────────────────
  document.querySelectorAll('input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', () => {
      document.querySelectorAll(`input[name="${radio.name}"]`).forEach(r => {
        const label = r.closest('label');
        const ring  = label?.querySelector('span');
        const dot   = ring?.querySelector('span');
        if (r.checked) {
          label.classList.add('border-blue-400', 'bg-blue-50', 'dark:bg-blue-500/10');
          label.classList.remove('border-neutral-200', 'dark:border-neutral-600/30');
          ring?.classList.add('border-blue-500');
          ring?.classList.remove('border-neutral-300', 'dark:border-neutral-600');
          if (!dot && ring) { const d = document.createElement('span'); d.className = 'w-2.5 h-2.5 rounded-full bg-blue-500'; ring.appendChild(d); }
        } else {
          label.classList.remove('border-blue-400', 'bg-blue-50', 'dark:bg-blue-500/10');
          label.classList.add('border-neutral-200', 'dark:border-neutral-600/30');
          ring?.classList.remove('border-blue-500');
          ring?.classList.add('border-neutral-300', 'dark:border-neutral-600');
          dot?.remove();
        }
      });
    });
  });

  // ── Favicon auto-convert ─────────────────────────────────────────────────
  document.querySelector('input[name="favicon"]')?.addEventListener('change', async e => {
    const file = e.target.files[0];
    if (!file || file.name.toLowerCase().endsWith('.ico')) return;
    try {
      const canvas = document.createElement('canvas');
      canvas.width = 32; canvas.height = 32;
      const img = new Image();
      img.onload = () => {
        canvas.getContext('2d').drawImage(img, 0, 0, 32, 32);
        canvas.toBlob(blob => {
          const dt = new DataTransfer();
          dt.items.add(new File([blob], 'favicon.ico', { type: 'image/x-icon' }));
          e.target.files = dt.files;
          showToast('Image converted to favicon format', 'success');
        }, 'image/x-icon');
      };
      img.src = URL.createObjectURL(file);
    } catch { showToast('Failed to convert image', 'error'); }
  });

  // ── Generic form submit ───────────────────────────────────────────────────
  function submitForm(form, url) {
    const btn = form.querySelector('button[type="submit"]');
    const orig = btn?.textContent || '';
    if (btn) { btn.disabled = true; btn.textContent = 'Saving...'; }
    fetch(url, { method: 'POST', body: new FormData(form) })
      .then(r => r.json())
      .then(d => {
        if (d.success) { showToast('Settings saved', 'success'); setTimeout(() => location.reload(), 1400); }
        else throw new Error(d.error || 'Failed to save');
      })
      .catch(err => { showToast(err.message, 'error'); if (btn) { btn.disabled = false; btn.textContent = orig; } });
  }

  document.getElementById('form-appearance').addEventListener('submit', e => { e.preventDefault(); submitForm(e.target, '/admin/settings'); });
  document.getElementById('form-general').addEventListener('submit',    e => { e.preventDefault(); submitForm(e.target, '/admin/settings'); });

  // ── Reset ─────────────────────────────────────────────────────────────────
  document.getElementById('resetButton').addEventListener('click', () => {
    window.modal.confirm({
      title: 'Reset settings',
      body: 'Reset all settings to their defaults?',
      danger: true,
      confirmLabel: 'Reset',
      onConfirm: () => {
        fetch('/admin/settings/reset', { method: 'POST' })
          .then(r => r.json())
          .then(d => {
            if (d.success) { showToast('Settings reset', 'success'); setTimeout(() => location.reload(), 1200); }
            else showToast(d.error || 'Failed', 'error');
          })
          .catch(() => showToast('Failed', 'error'));
      }
    });
  });

  // ── Rate limiting ─────────────────────────────────────────────────────────
  document.getElementById('saveRateLimit').addEventListener('click', function () {
    const btn = this;
    btn.disabled = true; btn.textContent = 'Saving...';
    fetch('/admin/settings/security', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        rateLimitEnabled: document.getElementById('rateLimitEnabled').checked,
        rateLimitRpm:     document.getElementById('rateLimitRpm').value,
      }),
    })
      .then(r => r.json())
      .then(d => { if (d.success) showToast('Saved', 'success'); else showToast(d.error || 'Failed', 'error'); })
      .catch(() => showToast('Failed', 'error'))
      .finally(() => { btn.disabled = false; btn.textContent = 'Save'; });
  });

  // ── IP banning ────────────────────────────────────────────────────────────
  document.getElementById('banIpBtn').addEventListener('click', () => {
    const ip = document.getElementById('banIpInput').value.trim();
    if (!ip) { showToast('Enter an IP address', 'error'); return; }
    fetch('/admin/settings/ban-ip', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ ip }) })
      .then(r => r.json())
      .then(d => {
        if (!d.success) throw new Error(d.error || 'Failed');
        document.getElementById('banIpInput').value = '';
        addBannedRow(ip);
        showToast(`${ip} banned`, 'success');
      })
      .catch(err => showToast(err.message, 'error'));
  });

  function addBannedRow(ip) {
    const list = document.getElementById('bannedIpList');
    list.querySelector('p')?.remove();
    const row = document.createElement('div');
    row.className = 'flex items-center justify-between bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 rounded-xl px-4 py-2.5';
    row.dataset.bannedIp = ip;
    row.innerHTML = `<span class="text-sm font-mono text-neutral-700 dark:text-neutral-300">${ip}</span><button type="button" class="unban-btn text-xs text-red-500 hover:text-red-400 font-medium transition" data-ip="${ip}">Unban</button>`;
    row.querySelector('.unban-btn').addEventListener('click', handleUnban);
    list.appendChild(row);
  }

  function handleUnban() {
    const ip = this.dataset.ip;
    fetch('/admin/settings/unban-ip', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ ip }) })
      .then(r => r.json())
      .then(d => {
        if (!d.success) throw new Error(d.error || 'Failed');
        document.querySelector(`[data-banned-ip="${ip}"]`)?.remove();
        const list = document.getElementById('bannedIpList');
        if (!list.querySelector('[data-banned-ip]')) {
          const p = document.createElement('p'); p.className = 'text-xs text-neutral-400 italic'; p.textContent = 'No IPs are currently banned.';
          list.appendChild(p);
        }
        showToast(`${ip} unbanned`, 'success');
      })
      .catch(err => showToast(err.message, 'error'));
  }

  document.querySelectorAll('.unban-btn').forEach(btn => btn.addEventListener('click', handleUnban.bind(btn)));
})();
</script>

