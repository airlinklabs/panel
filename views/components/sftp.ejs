
<button onclick="openSftpModal()" type="button" aria-label="Open SFTP access"
  class="inline-flex items-center gap-1.5 rounded-xl border border-neutral-200 dark:border-white/10
         bg-white dark:bg-neutral-800 hover:bg-neutral-50 dark:hover:bg-neutral-700/60
         text-neutral-700 dark:text-neutral-300 px-3 py-1.5 text-xs font-medium
         shadow-sm transition duration-200 focus-visible:outline-none focus-visible:ring-2
         focus-visible:ring-neutral-400">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
    <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.75 8.25v-3a3.75 3.75 0 1 0-7.5 0v3h7.5Z" clip-rule="evenodd" />
  </svg>
  SFTP
</button>


<div id="sftpModal" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200">

  
  <div onclick="closeSftpModal()" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  
  <div class="relative bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-white/10 rounded-2xl shadow-2xl w-full max-w-md mx-4 anim-scale-in">

    
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-200 dark:border-white/5">
      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-neutral-100 dark:bg-white/5">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-neutral-500 dark:text-neutral-300">
            <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.75 8.25v-3a3.75 3.75 0 1 0-7.5 0v3h7.5Z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <h2 class="text-sm font-semibold text-neutral-800 dark:text-white leading-none">SFTP Access</h2>
          <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5">Connect using any SFTP client</p>
        </div>
      </div>
      <button onclick="closeSftpModal()" aria-label="Close SFTP modal" class="flex items-center justify-center w-7 h-7 rounded-lg text-neutral-400 hover:text-white hover:bg-white/10 transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
          <path fill-rule="evenodd" d="M5.47 5.47a.75.75 0 0 1 1.06 0L12 10.94l5.47-5.47a.75.75 0 1 1 1.06 1.06L13.06 12l5.47 5.47a.75.75 0 1 1-1.06 1.06L12 13.06l-5.47 5.47a.75.75 0 0 1-1.06-1.06L10.94 12 5.47 6.53a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
        </svg>
      </button>
    </div>

    
    <div id="sftpLoading" class="flex items-center gap-3 px-5 py-8">
      <svg class="animate-spin w-4 h-4 text-neutral-500 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <span class="text-sm text-neutral-500 dark:text-neutral-400">Loading credentials...</span>
    </div>

    
    <div id="sftpError" class="hidden px-5 py-4">
      <div class="flex items-start gap-3 p-3 rounded-lg bg-red-500/10 border border-red-500/20 mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-red-400 shrink-0 mt-0.5">
          <path fill-rule="evenodd" d="M9.401 3.003c1.155-2 4.043-2 5.197 0l7.355 12.748c1.154 2-.29 4.5-2.599 4.5H4.645c-2.309 0-3.752-2.5-2.598-4.5L9.4 3.003ZM12 8.25a.75.75 0 0 1 .75.75v3.75a.75.75 0 0 1-1.5 0V9a.75.75 0 0 1 .75-.75Zm0 8.25a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z" clip-rule="evenodd" />
        </svg>
        <div>
          <p class="text-xs font-medium text-red-400">Failed to load credentials</p>
          <p id="sftpErrorMsg" class="text-xs text-red-400/70 mt-0.5"></p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button onclick="generateSftpCredentials()" class="px-3 py-1.5 rounded-lg bg-neutral-100 dark:bg-white/10 hover:bg-neutral-200 dark:hover:bg-white/15 text-neutral-800 dark:text-white text-xs font-medium transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none border border-neutral-200 dark:border-transparent">Generate credentials</button>
        <button onclick="closeSftpModal()" class="px-3 py-1.5 rounded-lg text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white text-xs font-medium transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">Close</button>
      </div>
    </div>

    
    <div id="sftpCredentials" class="hidden">
      <div class="px-5 py-3 space-y-1">

        
        <div class="flex items-center gap-3 px-4 py-2.5 hover:bg-neutral-50 dark:hover:bg-white/5 rounded-lg transition">
          <span class="text-xs font-medium text-neutral-500 w-16 shrink-0">Host</span>
          <span id="sftpValHost" class="text-xs text-neutral-700 dark:text-neutral-200 flex-1 truncate font-mono"></span>
          <button onclick="sftpCopy('sftpValHost', this)" aria-label="Copy host" class="shrink-0 flex items-center justify-center w-6 h-6 rounded-md bg-neutral-100 dark:bg-white/5 hover:bg-neutral-200 dark:hover:bg-white/10 text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 8.25V6.375a2.25 2.25 0 0 0-2.25-2.25h-8.25A2.25 2.25 0 0 0 3.75 6.375v8.25a2.25 2.25 0 0 0 2.25 2.25H7.5M9.75 8.25h8.25A2.25 2.25 0 0 1 20.25 10.5v8.25A2.25 2.25 0 0 1 18 21H9.75a2.25 2.25 0 0 1-2.25-2.25V10.5A2.25 2.25 0 0 1 9.75 8.25Z" /></svg>
          </button>
        </div>
        <div class="h-px bg-neutral-200 dark:bg-white/5 mx-4"></div>

        
        <div class="flex items-center gap-3 px-4 py-2.5 hover:bg-neutral-50 dark:hover:bg-white/5 rounded-lg transition">
          <span class="text-xs font-medium text-neutral-500 w-16 shrink-0">Port</span>
          <span id="sftpValPort" class="text-xs text-neutral-700 dark:text-neutral-200 flex-1 font-mono"></span>
          <button onclick="sftpCopy('sftpValPort', this)" aria-label="Copy port" class="shrink-0 flex items-center justify-center w-6 h-6 rounded-md bg-neutral-100 dark:bg-white/5 hover:bg-neutral-200 dark:hover:bg-white/10 text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 8.25V6.375a2.25 2.25 0 0 0-2.25-2.25h-8.25A2.25 2.25 0 0 0 3.75 6.375v8.25a2.25 2.25 0 0 0 2.25 2.25H7.5M9.75 8.25h8.25A2.25 2.25 0 0 1 20.25 10.5v8.25A2.25 2.25 0 0 1 18 21H9.75a2.25 2.25 0 0 1-2.25-2.25V10.5A2.25 2.25 0 0 1 9.75 8.25Z" /></svg>
          </button>
        </div>
        <div class="h-px bg-neutral-200 dark:bg-white/5 mx-4"></div>

        
        <div class="flex items-center gap-3 px-4 py-2.5 hover:bg-neutral-50 dark:hover:bg-white/5 rounded-lg transition">
          <span class="text-xs font-medium text-neutral-500 w-16 shrink-0">Username</span>
          <span id="sftpValUser" class="text-xs text-neutral-700 dark:text-neutral-200 flex-1 truncate font-mono"></span>
          <button onclick="sftpCopy('sftpValUser', this)" aria-label="Copy username" class="shrink-0 flex items-center justify-center w-6 h-6 rounded-md bg-neutral-100 dark:bg-white/5 hover:bg-neutral-200 dark:hover:bg-white/10 text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 8.25V6.375a2.25 2.25 0 0 0-2.25-2.25h-8.25A2.25 2.25 0 0 0 3.75 6.375v8.25a2.25 2.25 0 0 0 2.25 2.25H7.5M9.75 8.25h8.25A2.25 2.25 0 0 1 20.25 10.5v8.25A2.25 2.25 0 0 1 18 21H9.75a2.25 2.25 0 0 1-2.25-2.25V10.5A2.25 2.25 0 0 1 9.75 8.25Z" /></svg>
          </button>
        </div>
        <div class="h-px bg-neutral-200 dark:bg-white/5 mx-4"></div>

        
        <div class="flex items-center gap-3 px-4 py-2.5 hover:bg-neutral-50 dark:hover:bg-white/5 rounded-lg transition">
          <span class="text-xs font-medium text-neutral-500 w-16 shrink-0">Password</span>
          <span id="sftpValPass" class="text-xs text-neutral-200 flex-1 truncate font-mono" style="filter: blur(4px);" title="Click eye icon to reveal"></span>
          <button onclick="toggleSftpPassword()" id="sftpTogglePass" aria-label="Toggle password visibility" class="shrink-0 flex items-center justify-center w-6 h-6 rounded-md bg-neutral-100 dark:bg-white/5 hover:bg-neutral-200 dark:hover:bg-white/10 text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
            <svg id="sftpEyeOff" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>
            <svg id="sftpEyeOn" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 hidden"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
          </button>
          <button onclick="sftpCopy('sftpValPass', this)" aria-label="Copy password" class="shrink-0 flex items-center justify-center w-6 h-6 rounded-md bg-neutral-100 dark:bg-white/5 hover:bg-neutral-200 dark:hover:bg-white/10 text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 8.25V6.375a2.25 2.25 0 0 0-2.25-2.25h-8.25A2.25 2.25 0 0 0 3.75 6.375v8.25a2.25 2.25 0 0 0 2.25 2.25H7.5M9.75 8.25h8.25A2.25 2.25 0 0 1 20.25 10.5v8.25A2.25 2.25 0 0 1 18 21H9.75a2.25 2.25 0 0 1-2.25-2.25V10.5A2.25 2.25 0 0 1 9.75 8.25Z" /></svg>
          </button>
        </div>

      </div>

      
      <div class="flex items-center gap-2 px-5 py-4 border-t border-neutral-200 dark:border-white/5">
        <button onclick="generateSftpCredentials()" id="sftpRegenBtn" class="px-3 py-1.5 rounded-xl bg-orange-500 hover:bg-orange-400 text-black text-xs font-semibold transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none disabled:opacity-40">Regenerate</button>
        <button onclick="revokeSftpCredentials()" class="px-3 py-1.5 rounded-xl bg-red-600 hover:bg-red-500 text-white text-xs font-semibold transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">Revoke</button>
      </div>
    </div>

  </div>
</div>

<script nonce="<%- nonce %>">
(function () {
  var SERVER_ID = '<%= server.UUID %>';
  var sftpPlainPassword = null;
  var sftpPasswordVisible = false;

  window.openSftpModal = function () {
    var modal = document.getElementById('sftpModal');
    var panel = modal.querySelector('.relative');
    modal.classList.remove('opacity-0', 'pointer-events-none');
    sftpPasswordVisible = false;
    resetSftpPasswordToggle();
    loadSftpCredentials();
  };

  window.closeSftpModal = function () {
    var modal = document.getElementById('sftpModal');
    modal.classList.add('opacity-0', 'pointer-events-none');
    sftpPasswordVisible = false;
    resetSftpPasswordToggle();
  };

  function resetSftpPasswordToggle() {
    var passEl = document.getElementById('sftpValPass');
    var eyeOff = document.getElementById('sftpEyeOff');
    var eyeOn = document.getElementById('sftpEyeOn');
    if (passEl) passEl.style.filter = 'blur(4px)';
    if (eyeOff) eyeOff.classList.remove('hidden');
    if (eyeOn) eyeOn.classList.add('hidden');
  }

  window.toggleSftpPassword = function () {
    sftpPasswordVisible = !sftpPasswordVisible;
    var passEl = document.getElementById('sftpValPass');
    var eyeOff = document.getElementById('sftpEyeOff');
    var eyeOn = document.getElementById('sftpEyeOn');
    if (sftpPasswordVisible) {
      passEl.style.filter = 'none';
      eyeOff.classList.add('hidden');
      eyeOn.classList.remove('hidden');
    } else {
      passEl.style.filter = 'blur(4px)';
      eyeOff.classList.remove('hidden');
      eyeOn.classList.add('hidden');
    }
  };

  function showSftpState(state) {
    document.getElementById('sftpLoading').classList.toggle('hidden', state !== 'loading');
    document.getElementById('sftpError').classList.toggle('hidden', state !== 'error');
    document.getElementById('sftpCredentials').classList.toggle('hidden', state !== 'credentials');
  }

  function fillCredentials(data) {
    if (data.password) {
      sftpPlainPassword = data.password;
    }

    document.getElementById('sftpValHost').textContent = data.host;
    document.getElementById('sftpValPort').textContent = data.port;
    document.getElementById('sftpValUser').textContent = data.username;
    document.getElementById('sftpValPass').textContent = data.password || sftpPlainPassword || 'Regenerate to view';
    showSftpState('credentials');
  }

  function loadSftpCredentials() {
    showSftpState('loading');
    fetch('/server/' + SERVER_ID + '/sftp/credentials')
      .then(function (resp) {
        if (resp.status === 404) {
          return generateSftpCredentials();
        }
        if (!resp.ok) {
          return resp.json().catch(function () { return {}; }).then(function (d) {
            throw new Error(d.error || 'Request failed (' + resp.status + ')');
          });
        }
        return resp.json().then(fillCredentials);
      })
      .catch(function (err) {
        document.getElementById('sftpErrorMsg').textContent = err.message || 'Unknown error.';
        showSftpState('error');
      });
  }

  window.generateSftpCredentials = function () {
    var btn = document.getElementById('sftpRegenBtn');
    if (btn) btn.disabled = true;
    showSftpState('loading');

    return fetch('/server/' + SERVER_ID + '/sftp/credentials', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
    })
      .then(function (resp) {
        if (!resp.ok) {
          return resp.json().catch(function () { return {}; }).then(function (d) {
            throw new Error(d.error || 'Request failed (' + resp.status + ')');
          });
        }
        return resp.json();
      })
      .then(function (data) {
        if (btn) btn.disabled = false;
        sftpPasswordVisible = false;
        resetSftpPasswordToggle();
        fillCredentials(data);
        showToast('Credentials regenerated.', 'success');
      })
      .catch(function (err) {
        if (btn) btn.disabled = false;
        document.getElementById('sftpErrorMsg').textContent = err.message || 'Unknown error.';
        showSftpState('error');
      });
  };

  window.revokeSftpCredentials = function () {
    fetch('/server/' + SERVER_ID + '/sftp/credentials', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
    })
      .then(function () {
        closeSftpModal();
        showToast('SFTP access revoked.', 'success');
      })
      .catch(function () {
        showToast('Failed to revoke SFTP access.', 'error');
      });
  };

  window.sftpCopy = function (elementId, btnEl) {
    var el = document.getElementById(elementId);
    if (!el) return;
    navigator.clipboard.writeText(el.textContent || '').then(function () {
      if (btnEl) {
        var originalHTML = btnEl.innerHTML;
        btnEl.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>';
        setTimeout(function () {
          btnEl.innerHTML = originalHTML;
        }, 1000);
      }
      showToast('Copied to clipboard', 'success');
    }).catch(function () {
      showToast('Copy failed', 'error');
    });
  };
})();
</script>

