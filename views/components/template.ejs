                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 mt-0.5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" />
                  </svg>
                  <span><%= req.translations.navServers || 'Servers' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/users" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 mt-0.5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                  </svg>
                  <span><%= req.translations.navUsers || 'Users' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/nodes" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 mt-0.5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3" />
                  </svg>
                  <span><%= req.translations.navNodes || 'Nodes' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/images" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 mt-0.5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m20.25 7.5-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125Z" />
                  </svg>
                  <span><%= req.translations.navImages || 'Images' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/addons" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 mt-0.5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.39 48.39 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 4.126-.33c-.206-1.578-.322-3.174-.346-4.777a.637.637 0 0 1 .7-.631v0c.355 0 .676.186.959.401.29.221.634.349 1.003.349 1.035 0 1.875-1.007 1.875-2.25s-.84-2.25-1.875-2.25c-.37 0-.713.128-1.003.349-.283.215-.604.401-.96.401v0a.656.656 0 0 1-.658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" />
                  </svg>
                  <span><%= req.translations.navAddons || 'Addons' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/airlink-cloud" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 mt-0.5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
                  </svg>
                  <span><%= req.translations.navAirlinkCloud || 'Airlink Cloud' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/apikeys" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 mt-0.5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
                  </svg>
                  <span><%= req.translations.navApiKeys || 'API Keys' %></span>
                </a>
              </li>
              <% if (adminMenuItems && adminMenuItems.length > 0) {
                adminMenuItems.forEach(item => {
              %>
              <li>
                <a href="<%= item.url %>" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <%- renderNavIcon(item.icon) %>
                  <span><%= item.label %></span>
                </a>
              </li>
              <% }); } %>
            <% } %>
          </ul>
        </li>
      </ul>
    </nav>

    <!-- Static bottom: logout -->
    <div class="shrink-0 border-t border-neutral-800/10 dark:border-white/5">
      <a href="/logout" id="sidebar-logout-link" class="sidebar-special-link group flex gap-x-3 pl-6 py-4 text-sm font-medium leading-6 text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-500/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-red-500 transition-colors duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 mt-0.5 shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" />
        </svg>
        <span><%= req.translations.navLogout || 'Logout' %></span>
      </a>
    </div>

  </div>
</div>
</div>

<script nonce="<%- nonce %>">
(function () {
  var wsProtocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
  var ws = new WebSocket(wsProtocol + '//' + window.location.host + '/online-check');
  ws.addEventListener('error', function () {});

  // Highlight account/logout when on those pages
  function markSpecialLinks(path) {
    var account = document.getElementById('sidebar-account-link');
    var logout  = document.getElementById('sidebar-logout-link');
    var isDark  = document.documentElement.classList.contains('dark');
    if (account) {
      var onAccount = path === '/account' || path.startsWith('/account/');
      account.style.background = onAccount
        ? (isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)')
        : '';
    }
    if (logout) {
      logout.style.background = '';
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    markSpecialLinks(window.location.pathname);
  });
  document.addEventListener('al:navigated', function () {
    markSpecialLinks(window.location.pathname);
  });
})();
</script>

<div id="colcont" class="md:pl-56">
  <div class="hidden md:flex fixed top-0 left-0 md:left-56 right-0 z-40 h-16 shrink-0 items-center gap-x-4 bg-white/8 dark:bg-[#141414]/8 backdrop-blur-xl border-b border-neutral-200/30 dark:border-white/5 px-4 sm:gap-x-6 sm:px-4 md:px-4">
    <div class="flex flex-1 gap-x-4 self-stretch md:gap-x-6">
      <style>
        #search-container {
          position: relative;
          width: 200px;
          transition: width 0.3s cubic-bezier(0.16,1,0.3,1);
        }
        #search-container.expanded { width: 380px; }
        #search-container:not(.expanded) { width: 200px; }
        #search-dropdown {
          position: fixed;
          transform-origin: top left;
          z-index: 9999;
        }
        #search-dropdown.anim-scale-in {
          animation: scaleIn 0.28s cubic-bezier(0.16,1,0.3,1) both;
        }
        #search-container:not(.expanded) #search-clear-btn { display: none; }
        #search-container.expanded #search-clear-btn { display: flex; }
      </style>

      <div id="search-container" class="md:-ml-2 flex items-center mt-3.5 px-4 py-2 h-10 rounded-xl border border-neutral-300 dark:border-white/5 active:scale-100 duration-200 hover:border-neutral-400 dark:hover:border-neutral-300/10 bg-transparent text-neutral-800 dark:text-white" role="search">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-neutral-400 shrink-0">
          <path fill-rule="evenodd" d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Z" clip-rule="evenodd" />
        </svg>
        <input id="searchInput"
          class="bg-transparent border-transparent ml-2 flex-1 min-w-0 focus-visible:ring-transparent border-none ring-transparent sm:text-sm placeholder:text-zinc-500 text-neutral-700 dark:text-neutral-300 focus-visible:outline-none"
          placeholder="Search servers, users, pages..."
          type="search"
          role="combobox"
          aria-autocomplete="list"
          aria-expanded="false"
          aria-controls="searchResults"
          aria-activedescendant=""
          aria-label="Search"
          name="search"
          autocomplete="off">
        <button id="search-clear-btn" type="button" class="ml-1 shrink-0 w-5 h-5 flex items-center justify-center rounded text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200 transition-colors" aria-label="Clear search">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        <div aria-hidden="true" class="ml-2 px-1 py-0.5 text-[10px] w-[55px] font-medium text-neutral-700 dark:text-neutral-400 bg-neutral-200 dark:bg-neutral-800 rounded-md border border-neutral-300 dark:border-neutral-700
          bg-[linear-gradient(45deg,transparent_25%,rgba(68,68,68,.2)_50%,transparent_75%,transparent_100%)]
          bg-[length:250%_250%,100%_100%] bg-[position:-100%_0,0_0] bg-no-repeat transition-ease-out
          hover:bg-[position:200%_0,0_0] hover:duration-[2s] shrink-0">
          CTRL + K
        </div>
      </div>

      <div id="searchResults" role="listbox" aria-label="Search results" class="hidden bg-neutral-50 dark:bg-neutral-900 w-[380px] rounded-xl shadow-2xl shadow-neutral-200/80 dark:shadow-black/40 px-2 pb-2 border border-neutral-200 dark:border-neutral-700/60 max-h-[60vh] overflow-y-auto">
      </div>

      <script nonce="<%- nonce %>">
      (function () {
        var container  = document.getElementById('search-container');
        var input      = document.getElementById('searchInput');
        var clearBtn   = document.getElementById('search-clear-btn');
        var resultsEl  = document.getElementById('searchResults');
        var activeIndex = -1;

        function getNavItems() {
          var items = [];
          var links = document.querySelectorAll('#pc-sidebar .nav-link, #pc-sidebar a[href]');
          links.forEach(function (link) {
            var href = link.getAttribute('href');
            if (!href || href === '#' || href === '/logout' || href === '/account') return;
            var label = (link.textContent || '').trim();
            var svg = link.querySelector('svg');
            var iconHtml = svg ? svg.outerHTML : '';
            var existing = items.find(function (i) { return i.path === href; });
            if (!existing) items.push({ path: href, label: label, iconHtml: iconHtml });
          });
          return items;
        }

        function getRecentNav() {
          try {
            var raw = localStorage.getItem('airlink-recent-nav');
            return raw ? JSON.parse(raw) : [];
          } catch (e) { return []; }
        }

        function storeRecentNav(path) {
          var recent = getRecentNav().filter(function (r) { return r.path !== path; });
          var navItems = getNavItems();
          var navItem = navItems.find(function (n) { return n.path === path; });
          recent.unshift({
            path: path,
            label: navItem ? navItem.label : path,
            iconHtml: navItem ? navItem.iconHtml : ''
          });
          if (recent.length > 3) recent = recent.slice(0, 3);
          try { localStorage.setItem('airlink-recent-nav', JSON.stringify(recent)); } catch (e) {}
        }

        function renderDropdown() {
          var term = input.value.trim().toLowerCase();
          var recent = getRecentNav();
          var navItems = getNavItems();
          activeIndex = -1;

          var filteredNav = navItems;
          if (term) {
            filteredNav = navItems.filter(function (item) {
              return item.label.toLowerCase().includes(term) || item.path.toLowerCase().includes(term);
            });
          }

          if (recent.length === 0 && filteredNav.length === 0) {
            resultsEl.innerHTML = '<p class="px-4 py-3 text-sm text-neutral-400">No results.</p>';
            return;
          }

          var html = '';

          if (recent.length > 0) {
            html += '<div class="px-3 pt-2 pb-1 text-[10px] font-semibold uppercase tracking-wider text-neutral-400 dark:text-neutral-500">Recent</div>';
            recent.forEach(function (item, i) {
              var icon = item.iconHtml || '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>';
              html += '<a href="' + item.path + '" data-search-item class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-neutral-100 dark:hover:bg-white/5 transition cursor-pointer" data-index="' + i + '">';
              html += '<span class="w-5 h-5 flex items-center justify-center shrink-0 text-neutral-400 [&>svg]:w-5 [&>svg]:h-5">' + icon + '</span>';
              html += '<span class="text-sm text-neutral-700 dark:text-neutral-200 truncate">' + item.label + '</span>';
              html += '<span class="ml-auto text-xs text-neutral-400 dark:text-neutral-500 truncate shrink-0">' + item.path + '</span>';
              html += '</a>';
            });
          }

          if (filteredNav.length > 0) {
            html += '<div class="px-3 pt-3 pb-1 text-[10px] font-semibold uppercase tracking-wider text-neutral-400 dark:text-neutral-500">Navigation</div>';
            filteredNav.forEach(function (item, i) {
              var idx = recent.length + i;
              html += '<a href="' + item.path + '" data-search-item class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-neutral-100 dark:hover:bg-white/5 transition cursor-pointer" data-index="' + idx + '">';
              html += '<span class="w-5 h-5 flex items-center justify-center shrink-0 text-neutral-400 [&>svg]:w-5 [&>svg]:h-5">' + (item.iconHtml || '') + '</span>';
              html += '<span class="text-sm text-neutral-700 dark:text-neutral-200 truncate">' + item.label + '</span>';
              html += '<span class="ml-auto text-xs text-neutral-400 dark:text-neutral-500 truncate shrink-0">' + item.path + '</span>';
              html += '</a>';
            });
          }

          resultsEl.innerHTML = html;
        }

        function positionDropdown() {
          var rect = container.getBoundingClientRect();
          resultsEl.style.top = (rect.bottom + 4) + 'px';
          resultsEl.style.left = rect.left + 'px';
        }

        function openDropdown() {
          container.classList.add('expanded');
          renderDropdown();
          positionDropdown();
          resultsEl.classList.remove('hidden');
          resultsEl.classList.add('anim-scale-in');
          input.setAttribute('aria-expanded', 'true');
        }

        function closeDropdown() {
          container.classList.remove('expanded');
          resultsEl.classList.add('hidden');
          resultsEl.classList.remove('anim-scale-in');
          input.setAttribute('aria-expanded', 'false');
          input.setAttribute('aria-activedescendant', '');
          activeIndex = -1;
        }

        function updateActive() {
          var items = resultsEl.querySelectorAll('[data-search-item]');
          items.forEach(function (el, i) {
            if (i === activeIndex) {
              el.classList.add('bg-neutral-100', 'dark:bg-white/5');
              el.setAttribute('aria-selected', 'true');
              input.setAttribute('aria-activedescendant', 'search-item-' + i);
              el.id = 'search-item-' + i;
              el.scrollIntoView({ block: 'nearest' });
            } else {
              el.classList.remove('bg-neutral-100', 'dark:bg-white/5');
              el.setAttribute('aria-selected', 'false');
              el.id = '';
            }
          });
        }

        input.addEventListener('focus', function () {
          openDropdown();
        });

        input.addEventListener('input', function () {
          if (input.value.trim().length > 0) {
            clearBtn.style.display = 'flex';
          } else {
            clearBtn.style.display = 'none';
          }
          renderDropdown();
          positionDropdown();
        });

        clearBtn.addEventListener('click', function (e) {
          e.stopPropagation();
          input.value = '';
          clearBtn.style.display = 'none';
          renderDropdown();
          input.focus();
        });

        input.addEventListener('keydown', function (e) {
          var items = resultsEl.querySelectorAll('[data-search-item]');
          var count = items.length;
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            activeIndex = activeIndex < count - 1 ? activeIndex + 1 : 0;
            updateActive();
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            activeIndex = activeIndex > 0 ? activeIndex - 1 : count - 1;
            updateActive();
          } else if (e.key === 'Enter') {
            e.preventDefault();
            if (activeIndex >= 0 && activeIndex < count) {
              var link = items[activeIndex];
              var path = link.getAttribute('href');
              storeRecentNav(path);
              window.location.href = path;
            } else if (input.value.trim()) {
              var firstLink = items[0];
              if (firstLink) {
                var fp = firstLink.getAttribute('href');
                storeRecentNav(fp);
                window.location.href = fp;
              }
            }
          } else if (e.key === 'Escape') {
            e.preventDefault();
            closeDropdown();
            input.blur();
          }
        });

        resultsEl.addEventListener('click', function (e) {
          var link = e.target.closest('[data-search-item]');
          if (link) {
            e.preventDefault();
            var path = link.getAttribute('href');
            storeRecentNav(path);
            window.location.href = path;
          }
        });

        document.addEventListener('keydown', function (e) {
          if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault();
            if (document.activeElement === input && container.classList.contains('expanded')) {
              closeDropdown();
              input.blur();
            } else {
              input.focus();
            }
          }
        });

        document.addEventListener('click', function (e) {
          if (!container.contains(e.target) && !resultsEl.contains(e.target)) {
            closeDropdown();
          }
        });

        document.addEventListener('al:navigated', function () {
          closeDropdown();
        });

        window.addEventListener('resize', function () {
          if (container.classList.contains('expanded')) {
            positionDropdown();
          }
        });
      })();
      </script>
    </div>
  </div>
</div>
