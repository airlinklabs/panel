    if (typeof updateToggleDot === 'function') updateToggleDot();

    var moreBtn      = document.getElementById('more-nav-btn');
    var moreSheet    = document.getElementById('more-sheet');
    var moreBackdrop = document.getElementById('more-sheet-backdrop');
    var moreClose    = document.getElementById('more-sheet-close');

    function openSheet() {
      if (!moreSheet || !moreBackdrop) return;
      moreSheet.style.transition = 'transform 0.38s cubic-bezier(0.16,1,0.3,1)';
      moreBackdrop.style.transition = 'opacity 0.2s ease';
      moreSheet.classList.remove('translate-y-full');
      moreBackdrop.classList.remove('opacity-0', 'pointer-events-none');
      setTimeout(function () {
        var list = moreSheet.querySelector('.space-y-1');
        if (window.airlinkAnimateChildren && list) {
          window.airlinkAnimateChildren(list, { baseDelay: 30, stagger: 24, duration: 180 });
        }
      }, 120);
    }
    function closeSheet() {
      if (!moreSheet || !moreBackdrop) return;
      moreSheet.style.transition = 'transform 0.28s cubic-bezier(0.4,0,1,1)';
      moreBackdrop.style.transition = 'opacity 0.2s ease';
      moreSheet.classList.add('translate-y-full');
      moreBackdrop.classList.add('opacity-0', 'pointer-events-none');
    }

    if (moreBtn)      moreBtn.addEventListener('click', openSheet);
    if (moreClose)    moreClose.addEventListener('click', closeSheet);
    if (moreBackdrop) moreBackdrop.addEventListener('click', closeSheet);

    var adminBtn = document.getElementById('admin-sheet-open');
    var adminSheet = document.getElementById('admin-sheet');
    var adminBackdrop = document.getElementById('admin-sheet-backdrop');
    var adminClose = document.getElementById('admin-sheet-close');
    function openAdminSheet() {
      if (!adminSheet || !adminBackdrop) return;
      adminSheet.style.transition = 'transform 0.38s cubic-bezier(0.16,1,0.3,1)';
      adminBackdrop.style.transition = 'opacity 0.2s ease';
      adminSheet.classList.remove('translate-y-full');
      adminBackdrop.classList.remove('opacity-0', 'pointer-events-none');
      setTimeout(function () {
        var list = adminSheet.querySelector('.space-y-1');
        if (window.airlinkAnimateChildren && list) {
          window.airlinkAnimateChildren(list, { baseDelay: 30, stagger: 24, duration: 180 });
        }
      }, 120);
    }
    function closeAdminSheet() {
      if (!adminSheet || !adminBackdrop) return;
      adminSheet.style.transition = 'transform 0.28s cubic-bezier(0.4,0,1,1)';
      adminBackdrop.style.transition = 'opacity 0.2s ease';
      adminSheet.classList.add('translate-y-full');
      adminBackdrop.classList.add('opacity-0', 'pointer-events-none');
    }
    if (adminBtn) adminBtn.addEventListener('click', openAdminSheet);
    if (adminClose) adminClose.addEventListener('click', closeAdminSheet);
    if (adminBackdrop) adminBackdrop.addEventListener('click', closeAdminSheet);
    document.addEventListener('keydown', function(event) { if (event.key === 'Escape') closeAdminSheet(); });
    document.querySelectorAll('.admin-sheet-link').forEach(function(link) {
      if (window.location.pathname.startsWith(link.getAttribute('data-admin-path'))) {
        link.classList.add('bg-neutral-100', 'dark:bg-white/5');
      }
    });

    var wsProtocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    var ws = new WebSocket(wsProtocol + '//' + window.location.host + '/online-check');
    ws.addEventListener('error', function () {});
  });
})();
</script>

<script nonce="<%- nonce %>">
(function () {
  var openBtn    = document.getElementById('mobile-search-open');
  var closeBtn   = document.getElementById('mobile-search-close');
  var defaultBar = document.getElementById('topbar-default');
  var searchBar  = document.getElementById('topbar-search');
  var input      = document.getElementById('mobileSearchInput');
  var resultsEl  = document.getElementById('mobileSearchResults');

  if (!openBtn || !input || !resultsEl) return;

  function renderResults(term) {
    resultsEl.innerHTML = '';
    if (!term) { resultsEl.classList.add('hidden'); return; }

    var links = Array.from(document.querySelectorAll('.mobile-nav-link, .nav-link'));
    var lower = term.toLowerCase();

    var matches = links.filter(function (link) {
      var text = (link.textContent || '').toLowerCase();
      var data = (link.getAttribute('data-search') || '').toLowerCase();
      return text.includes(lower) || data.includes(lower);
    });

    if (matches.length === 0) {
      var p = document.createElement('p');
      p.className = 'px-4 py-3 text-sm text-neutral-400';
      p.textContent = 'No results.';
      resultsEl.appendChild(p);
    } else {
      matches.forEach(function (link) {
        var a = document.createElement('a');
        a.href = link.href || '#';
        a.className = 'flex items-center gap-3 px-4 py-3 border-b border-neutral-100 dark:border-white/5 last:border-0 hover:bg-neutral-50 dark:hover:bg-white/5 transition';
        var icon = link.querySelector('svg');
        if (icon) { var ic = icon.cloneNode(true); ic.className = 'h-5 w-5 text-neutral-400 shrink-0'; a.appendChild(ic); }
        var span = document.createElement('span');
        span.className = 'text-sm text-neutral-800 dark:text-white';
        span.textContent = link.textContent.trim();
        a.appendChild(span);
        resultsEl.appendChild(a);
      });
    }
    resultsEl.classList.remove('hidden');
  }

  openBtn.addEventListener('click', function () {
    if (defaultBar) {
      defaultBar.style.transition = 'opacity 0.15s ease';
      defaultBar.style.opacity = '0';
    }
    setTimeout(function () {
      if (defaultBar) {
        defaultBar.classList.add('hidden');
        defaultBar.style.opacity = '';
      }
      searchBar.classList.remove('hidden');
      searchBar.classList.add('flex');
      searchBar.style.opacity = '0';
      searchBar.style.transition = 'opacity 0.15s ease';
      requestAnimationFrame(function () {
        searchBar.style.opacity = '1';
      });
      input.value = '';
      resultsEl.classList.add('hidden');
      setTimeout(function () { input.focus(); }, 60);
    }, 150);
  });

  function closeSearch() {
    searchBar.style.transition = 'opacity 0.15s ease';
    searchBar.style.opacity = '0';
    setTimeout(function () {
      searchBar.classList.add('hidden');
      searchBar.classList.remove('flex');
      searchBar.style.opacity = '';
      defaultBar.classList.remove('hidden');
      if (defaultBar) {
        defaultBar.style.transition = 'opacity 0.15s ease';
        requestAnimationFrame(function () { defaultBar.style.opacity = '1'; });
        setTimeout(function () { defaultBar.style.transition = ''; defaultBar.style.opacity = ''; }, 160);
      }
      resultsEl.classList.add('hidden');
      input.value = '';
    }, 150);
  }

  closeBtn.addEventListener('click', closeSearch);

  if (resultsEl) {
    resultsEl.addEventListener('click', function(e) {
      var link = (e.target as Element).closest('a');
      if (link) {
        setTimeout(function() {
          if (input) input.value = '';
          resultsEl.innerHTML = '';
          resultsEl.classList.add('hidden');
          closeSearch();
        }, 50);
      }
    });
  }

  var debounce;
  input.addEventListener('input', function () {
    clearTimeout(debounce);
    debounce = setTimeout(function () { renderResults(input.value.trim()); }, 120);
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeSearch();
  });
})();
</script>
