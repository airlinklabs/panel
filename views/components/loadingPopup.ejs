<style>
  .popup-spinner {
    width: 15px;
    height: 15px;
    border: 2px solid transparent;
    border-top-color: currentColor;
    border-radius: 50%;
    animation: popup-spin 0.65s linear infinite;
    flex-shrink: 0;
  }
  @keyframes popup-spin { to { transform: rotate(360deg); } }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .status-dot.pulse {
    animation: dot-pulse 1.4s ease-in-out infinite;
  }
  @keyframes dot-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }

  /* Inline action bar — single-line two-state feedback */
  #actionFeedback {
    display: none;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--af-color, #6b7280);
    transition: opacity 0.3s ease;
  }
  #actionFeedback.visible { display: flex; }
  #actionFeedback.fading  { opacity: 0; }
  .af-spinner {
    width: 12px;
    height: 12px;
    border: 1.5px solid transparent;
    border-top-color: currentColor;
    border-radius: 50%;
    animation: popup-spin 0.65s linear infinite;
    flex-shrink: 0;
  }
</style>

<!-- Inline single-line action feedback bar -->
<div id="actionFeedback" aria-live="polite">
  <span class="af-spinner" id="afSpinner"></span>
  <svg id="afCheck" xmlns="http://www.w3.org/2000/svg" class="hidden" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="20 6 9 17 4 12"/>
  </svg>
  <span id="afText"></span>
</div>

<!-- Full popup (used for detailed state like install) -->
<div id="loadingPopup" class="fixed inset-0 bg-black/50 z-50 flex items-end sm:items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
  <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700/60 rounded-2xl p-5 w-full max-w-sm mx-4 mb-4 sm:mb-0 sm:scale-95 transition-all duration-300 shadow-2xl">

    <div class="flex items-start gap-3 mb-3">
      <div id="loadingIconWrap" class="mt-0.5 shrink-0 text-neutral-400">
        <div id="loadingSpinner" class="popup-spinner"></div>
        <svg id="loadingCheckIcon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-500 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        <svg id="loadingErrorIcon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <p id="loadingTitle" class="text-sm font-semibold text-neutral-800 dark:text-white leading-tight">Processing</p>
          <div id="loadingStatusDot" class="status-dot pulse bg-neutral-300 dark:bg-neutral-600"></div>
        </div>
        <p id="loadingMessage" class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5 leading-tight"></p>
      </div>
    </div>

    <div id="loadingSteps" class="space-y-1.5 mb-3 overflow-hidden transition-all duration-300" style="max-height: 0px"></div>

    <button id="hideLoadingPopup" class="w-full rounded-xl bg-neutral-900 dark:bg-neutral-100 hover:bg-neutral-700 dark:hover:bg-neutral-300 text-white dark:text-neutral-900 px-3 py-2 text-xs font-medium transition">
      Hide
    </button>
  </div>
</div>

<script>
(function () {
  if (window.loadingPopupSystem) return;

  // SVG markup for step icons
  const svgDone = `<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-500 shrink-0"><polyline points="20 6 9 17 4 12"/></svg>`;
  const svgError = `<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-red-400 shrink-0"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`;
  const svgPending = `<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-300 dark:text-neutral-600 shrink-0"><circle cx="12" cy="12" r="1"/></svg>`;

  const dotColors = {
    start:   'bg-emerald-400',
    stop:    'bg-red-400',
    restart: 'bg-amber-400',
    default: 'bg-neutral-300 dark:bg-neutral-600',
  };

  const spinnerColors = {
    start:   'text-emerald-500',
    stop:    'text-red-500',
    restart: 'text-amber-500',
    default: 'text-neutral-400',
  };

  const el = {
    popup:     () => document.getElementById('loadingPopup'),
    inner:     () => document.getElementById('loadingPopup').querySelector('div'),
    title:     () => document.getElementById('loadingTitle'),
    message:   () => document.getElementById('loadingMessage'),
    dot:       () => document.getElementById('loadingStatusDot'),
    steps:     () => document.getElementById('loadingSteps'),
    spinner:   () => document.getElementById('loadingSpinner'),
    checkIcon: () => document.getElementById('loadingCheckIcon'),
    errorIcon: () => document.getElementById('loadingErrorIcon'),
  };

  let stepCount = 0;

  function addStep(text, type) {
    stepCount++;
    const isDone  = type === 'done';
    const isError = type === 'error';
    const icon      = isDone ? svgDone : isError ? svgError : svgPending;
    const textColor = isDone
      ? 'text-neutral-600 dark:text-neutral-300'
      : isError
        ? 'text-red-400'
        : 'text-neutral-500 dark:text-neutral-400';

    const stepsEl = el.steps();
    const row = document.createElement('div');
    row.className = 'flex items-center gap-1.5 opacity-0 transition-opacity duration-200';
    row.innerHTML = `${icon}<span class="text-xs ${textColor} leading-tight">${text}</span>`;
    stepsEl.appendChild(row);
    stepsEl.style.maxHeight = (stepCount * 24) + 'px';
    requestAnimationFrame(() => row.classList.remove('opacity-0'));
  }

  function setIcon(state) {
    el.spinner().classList.add('hidden');
    el.checkIcon().classList.add('hidden');
    el.errorIcon().classList.add('hidden');
    const dot = el.dot();

    if (state === 'done') {
      el.checkIcon().classList.remove('hidden');
      dot.classList.remove('pulse');
      dot.className = 'status-dot bg-emerald-400';
    } else if (state === 'error') {
      el.errorIcon().classList.remove('hidden');
      dot.classList.remove('pulse');
      dot.className = 'status-dot bg-red-400';
    } else {
      el.spinner().classList.remove('hidden');
      dot.classList.add('pulse');
    }
  }

  function open(title, theme) {
    stepCount = 0;
    el.steps().innerHTML = '';
    el.steps().style.maxHeight = '0px';

    const dotClass = dotColors[theme] || dotColors.default;
    el.dot().className = `status-dot pulse ${dotClass}`;

    const spinColor = spinnerColors[theme] || spinnerColors.default;
    el.spinner().className = `popup-spinner ${spinColor}`;

    el.title().textContent = title;
    el.message().textContent = '';
    el.checkIcon().classList.add('hidden');
    el.errorIcon().classList.add('hidden');
    el.spinner().classList.remove('hidden');

    el.popup().classList.remove('opacity-0', 'pointer-events-none');
    el.inner().classList.remove('scale-95');
    el.inner().classList.add('scale-100');
  }

  function close() {
    el.popup().classList.add('opacity-0', 'pointer-events-none');
    el.inner().classList.add('scale-95');
    el.inner().classList.remove('scale-100');
  }

  window.loadingPopupSystem = {
    open, close, addStep, setIcon,
    setProgress(pct, msg) {
      if (msg !== undefined) el.message().textContent = msg;
    },
    setMessage(msg) { el.message().textContent = msg; },
  };

  document.getElementById('hideLoadingPopup').addEventListener('click', close);

  window.showLoadingPopup = (title, msg) => {
    open(title, 'default');
    if (msg) el.message().textContent = msg;
    return {
      updateProgress: (pct, m) => window.loadingPopupSystem.setProgress(pct, m),
      updateMessage:  (m)      => window.loadingPopupSystem.setMessage(m),
      close:          ()       => window.loadingPopupSystem.close(),
    };
  };
  window.hideLoadingPopup = close;

  // ── Inline single-line action feedback ────────────────────────────────────
  // Usage:
  //   window.actionFeedback.show('Starting server')   → shows spinner + "Starting server..."
  //   window.actionFeedback.done('Server started')    → shows check + "Server started" then fades
  //   window.actionFeedback.error('Failed to start')  → shows text immediately then fades
  let afFadeTimer = null;

  window.actionFeedback = {
    show(msg) {
      if (afFadeTimer) { clearTimeout(afFadeTimer); afFadeTimer = null; }
      const bar = document.getElementById('actionFeedback');
      const spinner = document.getElementById('afSpinner');
      const check   = document.getElementById('afCheck');
      const text    = document.getElementById('afText');
      if (!bar) return;
      spinner.classList.remove('hidden');
      check.classList.add('hidden');
      bar.style.setProperty('--af-color', 'var(--color-neutral-500, #6b7280)');
      text.textContent = msg + '...';
      bar.classList.remove('fading');
      bar.classList.add('visible');
    },
    done(msg) {
      const bar = document.getElementById('actionFeedback');
      const spinner = document.getElementById('afSpinner');
      const check   = document.getElementById('afCheck');
      const text    = document.getElementById('afText');
      if (!bar) return;
      spinner.classList.add('hidden');
      check.classList.remove('hidden');
      bar.style.setProperty('--af-color', '#10b981');
      text.textContent = msg;
      bar.classList.remove('fading');
      afFadeTimer = setTimeout(() => {
        bar.classList.add('fading');
        setTimeout(() => {
          bar.classList.remove('visible', 'fading');
          spinner.classList.remove('hidden');
          check.classList.add('hidden');
        }, 320);
      }, 2200);
    },
    hide() {
      if (afFadeTimer) { clearTimeout(afFadeTimer); afFadeTimer = null; }
      const bar = document.getElementById('actionFeedback');
      if (bar) { bar.classList.remove('visible', 'fading'); }
    },
  };
})();
</script>
