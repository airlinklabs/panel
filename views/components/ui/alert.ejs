<%
const variants = {
  warning: 'bg-amber-50 dark:bg-amber-500/10 text-amber-800 dark:text-amber-200 border border-amber-200 dark:border-amber-500/20',
  error: 'bg-red-50 dark:bg-red-500/10 text-red-800 dark:text-red-200 border border-red-200 dark:border-red-500/20',
  info: 'bg-blue-50 dark:bg-blue-500/10 text-blue-800 dark:text-blue-200 border border-blue-200 dark:border-blue-500/20',
  success: 'bg-emerald-50 dark:bg-emerald-500/10 text-emerald-800 dark:text-emerald-200 border border-emerald-200 dark:border-emerald-500/20'
};
%>
<div class="rounded-xl px-4 py-3 <%= variants[variant || 'info'] %> anim-fade-down" data-ui-alert>
  <div class="flex items-start justify-between gap-4">
    <div><p class="text-sm font-medium"><%= title %></p><% if (body) { %><p class="text-xs opacity-80 mt-1"><%= body %></p><% } %></div>
    <% if (action) { %><button type="button" class="text-xs font-medium underline active:scale-95 transition-transform" data-alert-action="<%= action.onClick %>"><%= action.label %></button><% } %>
  </div>
</div>
