<div class="flex items-start justify-between gap-4">
  <div>
    <label for="<%= id %>" class="text-sm font-medium text-neutral-700 dark:text-neutral-300"><%= label %></label>
    <% if (hint) { %><p class="text-xs text-neutral-500 mt-1"><%= hint %></p><% } %>
  </div>
  <input class="sr-only" type="checkbox" id="<%= id %>" name="<%= name %>" <%= checked ? 'checked' : '' %> <%= disabled ? 'disabled' : '' %>>
  <button type="button" role="switch" aria-checked="<%= checked ? 'true' : 'false' %>" aria-label="<%= label %>" data-switch-for="<%= id %>" class="w-11 h-6 rounded-full p-1 transition-colors duration-300 <%= checked ? 'bg-neutral-900 dark:bg-neutral-100' : 'bg-neutral-300 dark:bg-neutral-700/70' %>" <%= disabled ? 'disabled' : '' %>>
    <span class="block w-4 h-4 bg-white rounded-full shadow-md border border-neutral-950/20 transition-transform duration-300 <%= checked ? 'translate-x-5' : '' %>"></span>
  </button>
</div>
<script nonce="<%- nonce %>">document.addEventListener('DOMContentLoaded',function(){var b=document.querySelector('[data-switch-for="<%= id %>"]');var i=document.getElementById('<%= id %>');if(!b||!i)return;b.addEventListener('click',function(){i.checked=!i.checked;b.setAttribute('aria-checked',i.checked?'true':'false');b.classList.toggle('bg-neutral-900',i.checked);b.classList.toggle('dark:bg-neutral-100',i.checked);b.classList.toggle('bg-neutral-300',!i.checked);b.classList.toggle('dark:bg-neutral-700/70',!i.checked);b.querySelector('span').classList.toggle('translate-x-5',i.checked);<%- onChange || '' %>});});</script>
