<div>
  <% if (label) { %><label for="<%= id %>" class="text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1 block"><%= label %></label><% } %>
  <div class="relative">
    <select id="<%= id %>" name="<%= name %>" class="w-full rounded-xl border border-neutral-200 dark:border-white/10 bg-neutral-50 dark:bg-neutral-800/40 px-3 py-2 pr-9 text-sm text-neutral-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-neutral-400 transition appearance-none" <%= disabled ? 'disabled' : '' %>>
      <% (options || []).forEach(function(option) { %>
      <option value="<%= option.value %>" <%= option.selected ? 'selected' : '' %>><%= option.label %></option>
      <% }); %>
    </select>
    <svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-neutral-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m6 9 6 6 6-6"/></svg>
  </div>
  <% if (hint) { %><p class="text-xs text-neutral-500 mt-1"><%= hint %></p><% } %>
</div>
