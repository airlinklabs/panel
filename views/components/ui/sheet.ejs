<div id="<%= id %>-backdrop" data-ui-sheet-backdrop="<%= id %>" class="fixed inset-0 z-40 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-200"></div>
<section id="<%= id %>" data-ui-sheet class="fixed bottom-0 left-0 right-0 z-50 rounded-t-2xl bg-white dark:bg-neutral-800 border-t border-neutral-200/30 dark:border-white/5 translate-y-full transition-transform duration-300 ease-out" aria-modal="true" role="dialog" aria-labelledby="<%= id %>-title">
  <div class="mx-auto mt-3 h-1 w-10 rounded-full bg-neutral-300 dark:bg-neutral-600"></div>
  <div class="flex items-center justify-between px-4 py-3">
    <h2 id="<%= id %>-title" class="text-sm font-medium text-neutral-800 dark:text-white"><%= title %></h2>
    <% if (closeable !== false) { %><button type="button" data-ui-sheet-close="<%= id %>" class="h-10 w-10 rounded-lg text-neutral-500 hover:bg-neutral-100 dark:hover:bg-white/5">×</button><% } %>
  </div>
  <div class="px-4 pb-8"><%- content || '' %></div>
</section>
<script nonce="<%- nonce %>">document.addEventListener('DOMContentLoaded',function(){if(window.ui)window.ui.registerSheet('<%= id %>');});</script>
