<%- include('../../components/header', { title: req.translations.adminServersTitle || 'Servers' }) %>

<main class="">
  <%- include('../../components/template') %>
  <%- include('../../components/toast') %>
  <%- include('../../components/loadingPopup') %>

  <div class="px-4 py-5">

    <div class="flex items-start justify-between mb-4">
      <div>
        <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.adminServersTitle %></h1>
        <p class="text-xs text-neutral-500 mt-0.5"><%= req.translations.adminServersText %></p>
      </div>
      <button onclick="location.href='/admin/servers/create'" type="button" class="inline-flex items-center gap-1.5 rounded-xl bg-neutral-900 dark:bg-neutral-800 border border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-300 hover:bg-neutral-800 dark:hover:bg-neutral-700 transition shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        New Server
      </button>
    </div>

    <% if (req.query.err == "none") { %>
      <div class="rounded-xl bg-emerald-50 dark:bg-emerald-800/10 border border-emerald-200 dark:border-emerald-500/20 px-4 py-3 mb-4 flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-emerald-500 shrink-0">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
        </svg>
        <p class="text-sm text-emerald-700 dark:text-emerald-400"><%= req.translations.actionCompleted %></p>
      </div>
    <% } %>

    <!-- Bulk toolbar — shown when any server is checked -->
    <div id="bulkToolbar" class="mb-3 overflow-hidden" style="max-height:0;opacity:0;transition:max-height 0.2s ease,opacity 0.15s ease">
      <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-neutral-100 dark:bg-neutral-800/60 border border-neutral-200 dark:border-neutral-700/40">
        <span id="selectionCount" class="text-xs font-medium text-neutral-600 dark:text-neutral-300 mr-1">0 selected</span>
        <div class="h-3.5 w-px bg-neutral-300 dark:bg-neutral-600 mx-0.5"></div>
        <button type="button" onclick="bulkRadarScan()" class="inline-flex items-center gap-1 rounded-lg bg-white dark:bg-neutral-700 border border-neutral-200 dark:border-neutral-600 px-2.5 py-1.5 text-xs font-medium text-neutral-700 dark:text-neutral-200 hover:bg-neutral-50 dark:hover:bg-neutral-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          </svg>
          Radar
        </button>
        <button type="button" onclick="bulkDelete()" class="inline-flex items-center gap-1 rounded-lg bg-red-600 hover:bg-red-500 px-2.5 py-1.5 text-xs font-medium text-white transition-colors ml-auto">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
          </svg>
          Delete
        </button>
      </div>
    </div>

    <!-- Server cards -->
    <div class="space-y-2">
      <% servers.forEach(function(server) { %>
        <div class="server-card rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3" data-id="<%= server.id %>" data-uuid="<%= server.UUID %>">

          <!-- Header row -->
          <div class="flex items-center gap-3 mb-3">
            <input type="checkbox" class="server-checkbox rounded border-neutral-300 dark:border-neutral-600 cursor-pointer shrink-0" value="<%= server.id %>" data-uuid="<%= server.UUID %>" data-name="<%= server.name %>">
            <div class="w-7 h-7 rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 flex items-center justify-center shrink-0">
              <% if (server.Suspended) { %>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-neutral-400"></span>
              <% } else { %>
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                </span>
              <% } %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-neutral-800 dark:text-white truncate server-name"><%= server.name %></p>
              <p class="text-xs text-neutral-500 font-mono truncate"><%= server.UUID %></p>
            </div>
            <span class="text-[10px] font-medium px-2 py-0.5 rounded-md shrink-0 <%= server.Suspended ? 'bg-amber-50 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-200 dark:border-amber-500/20' : 'bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20' %>">
              <%= server.Suspended ? 'Suspended' : 'Enabled' %>
            </span>
          </div>

          <!-- Meta row -->
          <div class="flex gap-2 mb-3">
            <div class="flex-1 bg-neutral-100 dark:bg-neutral-800/50 rounded-lg px-2.5 py-2">
              <p class="text-[10px] text-neutral-500 mb-0.5">Owner</p>
              <a href="/admin/users/view/<%= server.owner.id %>" class="flex items-center gap-1.5">
                <img class="h-4 w-4 rounded object-cover shrink-0" src="<%= server.owner.avatar ? server.owner.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(server.owner.username) %>" alt="">
                <span class="text-xs font-medium text-blue-600 dark:text-blue-400 truncate"><%= server.owner.username %></span>
              </a>
            </div>
            <div class="flex-1 bg-neutral-100 dark:bg-neutral-800/50 rounded-lg px-2.5 py-2">
              <p class="text-[10px] text-neutral-500 mb-0.5">Node</p>
              <a href="/admin/node/<%= server.node.id %>/stats" class="text-xs font-medium text-blue-600 dark:text-blue-400 truncate block"><%= server.node.name %></a>
            </div>
            <div class="flex-1 bg-neutral-100 dark:bg-neutral-800/50 rounded-lg px-2.5 py-2">
              <p class="text-[10px] text-neutral-500 mb-0.5">Port</p>
              <p class="text-xs font-medium text-neutral-700 dark:text-neutral-300 font-mono truncate"><%= server.node.address %>:<%= JSON.parse(server.Ports).filter(p => p.primary).map(p => p.Port.split(':')[1]).pop() %></p>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex gap-2 justify-end">
            <a href="/server/<%= server.UUID %>">
              <button type="button" class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 p-2 text-neutral-600 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition" title="Open console">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
              </button>
            </a>
            <a href="/admin/servers/edit/<%= server.id %>">
              <button type="button" class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 p-2 text-neutral-600 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition" title="Edit server">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                </svg>
              </button>
            </a>
            <button onclick="openRadarScanModal('<%= server.id %>', '<%= server.name %>')" type="button" class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 p-2 text-neutral-600 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition" title="Radar scan">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
            </button>
            <button onclick="confirmDelete('<%= server.id %>', '<%= server.name %>')" type="button" class="rounded-lg bg-red-600 p-2 text-white hover:bg-red-500 transition" title="Delete server">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg>
            </button>
          </div>

        </div>
      <% }); %>
    </div>

  </div>
</main>



<!-- Radar Scan Modal -->
<div id="radarScanModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/60">
  <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-white/10 rounded-2xl w-full shadow-xl overflow-hidden max-h-[90vh] flex flex-col">

    <!-- Header -->
    <div class="flex items-start justify-between px-5 pt-5 pb-4 border-b border-neutral-200 dark:border-white/10 shrink-0">
      <div>
        <p class="text-sm font-medium text-neutral-800 dark:text-white" id="radarScanModalTitle">Radar Scan</p>
        <p class="text-xs text-neutral-500 mt-0.5" id="radarScanModalSubtitle">Pick a script and scan the server volume</p>
      </div>
      <button onclick="closeRadarScanModal()" class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200 transition ml-3 shrink-0 mt-0.5">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Script picker phase -->
    <div id="radarPickerPhase" class="px-5 py-4 shrink-0">

      <!-- Scan mode toggle — only shown when VT key is configured -->
      <div id="scanModeToggle" class="hidden mb-4">
        <div class="flex gap-2">
          <button type="button" id="modeBuiltin" onclick="setScanMode('builtin')" class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl border-2 border-neutral-800 dark:border-white bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 text-xs font-medium transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
            Built-in
          </button>
          <button type="button" id="modeVT" onclick="setScanMode('vt')" class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl border-2 border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 text-xs font-medium transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.25-8.25-3.286Z" /></svg>
            VirusTotal
          </button>
        </div>
      </div>

      <!-- Built-in script picker -->
      <div id="builtinPickerSection">
        <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Script</label>
        <select id="scriptSelect" class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2 text-sm text-neutral-800 dark:text-white mb-2 focus:outline-none"></select>
        <p id="scriptDescription" class="text-xs text-neutral-500 italic mb-4 min-h-4"></p>
        <button id="runScanButton" onclick="runRadarScan()" class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-neutral-900 dark:bg-neutral-700 border border-neutral-700/40 px-4 py-2.5 text-sm font-medium text-white hover:bg-neutral-800 transition">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
          Run Scan
        </button>
      </div>

      <!-- VT file scan section -->
      <div id="vtScanSection" class="hidden">
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/60 border border-neutral-200 dark:border-neutral-700/40 p-4 mb-4 space-y-1.5 text-xs text-neutral-500">
          <p>Zips <span class="font-mono text-neutral-700 dark:text-neutral-300">plugins/</span>, <span class="font-mono text-neutral-700 dark:text-neutral-300">mods/</span>, <span class="font-mono text-neutral-700 dark:text-neutral-300">config/</span>, <span class="font-mono text-neutral-700 dark:text-neutral-300">addons/</span>, <span class="font-mono text-neutral-700 dark:text-neutral-300">datapacks/</span> and uploads to VirusTotal.</p>
          <p>Excludes world folders, logs, cache. Max 32 MB. Takes 30–120 seconds.</p>
          <p class="text-amber-600 dark:text-amber-400">Free tier: 4 requests/min · 500/day.</p>
        </div>
        <button type="button" id="runVtScanButton" onclick="runVtFileScan()" class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-neutral-900 dark:bg-neutral-700 border border-neutral-700/40 px-4 py-2.5 text-sm font-medium text-white hover:bg-neutral-800 transition">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.25-8.25-3.286Z" /></svg>
          Upload to VirusTotal
        </button>
      </div>

    </div>

    <!-- Results phase -->
    <div id="radarResultsPhase" class="hidden flex flex-col min-h-0 flex-1">

      <!-- Summary bar -->
      <div id="radarSummaryBar" class="px-5 py-3 border-t border-neutral-200 dark:border-white/10 bg-neutral-50 dark:bg-neutral-800/60 shrink-0"></div>

      <!-- Results body -->
      <div id="radarResultsBody" class="px-5 py-4 overflow-y-auto flex-1"></div>

      <!-- Rescan link -->
      <div class="px-5 py-3 border-t border-neutral-200 dark:border-white/10 flex justify-between items-center shrink-0">
        <button type="button" onclick="resetRadarToPickerPhase()" class="text-xs text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition">← Run another scan</button>
        <button onclick="closeRadarScanModal()" class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-1.5 text-xs font-medium text-neutral-700 dark:text-neutral-200 transition">Close</button>
      </div>
    </div>

  </div>
</div>

<script>
  // --- VirusTotal ---

  let vtEnabled = false;
  let scanMode = 'builtin';

  fetch('/admin/radar/virustotal-enabled')
    .then(r => r.json())
    .then(d => {
      vtEnabled = d.enabled;
      if (vtEnabled) document.getElementById('scanModeToggle').classList.remove('hidden');
    })
    .catch(() => {});

  function setScanMode(mode) {
    scanMode = mode;
    const builtinBtn = document.getElementById('modeBuiltin');
    const vtBtn = document.getElementById('modeVT');
    const active   = 'flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl border-2 border-neutral-800 dark:border-white bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 text-xs font-medium transition-all';
    const inactive = 'flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl border-2 border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 text-xs font-medium transition-all';
    if (mode === 'builtin') {
      builtinBtn.className = active;
      vtBtn.className = inactive;
      document.getElementById('builtinPickerSection').classList.remove('hidden');
      document.getElementById('vtScanSection').classList.add('hidden');
    } else {
      vtBtn.className = active;
      builtinBtn.className = inactive;
      document.getElementById('vtScanSection').classList.remove('hidden');
      document.getElementById('builtinPickerSection').classList.add('hidden');
    }
  }

  async function runVtFileScan() {
    if (currentServerIds.length === 0) return;
    const serverId = currentServerIds[0];
    const btn = document.getElementById('runVtScanButton');

    btn.disabled = true;
    btn.innerHTML = `
      <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      Starting...
    `;

    closeRadarScanModal();

    const p = window.loadingPopupSystem;
    p.open('VirusTotal Scan', 'default');
    p.setProgress(5, 'Requesting file archive from node...');
    p.addStep('Connecting to node');

    const steps = [
      { at: 3000,  pct: 12, msg: 'Node zipping plugins, mods and config...', step: 'Archiving server files' },
      { at: 8000,  pct: 22, msg: 'Uploading archive to VirusTotal...',        step: 'Archive ready — uploading to VT' },
      { at: 14000, pct: 35, msg: 'VirusTotal is queuing the analysis...',      step: 'Upload complete' },
      { at: 22000, pct: 48, msg: 'Analysis in progress — checking signatures...', step: 'VT analysis started' },
      { at: 35000, pct: 60, msg: 'Running 70+ antivirus engines...',           step: 'Scanning with multiple engines' },
      { at: 50000, pct: 72, msg: 'Almost done — collecting results...',        step: 'Engines finishing up' },
      { at: 65000, pct: 82, msg: 'Waiting for final verdicts...',              step: 'Collecting final results' },
    ];
    const timers = steps.map(s => setTimeout(() => { p.setProgress(s.pct, s.msg); p.addStep(s.step); }, s.at));

    try {
      const r = await fetch('/admin/radar/vtscan/' + serverId, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await r.json();

      timers.forEach(t => clearTimeout(t));

      if (!data.success) {
        p.setProgress(100, 'Scan failed');
        p.addStep(data.error || 'VT scan failed', 'error');
        p.setIcon('error');
        showToast(data.error || 'VT scan failed', 'error');
        setTimeout(() => p.close(), 3000);
        return;
      }

      p.setProgress(100, 'Scan complete');
      p.addStep('Analysis complete', 'done');
      p.setIcon('done');

      setTimeout(() => {
        p.close();
        document.getElementById('radarScanModalTitle').textContent = 'VirusTotal Scan: ' + (data.serverName || 'Server');
        document.getElementById('radarPickerPhase').classList.add('hidden');
        document.getElementById('radarResultsPhase').classList.remove('hidden');
        const modal = document.getElementById('radarScanModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        renderVtFileScanResults(data);
      }, 1000);

    } catch (err) {
      timers.forEach(t => clearTimeout(t));
      p.setProgress(100, 'Request failed');
      p.addStep('Network error', 'error');
      p.setIcon('error');
      showToast('VT file scan failed', 'error');
      setTimeout(() => p.close(), 3000);
    } finally {
      btn.disabled = false;
      btn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.25-8.25-3.286Z" /></svg>
        Upload to VirusTotal
      `;
    }
  }

  function renderVtFileScanResults(data) {
    const summaryEl = document.getElementById('radarSummaryBar');
    const bodyEl    = document.getElementById('radarResultsBody');

    if (data.pending) {
      summaryEl.innerHTML = `<span class="text-sm text-amber-600 dark:text-amber-400 font-medium">Analysis still processing on VT</span>`;
      bodyEl.innerHTML = `
        <div class="py-6 text-center">
          <p class="text-sm text-neutral-600 dark:text-neutral-300 mb-3">VT is still analysing. Check directly:</p>
          <a href="${data.vtLink}" target="_blank" rel="noopener" class="text-sm text-blue-500 break-all">${data.vtLink}</a>
        </div>`;
      return;
    }

    const malCount = data.maliciousEngines?.length || 0;
    const total    = data.totalEngines || 0;

    if (malCount === 0) {
      summaryEl.innerHTML = `
        <div class="flex items-center justify-between">
          <span class="inline-flex items-center gap-1.5 text-sm text-emerald-600 dark:text-emerald-400 font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>
            Clean — 0/${total} engines flagged
          </span>
          <a href="${data.vtLink}" target="_blank" rel="noopener" class="text-xs text-blue-500">Full report →</a>
        </div>`;
      bodyEl.innerHTML = `
        <div class="py-8 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="w-8 h-8 mx-auto mb-3 text-emerald-400"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
          <p class="text-sm font-medium text-neutral-600 dark:text-neutral-300">No engines flagged anything</p>
          <p class="text-xs text-neutral-400 mt-1">${total} engines scanned the zip</p>
        </div>`;
      return;
    }

    summaryEl.innerHTML = `
      <div class="flex items-center justify-between">
        <span class="inline-flex items-center gap-1.5 text-sm text-red-600 dark:text-red-400 font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/></svg>
          ${malCount}/${total} engines flagged
        </span>
        <a href="${data.vtLink}" target="_blank" rel="noopener" class="text-xs text-blue-500">Full report →</a>
      </div>`;

    let html = '<div class="space-y-1">';
    data.maliciousEngines.forEach(e => {
      html += `<div class="flex items-center justify-between px-3 py-2 rounded-lg bg-red-50 dark:bg-red-900/10 border border-red-100 dark:border-red-900/20">`;
      html += `<span class="text-xs font-medium text-neutral-700 dark:text-neutral-300">${e.engine}</span>`;
      html += `<span class="text-xs text-red-600 dark:text-red-400 font-mono">${e.result || 'flagged'}</span>`;
      html += `</div>`;
    });
    html += '</div>';
    bodyEl.innerHTML = html;
  }

  async function checkVirusTotal(hash, matchId) {
    const btn = document.querySelector('#' + matchId + ' .vt-btn');
    const resultEl = document.querySelector('.vt-result-' + matchId);
    if (!btn || !resultEl) return;

    btn.disabled = true;
    btn.textContent = '...';

    try {
      const r = await fetch('/admin/radar/virustotal', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ hash }),
      });
      const data = await r.json();

      if (!data.success) {
        resultEl.innerHTML = '<span class="text-xs text-red-500">VT error: ' + data.error + '</span>';
      } else if (!data.found) {
        resultEl.innerHTML = '<span class="text-xs text-neutral-400">Not found in VirusTotal database</span>';
      } else {
        const colour = data.malicious > 0 ? 'text-red-600 dark:text-red-400' : 'text-emerald-600 dark:text-emerald-400';
        resultEl.innerHTML =
          '<div class="flex flex-wrap gap-x-2 gap-y-0.5">' +
          '<span class="text-xs font-medium ' + colour + '">' + data.malicious + '/' + data.total + ' engines</span>' +
          (data.name ? '<span class="text-xs text-neutral-400">' + data.name + '</span>' : '') +
          (data.firstSeen ? '<span class="text-xs text-neutral-400">first seen ' + data.firstSeen + '</span>' : '') +
          '<a href="' + data.vtLink + '" target="_blank" rel="noopener" class="text-xs text-blue-500">View on VT →</a>' +
          '</div>';
        btn.remove();
      }

      resultEl.classList.remove('hidden');
    } catch (err) {
      resultEl.innerHTML = '<span class="text-xs text-red-500">Request failed</span>';
      resultEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'VT';
    }
  }

  // --- Selection ---

  function getChecked() {
    return Array.from(document.querySelectorAll('.server-checkbox:checked'));
  }

  function updateToolbar() {
    const checked = getChecked();
    const toolbar = document.getElementById('bulkToolbar');
    document.getElementById('selectionCount').textContent = checked.length + ' selected';
    if (checked.length > 0) {
      toolbar.style.maxHeight = '60px';
      toolbar.style.opacity = '1';
    } else {
      toolbar.style.maxHeight = '0';
      toolbar.style.opacity = '0';
    }
  }

  document.querySelectorAll('.server-checkbox').forEach(cb => {
    cb.addEventListener('change', updateToolbar);
  });

  // Tap anywhere on a card (not on a button/link) toggles the checkbox
  document.querySelectorAll('.server-card').forEach(card => {
    card.addEventListener('click', function (e) {
      if (['A', 'BUTTON', 'INPUT'].includes(e.target.tagName) || e.target.closest('a, button')) return;
      const cb = card.querySelector('.server-checkbox');
      cb.checked = !cb.checked;
      updateToolbar();
    });
  });

  // --- Bulk actions ---

  function bulkRadarScan() {
    const checked = getChecked();
    if (checked.length === 0) return;
    if (checked.length === 1) {
      openRadarScanModal(checked[0].value, checked[0].dataset.name);
    } else {
      checked.forEach(cb => {
        fetch('/admin/radar/scan/' + cb.value, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ scriptId: document.getElementById('scriptSelect').value }),
        })
        .then(r => r.json())
        .then(data => {
          const name = cb.dataset.name || cb.value;
          const count = (data.results?.results || []).reduce((s, x) => s + (x.matches?.length || 0), 0);
          showToast(name + ': ' + (count > 0 ? count + ' finding(s)' : 'clean'), count > 0 ? 'error' : 'success');
        })
        .catch(() => showToast((cb.dataset.name || cb.value) + ': scan failed', 'error'));
      });
      openRadarScanModal(checked[0].value, checked[0].dataset.name);
    }
  }

  function bulkDelete() {
    const checked = getChecked();
    if (checked.length === 0) return;
    const msg = checked.length === 1
      ? 'Delete this server? All data will be permanently removed.'
      : 'Delete ' + checked.length + ' servers? All data will be permanently removed.';
    window.modal.confirm({
      title: checked.length === 1 ? 'Delete Server' : 'Delete ' + checked.length + ' Servers',
      body: msg,
      danger: true,
      confirmLabel: 'Delete',
      onConfirm: () => checked.forEach(cb => { window.location.href = '/admin/server/delete/' + cb.value; })
    });
  }

  function confirmDelete(serverId, serverName) {
    window.modal.confirm({
      title: 'Delete Server',
      body: 'Delete "' + serverName + '"? All server data will be permanently removed.',
      danger: true,
      confirmLabel: 'Delete',
      onConfirm: () => { window.location.href = '/admin/server/delete/' + serverId; }
    });
  }

  // --- Radar ---

  let currentServerIds = [];
  let availableScripts = [];

  function openRadarScanModal(serverId, serverName) {
    currentServerIds = [serverId];
    document.getElementById('radarScanModalTitle').textContent = 'Radar Scan: ' + serverName;
    document.getElementById('radarScanModalSubtitle').textContent = 'Pick a script and scan the server volume';
    document.getElementById('radarResultsPhase').classList.add('hidden');
    document.getElementById('radarPickerPhase').classList.remove('hidden');
    const modal = document.getElementById('radarScanModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    fetchRadarScripts();
  }

  function closeRadarScanModal() {
    const modal = document.getElementById('radarScanModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    currentServerIds = [];
  }

  function resetRadarToPickerPhase() {
    document.getElementById('radarResultsPhase').classList.add('hidden');
    document.getElementById('radarPickerPhase').classList.remove('hidden');
  }

  async function fetchRadarScripts() {
    const select = document.getElementById('scriptSelect');
    select.innerHTML = '<option value="">Loading...</option>';
    document.getElementById('runScanButton').disabled = true;
    try {
      const response = await fetch('/admin/radar/scripts');
      const data = await response.json();
      if (data.success && data.scripts) {
        availableScripts = data.scripts;
        select.innerHTML = '';
        if (availableScripts.length === 0) {
          select.innerHTML = '<option value="">No scripts available</option>';
          document.getElementById('scriptDescription').textContent = 'No radar scripts found in storage/radar.';
        } else {
          availableScripts.forEach(s => {
            const opt = document.createElement('option');
            opt.value = s.id;
            opt.textContent = s.name;
            select.appendChild(opt);
          });
          updateScriptDescription();
          document.getElementById('runScanButton').disabled = false;
        }
      }
    } catch (err) {
      showToast('Failed to fetch radar scripts', 'error');
    }
  }

  function updateScriptDescription() {
    const id = document.getElementById('scriptSelect').value;
    const script = availableScripts.find(s => s.id === id);
    document.getElementById('scriptDescription').textContent = script ? script.description : '';
  }

  document.getElementById('scriptSelect').addEventListener('change', updateScriptDescription);

  async function runRadarScan() {
    if (currentServerIds.length === 0) return;
    const scriptId = document.getElementById('scriptSelect').value;
    if (!scriptId) { showToast('Select a script', 'error'); return; }

    const btn = document.getElementById('runScanButton');
    btn.disabled = true;
    btn.innerHTML = `
      <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      Scanning...
    `;

    try {
      const r = await fetch('/admin/radar/scan/' + currentServerIds[0], {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ scriptId }),
      });
      const data = await r.json();

      if (!data.success) {
        showToast('Scan failed: ' + (data.error || 'Unknown error'), 'error');
      } else {
        document.getElementById('radarPickerPhase').classList.add('hidden');
        document.getElementById('radarResultsPhase').classList.remove('hidden');
        renderResults(data.results);
      }
    } catch (err) {
      showToast('Failed to run scan', 'error');
    } finally {
      btn.disabled = false;
      btn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
        </svg>
        Run Scan
      `;
    }
  }

  function renderResults(scanResults) {
    const summaryEl = document.getElementById('radarSummaryBar');
    const bodyEl = document.getElementById('radarResultsBody');

    const total = !scanResults || !scanResults.results
      ? 0
      : scanResults.results.reduce((s, r) => s + (r.matches?.length || 0), 0);

    if (total === 0) {
      summaryEl.innerHTML = `
        <span class="inline-flex items-center gap-1.5 text-sm text-emerald-600 dark:text-emerald-400 font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>
          No suspicious files found
        </span>`;
      bodyEl.innerHTML = `
        <div class="py-8 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="w-8 h-8 mx-auto mb-3 text-emerald-400">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
          </svg>
          <p class="text-sm font-medium text-neutral-600 dark:text-neutral-300">All clear</p>
          <p class="text-xs text-neutral-400 mt-1">No matches found for any pattern</p>
        </div>`;
      return;
    }

    const patternCount = scanResults.results.length;
    summaryEl.innerHTML = `
      <span class="inline-flex items-center gap-1.5 text-sm text-red-600 dark:text-red-400 font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/></svg>
        ${total} finding${total !== 1 ? 's' : ''} across ${patternCount} pattern${patternCount !== 1 ? 's' : ''}
      </span>`;

    const sevStyles = {
      critical: 'bg-red-100 dark:bg-red-900/20 text-red-600 dark:text-red-400',
      high:     'bg-orange-100 dark:bg-orange-900/20 text-orange-600 dark:text-orange-400',
      medium:   'bg-amber-100 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400',
      low:      'bg-yellow-100 dark:bg-yellow-900/20 text-yellow-600 dark:text-yellow-400',
    };

    let html = '<div class="space-y-3">';
    scanResults.results.forEach(result => {
      const sev = result.severity || 'low';
      const count = result.matches?.length || 0;
      html += `<div class="rounded-lg border border-neutral-200 dark:border-neutral-700/40 overflow-hidden">`;
      html += `<div class="flex items-center justify-between px-3 py-2 bg-neutral-100 dark:bg-neutral-800/60">`;
      html += `<p class="text-xs font-medium text-neutral-700 dark:text-neutral-200 flex-1 min-w-0 pr-2">${result.pattern.description}</p>`;
      html += `<div class="flex items-center gap-1.5 shrink-0">`;
      html += `<span class="text-xs font-medium px-2 py-0.5 rounded-full ${sevStyles[sev] || sevStyles.low}">${sev}</span>`;
      html += `<span class="text-xs text-neutral-500">${count}</span>`;
      html += `</div></div>`;
      html += `<ul class="divide-y divide-neutral-100 dark:divide-neutral-700/30">`;
      result.matches.forEach(match => {
        const matchId = 'mm-' + Math.random().toString(36).slice(2, 8);
        html += `<li class="px-3 py-2" id="${matchId}">`;
        html += `<div class="flex items-center justify-between gap-2">`;
        html += `<span class="text-xs font-mono text-neutral-600 dark:text-neutral-300 truncate">${match.path}</span>`;
        html += `<div class="flex items-center gap-1.5 shrink-0">`;
        if (match.size) html += `<span class="text-xs text-neutral-400">${formatFileSize(match.size)}</span>`;
        if (match.hash && vtEnabled) {
          html += `<button type="button" onclick="checkVirusTotal('${match.hash}', '${matchId}')" class="vt-btn text-xs px-1.5 py-0.5 rounded border border-neutral-300 dark:border-neutral-600 text-neutral-500 dark:text-neutral-400 active:bg-neutral-100 dark:active:bg-neutral-700">VT</button>`;
        }
        html += `</div></div>`;
        html += `<div class="vt-result-${matchId} mt-1 hidden"></div>`;
        html += `</li>`;
      });
      html += `</ul></div>`;
    });
    html += '</div>';
    bodyEl.innerHTML = html;
  }

  function formatFileSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    if (bytes < 1073741824) return (bytes / 1048576).toFixed(1) + ' MB';
    return (bytes / 1073741824).toFixed(1) + ' GB';
  }
</script>

