<%- include('../../components/header', { title: 'Analytics' }) %>

<main id="page-content" class="">
  <%- include('../../components/template') %>
  <%- include('../../components/toast') %>

  <div class="px-4 py-5">

    <div class="flex items-start justify-between mb-5">
      <div>
        <h1 class="text-base font-medium text-neutral-800 dark:text-white">Analytics</h1>
        <p class="text-xs text-neutral-500 mt-0.5">Server performance and player activity</p>
      </div>
      <button id="refreshBtn" type="button" class="inline-flex items-center gap-1.5 rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
        </svg>
        Refresh
      </button>
    </div>

    <% if (errorMessage && errorMessage.message) { %>
      <div class="rounded-xl bg-red-50 dark:bg-red-800/10 border border-red-200 dark:border-red-500/20 px-4 py-3 mb-4 flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-red-500 shrink-0 mt-0.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 3.014-1.874 2.148-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
        </svg>
        <p class="text-xs text-red-600 dark:text-red-400"><%= errorMessage.message %></p>
      </div>
    <% } %>

    <!-- Tab buttons -->
    <div class="flex gap-1 p-1 bg-neutral-100 dark:bg-neutral-800/50 rounded-xl mb-5">
      <button onclick="switchTab('playerstats')" id="tab-playerstats" class="flex-1 rounded-lg py-2 text-xs font-medium transition tab-btn bg-white dark:bg-neutral-700 text-neutral-800 dark:text-white shadow-sm">Player Stats</button>
      <button onclick="switchTab('performance')" id="tab-performance" class="flex-1 rounded-lg py-2 text-xs font-medium transition tab-btn text-neutral-500 dark:text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-200">Performance</button>
      <button onclick="switchTab('usage')" id="tab-usage" class="flex-1 rounded-lg py-2 text-xs font-medium transition tab-btn text-neutral-500 dark:text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-200">Usage</button>
    </div>

    <!-- Player Stats tab -->
    <div id="content-playerstats" class="tab-content">
      <div class="grid grid-cols-2 gap-3 mb-5">
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Total Players</p>
          <p id="totalPlayers" class="text-2xl font-semibold text-neutral-800 dark:text-white">0</p>
          <p class="text-xs text-neutral-500 mt-1">Across all servers</p>
        </div>
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Capacity</p>
          <p id="maxCapacity" class="text-2xl font-semibold text-neutral-800 dark:text-white">0</p>
          <p class="text-xs text-neutral-500 mt-1">Max slots</p>
        </div>
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Online Servers</p>
          <p id="onlineServers" class="text-2xl font-semibold text-neutral-800 dark:text-white">0</p>
          <p class="text-xs text-neutral-500 mt-1">Currently up</p>
        </div>
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Utilization</p>
          <p id="utilization" class="text-2xl font-semibold text-neutral-800 dark:text-white">0%</p>
          <p class="text-xs text-neutral-500 mt-1">Capacity used</p>
        </div>
      </div>

      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4 mb-4">
        <div class="flex items-center justify-between mb-3">
          <p class="text-sm font-medium text-neutral-800 dark:text-white">Player History</p>
          <p class="text-[10px] text-neutral-500">Last 48 hours</p>
        </div>
        <div class="h-44">
          <canvas id="playerChart" class="w-full h-full"></canvas>
        </div>
      </div>

      <button id="serverDetailsBtn" type="button" class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-4 py-2.5 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">
        View Server Details
      </button>
    </div>

    <!-- Performance tab -->
    <div id="content-performance" class="tab-content hidden">
      <div class="py-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 mx-auto mb-3 text-neutral-300 dark:text-neutral-700">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z" />
        </svg>
        <p class="text-sm font-medium text-neutral-800 dark:text-white mb-1">Performance Metrics</p>
        <p class="text-xs text-neutral-500">Coming in a future update</p>
      </div>
    </div>

    <!-- Usage tab -->
    <div id="content-usage" class="tab-content hidden">
      <div class="py-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10 mx-auto mb-3 text-neutral-300 dark:text-neutral-700">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
        </svg>
        <p class="text-sm font-medium text-neutral-800 dark:text-white mb-1">Usage Analytics</p>
        <p class="text-xs text-neutral-500">Coming in a future update</p>
      </div>
    </div>

  </div>
</main>

<!-- Server details modal -->
<div id="serverDetailsModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/60">
  <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-white/10 rounded-2xl p-5 w-full shadow-xl max-h-[80vh] flex flex-col">
    <div class="flex items-center justify-between mb-4">
      <p class="text-sm font-medium text-neutral-800 dark:text-white">Server Details</p>
      <button id="closeServerModal" class="w-7 h-7 flex items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800 text-neutral-500 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div id="serverDetailsList" class="flex-1 overflow-y-auto space-y-2"></div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  let playerChart;
  let refreshInterval;
  let serverData = [];

  const ctx = document.getElementById('playerChart').getContext('2d');
  playerChart = new Chart(ctx, {
    type: 'line',
    data: { labels: [], datasets: [{ label: 'Players', data: [], backgroundColor: 'rgba(163,163,163,0.1)', borderColor: 'rgba(163,163,163,0.8)', borderWidth: 2, fill: true, tension: 0.4, pointRadius: 2 }] },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: 'rgba(128,128,128,0.8)', maxRotation: 0 }, grid: { color: 'rgba(128,128,128,0.1)' } },
        y: { beginAtZero: true, ticks: { color: 'rgba(128,128,128,0.8)' }, grid: { color: 'rgba(128,128,128,0.1)' } }
      }
    }
  });

  function switchTab(name) {
    document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('.tab-btn').forEach(el => {
      el.classList.remove('bg-white', 'dark:bg-neutral-700', 'text-neutral-800', 'dark:text-white', 'shadow-sm');
      el.classList.add('text-neutral-500', 'dark:text-neutral-400');
    });
    const target = document.getElementById('content-' + name);
    target.classList.remove('hidden');
    target.style.opacity = '0';
    target.style.transform = 'translateY(5px)';
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        target.style.transition = 'opacity 0.18s ease, transform 0.18s ease';
        target.style.opacity = '1';
        target.style.transform = 'translateY(0)';
        setTimeout(function() { target.style.transition = ''; target.style.opacity = ''; target.style.transform = ''; }, 200);
      });
    });
    const btn = document.getElementById('tab-' + name);
    btn.classList.remove('text-neutral-500', 'dark:text-neutral-400');
    btn.classList.add('bg-white', 'dark:bg-neutral-700', 'text-neutral-800', 'dark:text-white', 'shadow-sm');
    if (name === 'playerstats') fetchData();
  }

  async function fetchData() {
    try {
      const response = await fetch('/admin/playerstats/data');
      if (!response.ok) throw new Error('Request failed');
      const data = await response.json();
      if (data.error) throw new Error(data.error);

      document.getElementById('totalPlayers').textContent = data.totalPlayers ?? 0;
      document.getElementById('maxCapacity').textContent = data.totalMaxPlayers ?? 0;
      document.getElementById('onlineServers').textContent = data.onlineServers ?? 0;
      const pct = data.totalMaxPlayers > 0 ? Math.round((data.totalPlayers / data.totalMaxPlayers) * 100) : 0;
      document.getElementById('utilization').textContent = `${pct}%`;

      serverData = data.servers || [];

      if (data.historicalData && data.historicalData.length > 0) {
        playerChart.data.labels = data.historicalData.map(e => new Date(e.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }));
        playerChart.data.datasets[0].data = data.historicalData.map(e => e.totalPlayers);
        playerChart.update('none');
      }
    } catch (err) {
      console.error('Analytics fetch failed:', err);
    }
  }

  function showServerModal() {
    const list = document.getElementById('serverDetailsList');
    list.innerHTML = '';
    if (serverData.length === 0) {
      list.innerHTML = '<p class="text-xs text-neutral-500 text-center py-4">No servers found</p>';
    } else {
      serverData.forEach(s => {
        const div = document.createElement('div');
        div.className = 'rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3 flex items-center gap-3';
        div.innerHTML = `
          <div class="w-2 h-2 rounded-full shrink-0 ${s.online ? 'bg-emerald-500' : 'bg-neutral-400'}"></div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-neutral-800 dark:text-white truncate">${s.serverName || 'Unknown'}</p>
            <p class="text-xs text-neutral-500">${s.version || 'Unknown'}</p>
          </div>
          <p class="text-sm font-medium text-neutral-700 dark:text-neutral-300 shrink-0">${s.playerCount ?? 0}/${s.maxPlayers ?? 0}</p>
        `;
        list.appendChild(div);
      });
    }
    const modal = document.getElementById('serverDetailsModal');
    const inner = modal.querySelector('div');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    modal.style.opacity = '0';
    if (inner) { inner.style.transform = 'scale(0.97) translateY(6px)'; inner.style.opacity = '0'; }
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        modal.style.transition = 'opacity 0.18s ease';
        modal.style.opacity = '1';
        if (inner) {
          inner.style.transition = 'transform 0.18s ease, opacity 0.18s ease';
          inner.style.transform = 'scale(1) translateY(0)';
          inner.style.opacity = '1';
        }
        setTimeout(function() {
          modal.style.transition = ''; modal.style.opacity = '';
          if (inner) { inner.style.transition = ''; inner.style.transform = ''; inner.style.opacity = ''; }
        }, 200);
      });
    });
  }

  document.getElementById('closeServerModal').addEventListener('click', () => {
    const modal = document.getElementById('serverDetailsModal');
    const inner = modal.querySelector('div');
    modal.style.transition = 'opacity 0.15s ease';
    modal.style.opacity = '0';
    if (inner) {
      inner.style.transition = 'transform 0.15s ease, opacity 0.15s ease';
      inner.style.transform = 'scale(0.97) translateY(6px)';
      inner.style.opacity = '0';
    }
    setTimeout(function() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      modal.style.transition = ''; modal.style.opacity = '';
      if (inner) { inner.style.transition = ''; inner.style.transform = ''; inner.style.opacity = ''; }
    }, 160);
  });

  document.getElementById('serverDetailsBtn').addEventListener('click', showServerModal);

  document.getElementById('refreshBtn').addEventListener('click', function() {
    const icon = this.querySelector('svg');
    if (icon) {
      icon.style.transition = 'transform 0.6s ease';
      icon.style.transform = 'rotate(360deg)';
      setTimeout(function() { icon.style.transition = ''; icon.style.transform = ''; }, 650);
    }
    fetchData();
  });

  document.getElementById('refreshBtn').addEventListener('dblclick', async (e) => {
    e.preventDefault();
    try { await fetch('/api/admin/playerstats/collect', { method: 'POST' }); setTimeout(fetchData, 1000); } catch {}
  });

  fetchData();
  refreshInterval = setInterval(fetchData, 300000);
  window.addEventListener('beforeunload', () => clearInterval(refreshInterval));
</script>

<%- include('../../components/footer') %>
