<!-- Mobile top bar -->
<div class="mobile-top-bar fixed top-0 left-0 right-0 z-50 h-14 bg-white dark:bg-[#141414] border-b border-neutral-200 dark:border-white/5">
  <div id="topbar-default" class="flex items-center justify-between h-14 px-4">
    <a href="/" class="flex items-center gap-2 min-w-0 flex-1 mr-3">
      <img src="<%= settings.logo.startsWith('/') ? settings.logo : '/' + settings.logo %>" alt="Logo" class="logo-bg h-8 w-8 rounded-lg bg-neutral-950/90 dark:bg-transparent p-0.5 shrink-0">
      <span class="text-sm font-medium text-neutral-800 dark:text-white truncate"><%= settings.title %></span>
    </a>
    <div class="flex items-center gap-2.5 shrink-0">
      <button id="mobile-search-open" class="p-1.5 rounded-lg text-neutral-500 dark:text-neutral-400 hover:bg-neutral-100 dark:hover:bg-white/5 transition">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
          <path fill-rule="evenodd" d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Z" clip-rule="evenodd" />
        </svg>
      </button>
      <button id="theme-toggle" class="w-11 h-6 flex items-center bg-gray-300 dark:bg-neutral-700/70 rounded-full p-1 transition-colors duration-500">
        <span class="dot bg-white w-4 h-4 rounded-full shadow-md transform transition-transform duration-500 border border-neutral-950/20"></span>
      </button>
      <a href="/account">
        <img class="h-8 w-8 rounded-lg border border-neutral-200 dark:border-neutral-700" src="<%= user.avatar ? user.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(user.username) %>" alt="Avatar">
      </a>
    </div>
  </div>
  <div id="topbar-search" class="hidden items-center h-14 px-3 gap-2">
    <button id="mobile-search-close" class="p-1.5 text-neutral-500 dark:text-neutral-400 shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
        <path fill-rule="evenodd" d="M7.72 12.53a.75.75 0 0 1 0-1.06l7.5-7.5a.75.75 0 1 1 1.06 1.06L9.31 12l6.97 6.97a.75.75 0 1 1-1.06 1.06l-7.5-7.5Z" clip-rule="evenodd" />
      </svg>
    </button>
    <div class="flex-1 flex items-center bg-neutral-100 dark:bg-neutral-800 rounded-xl px-3 py-2 gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 text-neutral-400 shrink-0">
        <path fill-rule="evenodd" d="M10.5 3.75a6.75 6.75 0 1 0 0 13.5 6.75 6.75 0 0 0 0-13.5ZM2.25 10.5a8.25 8.25 0 1 1 14.59 5.28l4.69 4.69a.75.75 0 1 1-1.06 1.06l-4.69-4.69A8.25 8.25 0 0 1 2.25 10.5Z" clip-rule="evenodd" />
      </svg>
      <input id="mobileSearchInput" type="search" autocomplete="off" placeholder="Search navigation..."
        class="flex-1 bg-transparent text-sm text-neutral-800 dark:text-white placeholder-neutral-400 focus:outline-none">
    </div>
  </div>
</div>

<div id="mobileSearchResults" class="hidden fixed top-14 left-0 right-0 z-40 bg-white dark:bg-[#141414] border-b border-neutral-200 dark:border-white/5 max-h-[60dvh] overflow-y-auto shadow-lg">
</div>

<%
const allSidebarItems = regularMenuItems || (global.uiComponentStore ? global.uiComponentStore.getSidebarItems(undefined, false) : []);
const sidebarItems = allSidebarItems.filter(function(item) { return item.id !== 'account'; });
const mainNavItems = sidebarItems.slice(0, 3);
const extraItems = sidebarItems.length > 3 ? sidebarItems.slice(3) : [];
%>

<!-- Mobile bottom nav -->
<nav class="mobile-bottom-nav fixed bottom-0 left-0 right-0 z-50 bg-white dark:bg-[#141414] border-t border-neutral-200 dark:border-white/5">
  <ul class="flex items-center justify-around h-16">

    <% if (!sidebarItems || sidebarItems.length === 0) { %>
      <li class="flex-1">
        <a href="/" class="mobile-nav-link flex flex-col items-center justify-center h-16 gap-1 text-neutral-500 dark:text-neutral-400" data-match-exact="true" data-match-prefix-also="/server">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
            <path d="M12.378 1.602a.75.75 0 0 0-.756 0L3 6.632l9 5.25 9-5.25-8.622-5.03ZM21.75 7.93l-9 5.25v9l8.628-5.032a.75.75 0 0 0 .372-.648V7.93ZM11.25 22.18v-9l-9-5.25v8.57a.75.75 0 0 0 .372.648l8.628 5.033Z" />
          </svg>
          <span class="text-[10px] font-medium"><%= req.translations.navServers || 'Servers' %></span>
        </a>
      </li>
    <% } else { %>
      <% mainNavItems.forEach(function(item) { %>
      <li class="flex-1">
        <a href="<%= item.url %>" class="mobile-nav-link flex flex-col items-center justify-center h-16 gap-1 text-neutral-500 dark:text-neutral-400">
          <div class="w-5 h-5 flex items-center justify-center [&>svg]:w-5 [&>svg]:h-5 [&>svg]:shrink-0"><%- item.icon %></div>
          <span class="text-[10px] font-medium"><%= item.label %></span>
        </a>
      </li>
      <% }); %>
    <% } %>

    <% if (extraItems.length > 0) { %>
    <li class="flex-1">
      <button id="more-nav-btn" class="flex flex-col items-center justify-center w-full h-16 gap-1 text-neutral-500 dark:text-neutral-400">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <span class="text-[10px] font-medium"><%= req.translations.navMore || 'More' %></span>
      </button>
    </li>
    <% } %>

    <% if (user.isAdmin === true) { %>
    <li class="flex-1">
      <a href="/admin/menu" class="mobile-nav-link flex flex-col items-center justify-center h-16 gap-1 text-neutral-500 dark:text-neutral-400" data-match-prefix="/admin">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
        </svg>
        <span class="text-[10px] font-medium"><%= req.translations.navAdmin || 'Admin' %></span>
      </a>
    </li>
    <% } %>

    <li class="flex-1">
      <a href="/logout" class="mobile-nav-link flex flex-col items-center justify-center h-16 gap-1 text-neutral-500 dark:text-neutral-400">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" />
        </svg>
        <span class="text-[10px] font-medium"><%= req.translations.navLogout || 'Logout' %></span>
      </a>
    </li>

  </ul>
</nav>

<% if (extraItems.length > 0) { %>
<div id="more-sheet-backdrop" class="fixed inset-0 z-40 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-200"></div>
<div id="more-sheet" class="mobile-more-sheet fixed bottom-0 left-0 right-0 z-50 bg-white dark:bg-[#1c1c1c] border-t border-neutral-200 dark:border-white/5 rounded-t-2xl translate-y-full transition-transform duration-300 ease-out">
  <div class="flex items-center justify-between px-4 pt-4 pb-2">
    <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.navMore || 'More' %></p>
    <button id="more-sheet-close" class="w-7 h-7 flex items-center justify-center rounded-lg text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200 transition">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  <div class="px-4 pb-8 space-y-1">
    <% extraItems.forEach(function(item) { %>
    <a href="<%= item.url %>" class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-neutral-100 dark:hover:bg-white/5 transition">
      <div class="w-8 h-8 flex items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800 shrink-0 [&>svg]:w-4 [&>svg]:h-4 [&>svg]:shrink-0">
        <%- item.icon %>
      </div>
      <span class="text-sm font-medium text-neutral-700 dark:text-neutral-200"><%= item.label %></span>
    </a>
    <% }); %>
  </div>
</div>
<% } %>

<script>
(function () {
  // Mobile nav active state is handled by page-loader.js.
  // Keep sheet toggle and presence WebSocket here.
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof updateToggleDot === 'function') updateToggleDot();

    var moreBtn      = document.getElementById('more-nav-btn');
    var moreSheet    = document.getElementById('more-sheet');
    var moreBackdrop = document.getElementById('more-sheet-backdrop');
    var moreClose    = document.getElementById('more-sheet-close');

    function openSheet()  { if (moreSheet) { moreSheet.classList.remove('translate-y-full'); moreBackdrop.classList.remove('opacity-0', 'pointer-events-none'); } }
    function closeSheet() { if (moreSheet) { moreSheet.classList.add('translate-y-full');    moreBackdrop.classList.add('opacity-0', 'pointer-events-none'); } }

    if (moreBtn)      moreBtn.addEventListener('click', openSheet);
    if (moreClose)    moreClose.addEventListener('click', closeSheet);
    if (moreBackdrop) moreBackdrop.addEventListener('click', closeSheet);

    var wsProtocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    var ws = new WebSocket(wsProtocol + '//' + window.location.host + '/online-check');
    ws.addEventListener('error', function () {});
  });
})();
</script>
<script>
(function () {
  var ov = document.getElementById('pl-overlay');
  if (!ov) return;
  // Top bar is h-14 = 56px, bottom nav is h-16 = 64px — fixed Tailwind values
  ov.style.top    = '56px';
  ov.style.left   = '0';
  ov.style.right  = '0';
  ov.style.bottom = '64px';
  ov.style.display = 'flex';
})();
</script>
<script>
(function () {
  var openBtn    = document.getElementById('mobile-search-open');
  var closeBtn   = document.getElementById('mobile-search-close');
  var defaultBar = document.getElementById('topbar-default');
  var searchBar  = document.getElementById('topbar-search');
  var input      = document.getElementById('mobileSearchInput');
  var resultsEl  = document.getElementById('mobileSearchResults');

  if (!openBtn || !input || !resultsEl) return;

  function renderResults(term) {
    resultsEl.innerHTML = '';
    if (!term) { resultsEl.classList.add('hidden'); return; }

    var links = Array.from(document.querySelectorAll('.mobile-nav-link, .nav-link'));
    var lower = term.toLowerCase();

    var matches = links.filter(function (link) {
      var text = (link.textContent || '').toLowerCase();
      var data = (link.getAttribute('data-search') || '').toLowerCase();
      return text.includes(lower) || data.includes(lower);
    });

    if (matches.length === 0) {
      var p = document.createElement('p');
      p.className = 'px-4 py-3 text-sm text-neutral-400';
      p.textContent = 'No results.';
      resultsEl.appendChild(p);
    } else {
      matches.forEach(function (link) {
        var a = document.createElement('a');
        a.href = link.href || '#';
        a.className = 'flex items-center gap-3 px-4 py-3 border-b border-neutral-100 dark:border-white/5 last:border-0 hover:bg-neutral-50 dark:hover:bg-white/5 transition';
        var icon = link.querySelector('svg');
        if (icon) { var ic = icon.cloneNode(true); ic.className = 'h-5 w-5 text-neutral-400 shrink-0'; a.appendChild(ic); }
        var span = document.createElement('span');
        span.className = 'text-sm text-neutral-800 dark:text-white';
        span.textContent = link.textContent.trim();
        a.appendChild(span);
        resultsEl.appendChild(a);
      });
    }
    resultsEl.classList.remove('hidden');
  }

  openBtn.addEventListener('click', function () {
    defaultBar.classList.add('hidden');
    searchBar.classList.remove('hidden');
    searchBar.classList.add('flex');
    input.value = '';
    resultsEl.classList.add('hidden');
    setTimeout(function () { input.focus(); }, 60);
  });

  function closeSearch() {
    searchBar.classList.add('hidden');
    searchBar.classList.remove('flex');
    defaultBar.classList.remove('hidden');
    resultsEl.classList.add('hidden');
    input.value = '';
  }

  closeBtn.addEventListener('click', closeSearch);

  var debounce;
  input.addEventListener('input', function () {
    clearTimeout(debounce);
    debounce = setTimeout(function () { renderResults(input.value.trim()); }, 120);
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeSearch();
  });
})();
</script>
