<%- include('../components/header', { title: req.translations.userAccountTitle || 'Account' }) %>

<div id="toast-container" class="fixed top-16 right-4 z-50 flex flex-col gap-2"></div>

<main class="">
  <%- include('../components/template') %>

  <div class="px-4 py-4 space-y-4">
    <div class="mb-4">
      <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.userAccountTitle %></h1>
      <p class="text-xs text-neutral-500 mt-0.5"><%= req.translations.userAccountText %></p>
    </div>

    <!-- Profile Picture -->
    <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
      <h2 class="text-sm font-medium text-neutral-800 dark:text-white mb-4">Profile Picture</h2>
      <div class="flex items-center gap-4">
        <img id="avatar-preview" src="<%= user.avatar ? user.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(user.username) %>" alt="Avatar" class="h-16 w-16 rounded-xl border border-neutral-200 dark:border-neutral-700/30 object-cover shrink-0">
        <div class="flex flex-col gap-2">
          <label for="avatar-input" class="cursor-pointer inline-block rounded-xl bg-neutral-100 dark:bg-neutral-700/30 border border-neutral-200 dark:border-neutral-600/30 px-3 py-2 text-xs font-medium text-neutral-700 dark:text-neutral-300 transition active:scale-95">
            Choose image
          </label>
          <input id="avatar-input" type="file" accept="image/*" class="hidden">
          <p class="text-[10px] text-neutral-400">JPG, PNG, GIF or WebP — max 2 MB</p>
          <% if (user.avatar) { %>
          <button id="remove-avatar-btn" type="button" class="text-xs text-red-500 text-left">Remove picture</button>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Account settings -->
    <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
      <h2 class="text-sm font-medium text-neutral-800 dark:text-white mb-4"><%= req.translations.updateAccount %></h2>

      <form id="change-username-form" action="/change-username" method="POST" class="mb-4">
        <%- include('../components/csrf') %>
        <label class="block text-neutral-600 dark:text-neutral-400 text-xs font-medium mb-1.5"><%= req.translations.username %></label>
        <div class="flex gap-2">
          <input id="username" type="text" name="username"
            class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:outline-none text-sm w-full px-3 py-2 bg-neutral-100 dark:bg-neutral-700/20 placeholder-neutral-500 dark:placeholder-neutral-400 text-neutral-800 dark:text-white"
            placeholder="<%= user.username %>" />
          <button type="submit" id="change-username-btn" disabled
            class="rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium shrink-0 disabled:opacity-50 disabled:cursor-not-allowed">
            <%= req.translations.update %>
          </button>
        </div>
        <span id="username-feedback" class="mt-1.5 text-neutral-400 text-xs inline-block"><%= req.translations.checking %></span>
      </form>

      <form id="change-email-form" class="mb-4">
        <%- include('../components/csrf') %>
        <label class="block text-neutral-600 dark:text-neutral-400 text-xs font-medium mb-1.5"><%= req.translations.email %></label>
        <div class="flex gap-2">
          <input id="email" type="email" name="email"
            class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:outline-none text-sm w-full px-3 py-2 bg-neutral-100 dark:bg-neutral-700/20 placeholder-neutral-500 dark:placeholder-neutral-400 text-neutral-800 dark:text-white"
            placeholder="<%= user.email %>" />
          <button type="submit"
            class="rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium shrink-0">
            <%= req.translations.update %>
          </button>
        </div>
      </form>

      <form id="change-description-form" class="p-3 rounded-xl bg-neutral-100 dark:bg-neutral-700/20 border border-neutral-200 dark:border-white/5 mb-4">
        <%- include('../components/csrf') %>
        <label class="block text-neutral-600 dark:text-neutral-400 text-xs font-medium mb-1.5"><%= req.translations.description %></label>
        <textarea id="description" name="description"
          class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:outline-none text-sm w-full px-3 py-2 bg-neutral-100 dark:bg-neutral-700/20 placeholder-neutral-500 dark:placeholder-neutral-400 text-neutral-800 dark:text-white min-h-[70px]"
          placeholder="<%= user.description %>"><%= user.description %></textarea>
        <button type="submit" class="mt-2 rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium">
          <%= req.translations.updateDescription %>
        </button>
      </form>

      <form id="change-password-form" class="p-3 rounded-xl bg-neutral-100 dark:bg-neutral-700/20 border border-neutral-200 dark:border-white/5">
        <%- include('../components/csrf') %>
        <h3 class="text-xs font-medium text-neutral-800 dark:text-white mb-3"><%= req.translations.changePassword || 'Change Password' %></h3>
        <div id="current-password-feedback" class="text-neutral-400 text-xs mb-2"><%= req.translations.checking %></div>
        <input id="currentPassword" type="password" name="currentPassword"
          class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:outline-none text-sm w-full px-3 py-2 bg-neutral-100 dark:bg-neutral-700/20 text-neutral-800 dark:text-white mb-3"
          placeholder="<%= req.translations.currentPasswordHide %>" />
        <input id="newPassword" type="password" name="newPassword"
          class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:outline-none text-sm w-full px-3 py-2 bg-neutral-100 dark:bg-neutral-700/20 text-neutral-800 dark:text-white mb-3"
          placeholder="<%= req.translations.newPasswordHide %>" disabled />
        <button type="submit" class="rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium">
          <%= req.translations.update_password %>
        </button>
      </form>
    </div>

    <!-- Language -->
    <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
      <h2 class="text-sm font-medium text-neutral-800 dark:text-white mb-4"><%= req.translations.languagePreference || 'Language' %></h2>
      <form id="language-preference-form" class="p-3 rounded-xl bg-neutral-100 dark:bg-neutral-700/20 border border-neutral-200 dark:border-white/5">
        <%- include('../components/csrf') %>
        <select id="language" name="language"
          class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:outline-none text-sm w-full px-3 py-2 bg-neutral-100 dark:bg-neutral-700/20 text-neutral-800 dark:text-white mb-3">
          <option class="text-black" value="en" <%= req.lang === 'en' ? 'selected' : '' %>>English</option>
          <option class="text-black" value="fr" <%= req.lang === 'fr' ? 'selected' : '' %>>Français</option>
          <option class="text-black" value="de" <%= req.lang === 'de' ? 'selected' : '' %>>Deutsch</option>
          <option class="text-black" value="es" <%= req.lang === 'es' ? 'selected' : '' %>>Español</option>
          <option class="text-black" value="pt" <%= req.lang === 'pt' ? 'selected' : '' %>>Português</option>
          <option class="text-black" value="it" <%= req.lang === 'it' ? 'selected' : '' %>>Italiano</option>
          <option class="text-black" value="ru" <%= req.lang === 'ru' ? 'selected' : '' %>>Русский</option>
          <option class="text-black" value="zh" <%= req.lang === 'zh' ? 'selected' : '' %>>中文</option>
          <option class="text-black" value="ja" <%= req.lang === 'ja' ? 'selected' : '' %>>日本語</option>
          <option class="text-black" value="ta" <%= req.lang === 'ta' ? 'selected' : '' %>>தமிழ்</option>
        </select>
        <button type="submit" class="rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium">
          <%= req.translations.saveLanguagePreference || 'Save' %>
        </button>
      </form>
    </div>

    <!-- Login history -->
    <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
      <h2 class="text-sm font-medium text-neutral-800 dark:text-white mb-4"><%= req.translations.loginHistory || 'Login History' %></h2>
      <div class="space-y-2">
        <% if (loginHistory && loginHistory.length > 0) { %>
          <% loginHistory.forEach(login => { %>
            <div class="p-3 rounded-lg bg-neutral-100 dark:bg-neutral-700/20 border border-neutral-200 dark:border-white/5">
              <p class="text-xs font-medium text-neutral-800 dark:text-white"><%= new Date(login.timestamp).toLocaleString() %></p>
              <p class="text-xs text-neutral-500 mt-0.5"><%= login.ipAddress || 'Unknown' %></p>
              <p class="text-xs text-neutral-500 mt-0.5 truncate"><%= login.userAgent || 'Unknown' %></p>
            </div>
          <% }); %>
        <% } else { %>
          <p class="text-xs text-neutral-400"><%= req.translations.noLoginHistory || 'No login history' %></p>
        <% } %>
      </div>
    </div>
  </div>

  </div>
</main>

<%- include('../components/toast') %>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const { showToast } = createToastSystem();
    let isSubmitting = false;

    const getCSRF = () => document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');

    const submitForm = async (endpoint, data, successMessage, redirectUrl = null) => {
      if (isSubmitting) return;
      isSubmitting = true;
      try {
        const response = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCSRF() },
          body: JSON.stringify(data)
        });
        const responseBody = await response.text();
        if (response.ok) {
          showToast(successMessage, 'success');
          if (redirectUrl) setTimeout(() => window.location.href = redirectUrl, 1500);
        } else {
          showToast(responseBody);
        }
      } catch (error) {
        showToast(`Error: ${error.message}`);
      } finally {
        isSubmitting = false;
      }
    };

    document.getElementById('change-username-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const usernameInput = e.target.querySelector('#username');
      await submitForm('/update-username', { newUsername: usernameInput.value.trim() }, 'Username updated!');
      usernameInput.placeholder = usernameInput.value.trim();
    });

    document.getElementById('change-email-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = e.target.querySelector('#email').value.trim();
      await submitForm('/change-email', { email }, 'Email updated!');
    });

    document.getElementById('change-description-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const descEl = e.target.querySelector('#description');
      await submitForm('/update-description', { description: descEl.value.trim() }, 'Description updated!');
      descEl.placeholder = descEl.value.trim();
    });

    document.getElementById('change-password-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      await submitForm('/change-password', {
        currentPassword: form.querySelector('#currentPassword').value,
        newPassword: form.querySelector('#newPassword').value
      }, 'Password updated!', '/login?err=UpdatedCredentials');
    });

    const usernameInput = document.getElementById('username');
    const changeUsernameBtn = document.getElementById('change-username-btn');
    const usernameFeedback = document.getElementById('username-feedback');
    let usernameTimer;

    usernameInput?.addEventListener('input', () => {
      clearTimeout(usernameTimer);
      usernameTimer = setTimeout(async () => {
        const username = usernameInput.value.trim().toLowerCase();
        if (!username) { changeUsernameBtn.disabled = true; return; }
        try {
          const res = await fetch(`/check-username?username=${encodeURIComponent(username)}`);
          const data = await res.json();
          usernameFeedback.textContent = data.exists ? '<%= req.translations.usernameTaken %>' : '<%= req.translations.usernameIsNotTaken %>';
          changeUsernameBtn.disabled = data.exists;
        } catch (e) {
          changeUsernameBtn.disabled = true;
        }
      }, 500);
    });

    const currentPasswordInput = document.getElementById('currentPassword');
    const newPasswordInput = document.getElementById('newPassword');
    const currentPasswordFeedback = document.getElementById('current-password-feedback');
    let passwordTimer;

    currentPasswordInput?.addEventListener('input', () => {
      clearTimeout(passwordTimer);
      passwordTimer = setTimeout(async () => {
        const currentPassword = currentPasswordInput.value.trim();
        if (!currentPassword) { newPasswordInput.disabled = true; return; }
        try {
          const res = await fetch('/validate-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCSRF() },
            body: JSON.stringify({ currentPassword })
          });
          const data = await res.json();
          currentPasswordFeedback.textContent = data.valid ? '<%= req.translations.correctPassword %>' : '<%= req.translations.incorrectPassword %>';
          newPasswordInput.disabled = !data.valid;
        } catch (e) {
          newPasswordInput.disabled = true;
        }
      }, 500);
    });

    document.getElementById('language-preference-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const language = e.target.querySelector('#language').value;
      try {
        const res = await fetch('/set-language', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCSRF() },
          body: JSON.stringify({ language })
        });
        if (res.ok) {
          showToast('Language saved.', 'success');
          setTimeout(() => window.location.reload(), 1500);
        } else {
          const body = await res.text();
          showToast(body || 'Failed to save language.', 'error');
        }
      } catch (err) {
        showToast(err.message || 'Failed to save language.', 'error');
      }
    });

    // Avatar upload
    const avatarInput = document.getElementById('avatar-input');
    const avatarPreview = document.getElementById('avatar-preview');

    avatarInput?.addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file) return;

      if (file.size > 2 * 1024 * 1024) {
        showToast('Image must be under 2 MB.', 'error');
        return;
      }

      const formData = new FormData();
      formData.append('avatar', file);

      try {
        const response = await fetch('/upload-avatar', {
          method: 'POST',
          headers: { 'CSRF-Token': getCSRF() },
          body: formData,
        });

        if (response.ok) {
          const data = await response.json();
          avatarPreview.src = data.avatar;
          showToast('Profile picture updated.', 'success');
        } else {
          const err = await response.json().catch(() => ({}));
          showToast(err.message || 'Failed to upload image.', 'error');
        }
      } catch {
        showToast('Failed to upload image.', 'error');
      }
    });

    document.getElementById('remove-avatar-btn')?.addEventListener('click', async () => {
      try {
        const response = await fetch('/remove-avatar', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCSRF() },
        });

        if (response.ok) {
          avatarPreview.src = 'https://api.dicebear.com/9.x/thumbs/svg?seed=<%= encodeURIComponent(user.username) %>';
          showToast('Profile picture removed.', 'success');
          setTimeout(() => window.location.reload(), 1200);
        } else {
          showToast('Failed to remove picture.', 'error');
        }
      } catch {
        showToast('Failed to remove picture.', 'error');
      }
    });
  });
</script>

<%- include('../components/footer') %>
