            <div class="min-w-0 flex-1">
              <dt class="text-[10px] font-medium text-neutral-500 truncate"><%= req.translations.Image %></dt>
              <dd class="mt-0.5 text-xs font-medium text-neutral-800 dark:text-white truncate"><%= server.image.name %></dd>
            </div>
            <div class="rounded-lg p-2 bg-neutral-100 dark:bg-neutral-700/50 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="h-4 w-4 text-neutral-500 dark:text-neutral-400"><rect width="256" height="256" fill="none"/><path d="M243.31,136,144,36.69A15.86,15.86,0,0,0,132.69,32H40a8,8,0,0,0-8,8v92.69A15.86,15.86,0,0,0,36.69,144L136,243.31a16,16,0,0,0,22.63,0l84.68-84.68a16,16,0,0,0,0-22.63ZM84,96A12,12,0,1,1,96,84,12,12,0,0,1,84,96Z"/></svg>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3">
          <div class="flex items-center gap-2">
            <div class="min-w-0 flex-1">
              <dt class="text-[10px] font-medium text-neutral-500 truncate"><%= req.translations.Node %></dt>
              <dd class="mt-0.5 text-xs font-medium text-neutral-800 dark:text-white truncate"><%= server.node.name %></dd>
            </div>
            <div class="rounded-lg p-2 bg-neutral-100 dark:bg-neutral-700/50 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="h-4 w-4 text-neutral-500 dark:text-neutral-400"><rect width="256" height="256" fill="none"/><path d="M208,40H48A16,16,0,0,0,32,56v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V56A16,16,0,0,0,208,40ZM180,92a12,12,0,1,1,12-12A12,12,0,0,1,180,92Z"/><path d="M208,136H48a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V152A16,16,0,0,0,208,136Zm-28,52a12,12,0,1,1,12-12A12,12,0,0,1,180,188Z"/></svg>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3">
          <div class="flex items-center gap-2">
            <div class="min-w-0 flex-1">
              <dt class="text-[10px] font-medium text-neutral-500 truncate"><%= req.translations.identifier %></dt>
              <dd class="mt-0.5 text-xs font-medium text-neutral-800 dark:text-white font-mono"><%= server.UUID.split('-')[0] %></dd>
            </div>
            <div class="rounded-lg p-2 bg-neutral-100 dark:bg-neutral-700/50 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="h-4 w-4 text-neutral-500 dark:text-neutral-400"><rect width="256" height="256" fill="none"/><path d="M116.25,112h31.5l-8,32h-31.5ZM224,48V208a16,16,0,0,1-16,16H48a16,16,0,0,1-16-16V48A16,16,0,0,1,48,32H208A16,16,0,0,1,224,48Zm-16,56a8,8,0,0,0-8-8H168.25l7.51-30.06a8,8,0,0,0-15.52-3.88L151.75,96h-31.5l7.51-30.06a8,8,0,0,0-15.52-3.88L103.75,96H64a8,8,0,0,0,0,16H99.75l-8,32H56a8,8,0,0,0,0,16H87.75l-7.51,30.06a8,8,0,0,0,5.82,9.7,8.13,8.13,0,0,0,2,.24,8,8,0,0,0,7.75-6.06L104.25,160h31.5l-7.51,30.06a8,8,0,0,0,5.82,9.7A8.13,8.13,0,0,0,136,200a8,8,0,0,0,7.75-6.06L152.25,160H192a8,8,0,0,0,0-16H156.25l8-32H200A8,8,0,0,0,208,104Z"/></svg>
            </div>
          </div>
        </div>

      </dl>
    </div>

      <!-- Terminal -->
      <div class="rounded-xl bg-[#141414] border border-neutral-800 overflow-hidden">
        <div id="terminal-container" class="w-full">
          <div id="terminal"></div>
        </div>
        <div class="relative border-t border-neutral-800">
          <input id="input" type="text" autocomplete="off" placeholder="<%= req.translations.typeACommand || 'Type a command...' %>"
            class="w-full px-4 py-3 bg-neutral-800 text-white text-sm outline-none placeholder:text-neutral-500">
          <% if (typeof features !== 'undefined' && features && features.includes('auto-complete')) { %>
          <div id="settings-icon" class="absolute right-4 top-1/2 -translate-y-1/2 cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-neutral-500">
              <path stroke-linecap="round" stroke-linejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
          </div>
          <div id="suggestions" class="absolute bottom-full left-0 right-0 bg-neutral-800 text-white border border-neutral-600 rounded-t-lg max-h-40 overflow-y-auto hidden">
          </div>
          <div id="settings-menu" class="absolute bottom-full right-0 bg-neutral-800 text-white p-3 rounded-lg hidden w-48 border border-neutral-700">
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" id="auto-complete-toggle" class="w-4 h-4" />
              <span><%= req.translations.autoComplete || 'Auto-complete' %></span>
            </label>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Stats grid -->
      <div class="grid grid-cols-2 gap-3 mt-3">

        <!-- Status -->
        <div class="stats-card rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3 h-20">
          <canvas id="statusChart"></canvas>
          <div class="relative z-10">
            <p class="text-[10px] font-medium text-neutral-500"><%= req.translations.Status %></p>
            <p id="status" class="mt-0.5 text-base font-semibold text-neutral-800 dark:text-white leading-tight">—</p>
          </div>
        </div>

        <!-- RAM -->
        <div class="stats-card rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3 h-20">
          <canvas id="ramChart"></canvas>
          <div class="relative z-10">
            <p class="text-[10px] font-medium text-neutral-500"><%= req.translations.ramUsage %></p>
            <p id="ramUsage" class="mt-0.5 text-xs font-medium text-neutral-800 dark:text-white leading-tight break-all">0%</p>
          </div>
        </div>

        <!-- CPU -->
        <div class="stats-card rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3 h-20">
          <canvas id="cpuChart"></canvas>
          <div class="relative z-10">
            <p class="text-[10px] font-medium text-neutral-500"><%= req.translations.cpuUsage %></p>
            <p id="cpuUsage" class="mt-0.5 text-base font-semibold text-neutral-800 dark:text-white leading-tight">0%</p>
          </div>
        </div>

        <!-- Disk -->
        <div class="stats-card rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3 h-20">
          <canvas id="diskChart" class="hidden"></canvas>
          <div class="relative z-10">
            <p class="text-[10px] font-medium text-neutral-500"><%= req.translations.diskUsage %></p>
            <p id="diskUsage" class="mt-0.5 text-xs font-medium text-neutral-800 dark:text-white leading-tight break-all">—</p>
