<%- include('../../components/header', { title: 'Server Settings' }) %>

<main class="">
  <%- include('../../components/template') %>

  <section class="px-4 py-5">

    <header class="mb-5">
      <%- include('../../components/serverHeader') %>
    </header>

    <%- include('../../components/installHeader') %>
    <%- include('../../components/serverTemplate') %>

    <div class="space-y-4 mt-4">

      <!-- Settings form -->
      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
        <h2 class="text-sm font-medium text-neutral-800 dark:text-white mb-1">Server Settings</h2>
        <p class="text-xs text-neutral-500 mb-4">Configure your server's basic settings.</p>
        <form id="serverSettingsForm" class="space-y-3">
          <div>
            <label for="serverName" class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Server Name</label>
            <input type="text" id="serverName" name="name" value="<%= server.name %>"
              class="w-full rounded-xl text-sm px-3 py-2 bg-neutral-100 dark:bg-neutral-700/30 border border-neutral-200 dark:border-white/5 text-neutral-800 dark:text-white focus:outline-none focus:ring-1 focus:ring-neutral-400">
          </div>
          <div>
            <label for="serverDescription" class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Description</label>
            <input type="text" id="serverDescription" name="description" value="<%= server.description || '' %>"
              class="w-full rounded-xl text-sm px-3 py-2 bg-neutral-100 dark:bg-neutral-700/30 border border-neutral-200 dark:border-white/5 text-neutral-800 dark:text-white focus:outline-none focus:ring-1 focus:ring-neutral-400">
          </div>
          <button type="submit" class="rounded-xl bg-blue-600 hover:bg-blue-500 px-4 py-2 text-sm font-medium text-white transition">Save Settings</button>
        </form>
      </div>

      <!-- Server info -->
      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
        <h2 class="text-sm font-medium text-neutral-800 dark:text-white mb-3">Server Information</h2>
        <dl class="grid grid-cols-2 gap-x-4 gap-y-3">
          <div>
            <dt class="text-[10px] font-medium text-neutral-500 uppercase tracking-wide">Node</dt>
            <dd class="text-sm text-neutral-700 dark:text-neutral-300 mt-0.5 truncate"><%= server.node.name %></dd>
          </div>
          <div>
            <dt class="text-[10px] font-medium text-neutral-500 uppercase tracking-wide">Image</dt>
            <dd class="text-sm text-neutral-700 dark:text-neutral-300 mt-0.5 truncate"><%= server.image.name || 'Unknown' %></dd>
          </div>
          <div>
            <dt class="text-[10px] font-medium text-neutral-500 uppercase tracking-wide">Memory</dt>
            <dd class="text-sm text-neutral-700 dark:text-neutral-300 mt-0.5"><%= server.Memory %> GB</dd>
          </div>
          <div>
            <dt class="text-[10px] font-medium text-neutral-500 uppercase tracking-wide">CPU</dt>
            <dd class="text-sm text-neutral-700 dark:text-neutral-300 mt-0.5"><%= server.Cpu * 100 %>%</dd>
          </div>
          <div>
            <dt class="text-[10px] font-medium text-neutral-500 uppercase tracking-wide">Storage</dt>
            <dd class="text-sm text-neutral-700 dark:text-neutral-300 mt-0.5"><%= server.Storage %> GB</dd>
          </div>
          <div>
            <dt class="text-[10px] font-medium text-neutral-500 uppercase tracking-wide">Status</dt>
            <dd class="mt-0.5">
              <span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium ring-1 ring-inset
                <%= server.Suspended ? 'bg-yellow-50 dark:bg-yellow-600/10 text-yellow-700 dark:text-yellow-400 ring-yellow-600/20' : 'bg-emerald-50 dark:bg-emerald-600/10 text-emerald-700 dark:text-emerald-400 ring-emerald-600/20' %>">
                <%= server.Suspended ? 'Suspended' : 'Active' %>
              </span>
            </dd>
          </div>
          <div class="col-span-2">
            <dt class="text-[10px] font-medium text-neutral-500 uppercase tracking-wide">Server ID</dt>
            <dd class="text-xs text-neutral-500 dark:text-neutral-400 font-mono mt-0.5 truncate"><%= server.UUID %></dd>
          </div>
          <div class="col-span-2">
            <dt class="text-[10px] font-medium text-neutral-500 uppercase tracking-wide">Created</dt>
            <dd class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5"><%= new Date(server.createdAt).toLocaleString() %></dd>
          </div>
        </dl>
      </div>

      <!-- Danger zone -->
      <div class="rounded-xl bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-800/20 p-4">
        <h2 class="text-sm font-medium text-red-700 dark:text-red-400 mb-3">Danger Zone</h2>
        <div class="space-y-3">
          <div class="flex items-center justify-between gap-3">
            <div class="min-w-0">
              <p class="text-xs font-medium text-neutral-700 dark:text-neutral-300">Restart Server</p>
              <p class="text-xs text-neutral-500">Force a restart of your server.</p>
            </div>
            <button id="restartButton" type="button"
              class="shrink-0 rounded-xl bg-red-600 hover:bg-red-500 text-white px-3 py-2 text-xs font-medium transition">
              Restart
            </button>
          </div>
          <div class="h-px bg-red-200 dark:bg-red-800/30"></div>
          <div class="flex items-center justify-between gap-3">
            <div class="min-w-0">
              <p class="text-xs font-medium text-neutral-700 dark:text-neutral-300">Reinstall Server</p>
              <p class="text-xs text-neutral-500">Reinstall from scratch — all data will be lost.</p>
            </div>
            <button id="reinstallButton" type="button"
              class="shrink-0 rounded-xl bg-red-600 hover:bg-red-500 text-white px-3 py-2 text-xs font-medium transition">
              Reinstall
            </button>
          </div>
        </div>
      </div>

    </div>
  </section>
</main>

<%- include('../../components/toast') %>
<%- include('../../components/loadingPopup') %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var serverSettingsForm = document.getElementById('serverSettingsForm');
    var restartButton = document.getElementById('restartButton');
    var reinstallButton = document.getElementById('reinstallButton');

    serverSettingsForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var formData = new FormData(serverSettingsForm);
      var settings = { name: formData.get('name'), description: formData.get('description') };
      var loader = showLoadingPopup('Updating Server Settings', 'Saving your changes...');
      fetch('/server/<%= server.UUID %>/settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(settings)
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        loader.close();
        if (data.success) {
          showToast('Settings saved.', 'success');
          setTimeout(function() { window.location.reload(); }, 1500);
        } else {
          showToast('Failed: ' + (data.error || 'Unknown error'), 'error');
        }
      })
      .catch(function(err) { loader.close(); showToast('An error occurred.', 'error'); });
    });

    function makeModal(title, body, confirmLabel, onConfirm) {
      var modal = document.createElement('div');
      modal.className = 'fixed inset-0 bg-black/50 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200';
      modal.innerHTML = '<div class="bg-white dark:bg-neutral-800 rounded-xl p-5 w-full mx-4 transform scale-95 transition-transform duration-200">' +
        '<h2 class="text-base font-medium text-neutral-800 dark:text-white mb-1">' + title + '</h2>' +
        '<p class="text-sm text-neutral-600 dark:text-neutral-400 mb-5">' + body + '</p>' +
        '<div class="flex justify-end gap-2">' +
          '<button class="cancel-btn px-4 py-2 rounded-xl bg-neutral-200 dark:bg-neutral-700 text-neutral-800 dark:text-white text-sm hover:bg-neutral-300 dark:hover:bg-neutral-600 transition">Cancel</button>' +
          '<button class="confirm-btn rounded-xl bg-red-600 hover:bg-red-500 text-white px-4 py-2 text-sm font-medium transition">' + confirmLabel + '</button>' +
        '</div></div>';
      document.body.appendChild(modal);
      setTimeout(function() {
        modal.classList.remove('opacity-0', 'pointer-events-none');
        modal.querySelector('div').classList.remove('scale-95');
        modal.querySelector('div').classList.add('scale-100');
      }, 10);
      function close() {
        modal.classList.add('opacity-0', 'pointer-events-none');
        setTimeout(function() { document.body.removeChild(modal); }, 200);
      }
      modal.querySelector('.cancel-btn').addEventListener('click', close);
      modal.querySelector('.confirm-btn').addEventListener('click', function() { close(); onConfirm(); });
    }

    restartButton.addEventListener('click', function() {
      makeModal('Confirm Restart', 'Are you sure you want to restart the server? This will disconnect all users.', 'Restart', function() {
        var loader = showLoadingPopup('Restarting Server', 'Initiating server restart...');
        fetch('/server/<%= server.UUID %>/power/restart', { method: 'POST' })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            loader.close();
            if (data.success || data.message) { showToast('Restart initiated.', 'success'); }
            else { showToast('Failed: ' + (data.error || 'Unknown error'), 'error'); }
          })
          .catch(function() { loader.close(); showToast('An error occurred.', 'error'); });
      });
    });

    reinstallButton.addEventListener('click', function() {
      makeModal('Confirm Reinstallation', 'WARNING: This will delete all data and reinstall from scratch. This cannot be undone.', 'Reinstall', function() {
        makeModal('Final Warning', 'All server data will be permanently deleted. Proceed?', 'Proceed', function() {
          var loader = showLoadingPopup('Reinstalling Server', 'Initiating server reinstallation...');
          loader.updateProgress(10, 'Preparing...');
          fetch('/server/<%= server.UUID %>/reinstall', { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              loader.updateProgress(100, 'Reinstallation initiated!');
              setTimeout(function() {
                loader.close();
                if (data.success) { showToast('Reinstallation started. This may take a few minutes.', 'success'); }
                else { showToast('Failed: ' + (data.error || 'Unknown error'), 'error'); }
              }, 1000);
            })
            .catch(function() { loader.close(); showToast('An error occurred.', 'error'); });
        });
      });
    });
  });
</script>
