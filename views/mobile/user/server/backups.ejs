<%- include('../../components/header', { title: 'Backups' }) %>

<main class="">
  <div id="message-container" class="fixed bottom-24 left-4 right-4 z-50"></div>
  <%- include('../../components/template') %>

  <section class="px-4 py-5">

    <header class="mb-5">
      <%- include('../../components/serverHeader') %>
      <div class="flex gap-2 mt-3">
        <button id="createBackup" onclick="openCreateBackupModal()" type="button"
          class="flex items-center gap-1.5 rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Create Backup
        </button>
      </div>
    </header>

    <%- include('../../components/installHeader') %>
    <%- include('../../components/serverTemplate') %>

    <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 overflow-hidden mt-4">
      <div class="px-4 py-3 border-b border-neutral-200 dark:border-white/5">
        <p class="text-sm font-medium text-neutral-800 dark:text-white">Server Backups</p>
        <p class="text-xs text-neutral-500 mt-0.5">Manage your server backups.</p>
      </div>

      <% if (backups && backups.length > 0) { %>
      <div class="divide-y divide-neutral-200 dark:divide-white/5">
        <% backups.forEach(function(backup) { %>
        <div class="px-4 py-3" data-backup-id="<%= backup.UUID %>">
          <div class="flex items-start justify-between gap-3 mb-2">
            <div class="min-w-0">
              <p class="text-sm font-medium text-neutral-800 dark:text-white truncate"><%= backup.name %></p>
              <p class="text-xs text-neutral-500 mt-0.5">
                <%= backup.size ? (Number(backup.size) / (1024 * 1024)).toFixed(2) + ' MB' : 'Unknown size' %>
                &middot; <%= new Date(backup.createdAt).toLocaleDateString() %>
              </p>
            </div>
          </div>
          <div class="flex gap-2">
            <button onclick="downloadBackup('<%= backup.UUID %>')"
              class="flex-1 rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">
              Download
            </button>
            <button onclick="restoreBackup('<%= backup.UUID %>', '<%= backup.name %>')"
              class="flex-1 rounded-xl bg-emerald-600 hover:bg-emerald-500 px-3 py-2 text-xs font-medium text-white transition">
              Restore
            </button>
            <button onclick="deleteBackup('<%= backup.UUID %>', '<%= backup.name %>')"
              class="flex-1 rounded-xl bg-red-600 hover:bg-red-500 px-3 py-2 text-xs font-medium text-white transition">
              Delete
            </button>
          </div>
        </div>
        <% }); %>
      </div>
      <% } else { %>
      <div class="px-4 py-10 text-center">
        <svg class="mx-auto h-10 w-10 text-neutral-300 dark:text-neutral-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75"></path>
        </svg>
        <p class="text-sm font-medium text-neutral-700 dark:text-neutral-300">No backups yet</p>
        <p class="text-xs text-neutral-500 mt-1">Create your first backup to get started.</p>
      </div>
      <% } %>
    </div>

  </section>
</main>

<%- include('../../components/toast') %>

<!-- Loading modal -->
<div id="loading-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
  <div class="bg-white dark:bg-neutral-800 rounded-xl p-5 mx-4 flex items-center gap-3">
    <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-blue-600 shrink-0"></div>
    <div>
      <p class="text-sm font-medium text-neutral-800 dark:text-white" id="loading-title">Working...</p>
      <p class="text-xs text-neutral-500" id="loading-message">Please wait.</p>
    </div>
  </div>
</div>

<!-- Confirmation modal -->
<div id="confirmation-modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
  <div class="bg-white dark:bg-neutral-800 rounded-xl p-5 w-full mx-4">
    <p class="text-base font-medium text-neutral-800 dark:text-white mb-1" id="confirmation-title">Confirm</p>
    <p class="text-sm text-neutral-600 dark:text-neutral-400 mb-5" id="confirmation-message"></p>
    <div class="flex justify-end gap-2">
      <button id="confirmation-cancel" class="px-4 py-2 rounded-xl bg-neutral-200 dark:bg-neutral-700 text-neutral-800 dark:text-white text-sm hover:bg-neutral-300 dark:hover:bg-neutral-600 transition">Cancel</button>
      <button id="confirmation-confirm" class="px-4 py-2 rounded-xl bg-red-600 hover:bg-red-500 text-white text-sm font-medium transition">Confirm</button>
    </div>
  </div>
</div>

<!-- Create Backup modal -->
<div id="createBackupModal" class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-200">
  <div class="bg-white dark:bg-neutral-800 rounded-xl p-5 w-full mx-4 transform scale-95 transition-transform duration-200">
    <p class="text-base font-medium text-neutral-800 dark:text-white mb-1">Create Backup</p>
    <p class="text-sm text-neutral-500 mb-4">Choose a name for this backup.</p>
    <input type="text" id="backupName"
      class="w-full px-3 py-2 rounded-xl border border-neutral-200 dark:border-neutral-600 bg-neutral-50 dark:bg-neutral-700 text-neutral-800 dark:text-white text-sm focus:outline-none focus:ring-1 focus:ring-neutral-400 mb-4"
      placeholder="<%= req.translations.backupName || 'Backup name' %>"
      onkeydown="handleBackupNameKeyPress(event)">
    <div class="flex justify-end gap-2">
      <button onclick="closeCreateBackupModal()" class="px-4 py-2 rounded-xl bg-neutral-200 dark:bg-neutral-700 text-neutral-800 dark:text-white text-sm hover:bg-neutral-300 dark:hover:bg-neutral-600 transition">Cancel</button>
      <button onclick="confirmCreateBackup()" class="px-4 py-2 rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 text-sm font-medium hover:bg-neutral-700 dark:hover:bg-neutral-100 transition">Create</button>
    </div>
  </div>
</div>

<script>
var serverUUID = '<%= server.UUID %>';

function showLoading(title, message) {
  document.getElementById('loading-title').textContent = title;
  document.getElementById('loading-message').textContent = message;
  var m = document.getElementById('loading-modal');
  m.classList.remove('hidden');
  m.classList.add('flex');
}
function hideLoading() {
  var m = document.getElementById('loading-modal');
  m.classList.add('hidden');
  m.classList.remove('flex');
}
function showConfirmation(title, message, onConfirm) {
  document.getElementById('confirmation-title').textContent = title;
  document.getElementById('confirmation-message').textContent = message;
  var m = document.getElementById('confirmation-modal');
  m.classList.remove('hidden');
  m.classList.add('flex');
  document.getElementById('confirmation-confirm').onclick = function() {
    hideConfirmation();
    onConfirm();
  };
}
function hideConfirmation() {
  var m = document.getElementById('confirmation-modal');
  m.classList.add('hidden');
  m.classList.remove('flex');
}
document.getElementById('confirmation-cancel').onclick = hideConfirmation;

function openCreateBackupModal() {
  var modal = document.getElementById('createBackupModal');
  modal.classList.remove('opacity-0', 'pointer-events-none');
  modal.querySelector('div').classList.remove('scale-95');
  modal.querySelector('div').classList.add('scale-100');
  document.getElementById('backupName').focus();
}
function closeCreateBackupModal() {
  var modal = document.getElementById('createBackupModal');
  modal.classList.add('opacity-0', 'pointer-events-none');
  modal.querySelector('div').classList.remove('scale-100');
  modal.querySelector('div').classList.add('scale-95');
  document.getElementById('backupName').value = '';
}
function handleBackupNameKeyPress(e) {
  if (e.key === 'Enter') { e.preventDefault(); confirmCreateBackup(); }
}

async function confirmCreateBackup() {
  var name = document.getElementById('backupName').value.trim();
  if (!name) { showToast('Please enter a backup name.', 'error'); return; }
  closeCreateBackupModal();
  var loading = showLoadingToast('Creating backup...');
  var progress = 0;
  var interval = setInterval(function() {
    progress += 10;
    loading.updateProgress(progress);
    if (progress >= 90) clearInterval(interval);
  }, 300);
  try {
    var res = await fetch('/server/' + serverUUID + '/backups/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: name })
    });
    var data = await res.json();
    clearInterval(interval);
    if (data.success) {
      loading.updateProgress(100);
      showToast('Backup created!', 'success');
      addBackupRow(data.backup);
    } else {
      loading.close();
      showToast(data.error || 'Failed to create backup.', 'error');
    }
  } catch(err) {
    clearInterval(interval);
    loading.close();
    showToast('Failed to create backup.', 'error');
  }
}

function downloadBackup(id) {
  window.location.href = '/server/' + serverUUID + '/backups/' + id + '/download';
}

function restoreBackup(id, name) {
  showConfirmation('Restore Backup',
    'Restore "' + name + '"? This will replace all current server files and cannot be undone.',
    async function() {
      showLoading('Restoring backup...', 'This may take a few minutes.');
      try {
        var res = await fetch('/server/' + serverUUID + '/backups/' + id + '/restore', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        var data = await res.json();
        if (data.success) { showToast('Backup restored!', 'success'); }
        else { showToast(data.error || 'Failed to restore.', 'error'); }
      } catch(e) { showToast('Failed to restore.', 'error'); }
      finally { hideLoading(); }
    }
  );
}

function deleteBackup(id, name) {
  showConfirmation('Delete Backup',
    'Delete "' + name + '"? This cannot be undone.',
    async function() {
      try {
        var res = await fetch('/server/' + serverUUID + '/backups/' + id, { method: 'DELETE', headers: { 'Content-Type': 'application/json' } });
        var data = await res.json();
        if (data.success) {
          showToast('Backup deleted.', 'success');
          var row = document.querySelector('[data-backup-id="' + id + '"]');
          if (row) row.remove();
        } else { showToast(data.error || 'Failed to delete.', 'error'); }
      } catch(e) { showToast('Failed to delete.', 'error'); }
    }
  );
}

function addBackupRow(backup) {
  var list = document.querySelector('.divide-y');
  if (!list) return;
  var div = document.createElement('div');
  div.className = 'px-4 py-3';
  div.setAttribute('data-backup-id', backup.UUID);
  div.innerHTML =
    '<div class="flex items-start justify-between gap-3 mb-2">' +
      '<div class="min-w-0">' +
        '<p class="text-sm font-medium text-neutral-800 dark:text-white truncate">' + backup.name + '</p>' +
        '<p class="text-xs text-neutral-500 mt-0.5">Just created</p>' +
      '</div>' +
    '</div>' +
    '<div class="flex gap-2">' +
      '<button onclick="downloadBackup(\'' + backup.UUID + '\')" class="flex-1 rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">Download</button>' +
      '<button onclick="restoreBackup(\'' + backup.UUID + '\', \'' + backup.name + '\')" class="flex-1 rounded-xl bg-emerald-600 hover:bg-emerald-500 px-3 py-2 text-xs font-medium text-white transition">Restore</button>' +
      '<button onclick="deleteBackup(\'' + backup.UUID + '\', \'' + backup.name + '\')" class="flex-1 rounded-xl bg-red-600 hover:bg-red-500 px-3 py-2 text-xs font-medium text-white transition">Delete</button>' +
    '</div>';
  list.prepend(div);
}
</script>

<%- include('../../components/footer') %>
